@* [ACURATEX] Control de una posición servo del sistema unificado.
   [FLUJO] UI -> callbacks -> dashboard padre -> servicio -> firmware. *@
<section class="position-block">
    <div class="position-title">
        <span>Posici&oacute;n @Position.Number</span>
        @if (CanClose)
        {
            <button class="position-close"
                    type="button"
                    title="Quitar posicion"
                    disabled="@Disabled"
                    @onclick="() => CloseClicked.InvokeAsync(Position.Number)">
                &times;
            </button>
        }
    </div>

    <div class="goto-row">
        <input type="number"
               placeholder="@Placeholder"
               value="@Position.Target"
               min="0"
               max="1000"
               step="1"
               disabled="@Disabled"
               @oninput="HandleTargetInput" />
        <button class="@GotoClass"
                type="button"
                disabled="@Disabled"
                @onpointerdown="SetPressing"
                @onpointerup="ClearPressing"
                @onpointerleave="ClearPressing"
                @onpointercancel="ClearPressing"
                @onclick="HandleGoToAsync">
            IR A POS. @Position.Number
        </button>
    </div>

    <div class="turn-control">
        <button class="turn-btn minus"
                type="button"
                disabled="@Disabled"
                @onclick="() => TurnsChanged.InvokeAsync(new ServoDashboardUnificadoTurnsChange(Position.Number, -1))">
            &minus;
        </button>
        <div class="turn-display">@TurnsText</div>
        <button class="turn-btn plus"
                type="button"
                disabled="@Disabled"
                @onclick="() => TurnsChanged.InvokeAsync(new ServoDashboardUnificadoTurnsChange(Position.Number, 1))">
            +
        </button>
    </div>
</section>

@code {
    // [C#] Este campo privado solo cambia la clase CSS mientras el botón está presionado.
    // [ACURATEX] No altera el hardware; solo da feedback visual inmediato.
    private bool _isPressing;

    // [ACURATEX] La posición llega armada desde el padre con número, objetivo y vueltas.
    [Parameter, EditorRequired]
    public ServoDashboardUnificadoPosition Position { get; set; } = new(1);

    [Parameter]
    public bool CanClose { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public EventCallback<int> CloseClicked { get; set; }

    [Parameter]
    public EventCallback<int> GoToClicked { get; set; }

    [Parameter]
    public EventCallback<ServoDashboardUnificadoTurnsChange> TurnsChanged { get; set; }

    [Parameter]
    public EventCallback<ServoDashboardUnificadoTargetChange> TargetChanged { get; set; }

    // [ACURATEX] El placeholder ayuda a que el operador recuerde qué posición está editando.
    private string Placeholder => $"Ingrese posicion {Position.Number}";

    // [ACURATEX] El estilo visual depende de si el botón está presionado o deshabilitado.
    private string GotoClass => Disabled
        ? "goto-btn disabled"
        : _isPressing ? "goto-btn pressing" : "goto-btn";

    private string TurnsText => Position.Turns switch
    {
        0 => "0 vueltas",
        1 => "+1 vuelta",
        -1 => "-1 vuelta",
        > 0 => $"+{Position.Turns} vueltas",
        _ => $"{Position.Turns} vueltas"
    };

    // [ACURATEX] Convierte el texto escrito en una intención de cambio enviada al padre.
    private async Task HandleTargetInput(ChangeEventArgs args)
    {
        if (Disabled) {
            return;
        }

        if (decimal.TryParse(args.Value?.ToString(), out decimal value)) {
            await TargetChanged.InvokeAsync(new ServoDashboardUnificadoTargetChange(Position.Number, value));
        }
    }

    // [ACURATEX] El click confirma la orden de ir a esa posición lógica.
    private async Task HandleGoToAsync()
    {
        if (Disabled) {
            return;
        }

        await GoToClicked.InvokeAsync(Position.Number);
    }

    // [ACURATEX] Estas dos funciones solo cambian la apariencia de presión del botón.
    private void SetPressing()
    {
        if (Disabled) {
            return;
        }

        _isPressing = true;
    }

    private void ClearPressing()
    {
        _isPressing = false;
    }
}
