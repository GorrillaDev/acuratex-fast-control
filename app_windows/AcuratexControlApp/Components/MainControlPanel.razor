    // [ACURATEX] Devuelve la clase CSS de una fila de programa según su estado.
    private static string HeadProgramRowClass(HeadProgramInfo program)
    {
        string css = "head-program-admin-row";
        if (program.IsActive) {
            css += " active";
        }

        if (!program.IsValid) {
