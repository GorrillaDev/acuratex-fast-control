        _duplicateUploadDialog = null;
        _localTempStatusMessage = "Subida cancelada. No se subio ningun archivo.";
    }

    /// <summary>
    /// [POR QUÉ EXISTE]
    /// Esta función existe para subir los archivos locales uno por uno con progreso agregado.
    ///
    /// [QUIÉN LA LLAMA]
    /// La llaman los flujos de subida local y los diálogos de duplicados.
    ///
    /// [CUÁNDO SE EJECUTA]
    /// Se ejecuta al confirmar una subida de archivos temporales.
    ///
    /// [ENTRADAS]
    /// Recibe la lista de archivos y cuántos se omitieron.
    ///
    /// [SALIDAS]
    /// Devuelve `Task`.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Lee archivos locales, manda FILE_* y actualiza progreso por lote.
    ///
    /// [FLUJO ACURATEX]
    /// UI -> UploadLocalTempFilesSequentialAsync -> archivo local -> firmware.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a enviar varios bloques de memoria en secuencia con estado agregado.
    ///
    /// [SI NO EXISTIERA]
    /// La subida por lotes no tendría una rutina central.
    /// </summary>
    /// <summary>
    /// [POR QUE EXISTE]
    /// Este metodo existe para subir los archivos locales uno por uno y mantener un progreso agregado.
    ///
    /// [QUIEN LO LLAMA]
    /// Lo llaman la subida directa y los dialogos de duplicados.
    ///
    /// [CUANDO SE EJECUTA]
    /// Se ejecuta al confirmar una subida por lotes desde la carpeta temporal.
    ///
    /// [ENTRADAS]
    /// Recibe la lista de archivos y cuántos se omitieron.
    ///
    /// [SALIDAS]
    /// Devuelve una tarea asincrona.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Lee archivos locales, manda `FILE_*` y actualiza progreso por lote.
    ///
    /// [FLUJO ACURATEX]
    /// UI -> `UploadLocalTempFilesSequentialAsync()` -> archivo local -> firmware.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a enviar varios bloques de datos en secuencia con una barra global.
    ///
    /// [SI NO EXISTIERA]
    /// La subida por lotes no tendría una rutina central.
    /// </summary>
    private async Task UploadLocalTempFilesSequentialAsync(IReadOnlyList<LocalTempFileEntry> files, int omittedCount)
    {
        // [ACURATEX] La subida es secuencial para que el operador vea el progreso archivo por archivo.
        // [FLUJO] Lista local -> FILE_BEGIN/DATA/END repetidos -> firmware.
        if (files.Count == 0) {
            return;
        }

        _isLocalTempBusy = true;
        _isTesterFileBusy = true;
        _localTempUploadIssues = Array.Empty<LocalTempUploadIssue>();
        _localTempTotalFiles = files.Count;
        _localTempCurrentFileIndex = 0;
        _localTempCurrentFileProgressPercent = 0;
        _localTempGlobalProgressPercent = 0;
        _localTempCurrentFileName = string.Empty;
        SetLocalTempUploadState(files.Select(static file => file.FileName), "Pendiente");
        await InvokeAsync(StateHasChanged);

        int successCount = 0;
        int errorCount = 0;
        List<LocalTempUploadIssue> issues = new();

        try {
            for (int index = 0; index < files.Count; index++) {
                LocalTempFileEntry file = files[index];
                _localTempCurrentFileIndex = index + 1;
                _localTempCurrentFileName = file.FileName;
                _localTempCurrentFileProgressPercent = 0;
                _localTempStatusMessage = $"Subiendo archivo {_localTempCurrentFileIndex} de {_localTempTotalFiles}: {file.FileName}";
                UpdateLocalTempUploadState(file.FileName, "Subiendo");
                await InvokeAsync(StateHasChanged);

                try {
                    byte[] bytes = await LocalTempFileService.ReadTempFileBytesAsync(file.FileName, CancellationToken.None);
                    Progress<CommandFileUploadProgress> progress = new(report =>
                    {
                        _localTempCurrentFileProgressPercent = Math.Clamp(report.ProgressPercent, 0, 100);
                        _localTempGlobalProgressPercent = CalculateBatchProgress(index, files.Count, _localTempCurrentFileProgressPercent);
                        _localTempStatusMessage = $"Archivo {_localTempCurrentFileIndex} de {_localTempTotalFiles}: {file.FileName} - {report.Stage}";
                        _ = InvokeAsync(StateHasChanged);
                    });

                    await CommandFileTransferService.UploadTextFileAsync(
                        file.FileName,
                        bytes,
                        progress,
                        CancellationToken.None);

                    successCount++;
                    _localTempCurrentFileProgressPercent = 100;
                    _localTempGlobalProgressPercent = CalculateBatchProgress(index + 1, files.Count, 0);
                    UpdateLocalTempUploadState(file.FileName, "Subido correctamente");
                } catch (Exception ex) {
                    errorCount++;
                    string message = BuildUserErrorMessage(ex, "No se pudo subir el archivo.");
                    issues.Add(new LocalTempUploadIssue(file.FileName, message));
                    UpdateLocalTempUploadState(file.FileName, "Error");
                }
            }

            _localTempUploadIssues = issues;
            await ReloadTesterFilesCoreAsync();
            await RefreshLocalTempFilesCoreAsync();
            _localTempGlobalProgressPercent = 100;
            _localTempStatusMessage = $"Subida finalizada: {successCount} correctos, {omittedCount} omitido(s), {errorCount} errores.";
        } finally {
            _localTempCurrentFileName = string.Empty;
            _isLocalTempBusy = false;
            _isTesterFileBusy = false;
        }
    }

    // [ACURATEX] Abre un archivo temporal local dentro del editor de texto.
    /// <summary>
    /// [POR QUE EXISTE]
    /// Este metodo existe para abrir una copia temporal local dentro del editor de texto.
    ///
    /// [QUIEN LO LLAMA]
    /// Lo llama la UI de archivos temporales cuando el operador pulsa Abrir.
    ///
    /// [CUANDO SE EJECUTA]
    /// Se ejecuta cuando el usuario quiere mirar o editar una copia local.
    ///
    /// [ENTRADAS]
    /// Recibe el nombre del archivo temporal.
    ///
    /// [SALIDAS]
    /// Devuelve una tarea asincrona.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Lee bytes locales, llena el editor y recuerda la copia de trabajo.
    ///
    /// [FLUJO ACURATEX]
    /// UI -> `OpenLocalTempFileInEditorAsync()` -> archivo local -> editor.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a cargar un bloque de texto desde una tarjeta SD hacia un buffer editable.
    ///
    /// [SI NO EXISTIERA]
    /// No se podria abrir una copia temporal para editarla.
    /// </summary>
    private async Task OpenLocalTempFileInEditorAsync(string fileName)
    {
        // [ACURATEX] Abrir una copia local no toca el tester; solo carga la copia de trabajo en el editor.
        if (!CanManageTesterFiles || _isLocalTempBusy) {
            return;
        }

        if (!await ConfirmDiscardTesterFileChangesAsync()) {
            return;
        }

        try {
            byte[] bytes = await LocalTempFileService.ReadTempFileBytesAsync(fileName, CancellationToken.None);
            string fullPath = _localTempFiles.FirstOrDefault(file => string.Equals(file.FileName, fileName, StringComparison.OrdinalIgnoreCase))?.FullPath
                ?? Path.Combine(LocalTempFileService.GetTempFolderPath(), fileName);

            _openedTesterFileName = fileName;
            _selectedTesterFileName = fileName;
            _testerFileEditorText = Encoding.UTF8.GetString(bytes);
            _testerFileOriginalText = _testerFileEditorText;
            _testerFileTempPath = fullPath;
            _testerFileEditorOrigin = "Archivo temporal local";
            _testerFileStatusMessage = "Archivo temporal local abierto en editor.";
        } catch (Exception ex) {
            _localTempStatusMessage = BuildUserErrorMessage(ex, "No se pudo abrir el archivo temporal.");
        }
    }

    /// <summary>
    /// [POR QUÉ EXISTE]
    /// Esta función existe para refrescar la tabla de archivos remotos del tester.
    ///
    /// [QUIÉN LA LLAMA]
    /// La llama el botón de actualizar archivos del tester.
    ///
    /// [CUÁNDO SE EJECUTA]
    /// Se ejecuta cuando el usuario quiere volver a leer FILE_LIST.
    ///
    /// [ENTRADAS]
    /// No recibe parámetros.
    ///
    /// [SALIDAS]
    /// Devuelve `Task`.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Relee la lista remota y actualiza la barra de progreso.
    ///
    /// [FLUJO ACURATEX]
    /// UI -> RefreshTesterFilesAsync -> FILE_LIST -> tabla remota.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a consultar un índice de archivos en memoria externa.
    ///
    /// [SI NO EXISTIERA]
    /// La UI no podría refrescar la lista remota.
    /// </summary>
    /// <summary>
    /// [POR QUE EXISTE]
    /// Este metodo existe para volver a leer `FILE_LIST` y refrescar la tabla de archivos remotos.
    ///
    /// [QUIEN LO LLAMA]
    /// Lo llama el boton de actualizar archivos del tester.
    ///
    /// [CUANDO SE EJECUTA]
    /// Se ejecuta cuando el usuario quiere refrescar la lista remota.
    ///
    /// [ENTRADAS]
    /// No recibe parametros.
    ///
    /// [SALIDAS]
    /// Devuelve una tarea asincrona.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Actualiza progreso y vuelve a consultar la lista remota.
    ///
    /// [FLUJO ACURATEX]
    /// UI -> `RefreshTesterFilesAsync()` -> `FILE_LIST` -> tabla remota.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a consultar un indice de archivos en memoria externa.
    ///
    /// [SI NO EXISTIERA]
    /// La UI no podria refrescar la lista remota.
    /// </summary>
    private async Task RefreshTesterFilesAsync()
    {
        // [ACURATEX] Esta ruta vuelve a leer FILE_LIST y refresca la tabla remota visible.
        if (!CanManageTesterFiles) {
            return;
        }

        if (!State.IsConnected) {
            _testerFileStatusMessage = "Conecta el tester antes de actualizar la lista.";
            _testerFileProgressPercent = 0;
            return;
        }

        _isTesterFileBusy = true;
        _testerFileProgressPercent = 10;
        _testerFileStatusMessage = "Actualizando lista de archivos del tester...";
        await InvokeAsync(StateHasChanged);

        try {
            await ReloadTesterFilesCoreAsync();
            _testerFileProgressPercent = 100;
            _testerFileStatusMessage = _testerFiles.Count == 0
                ? "El tester no reporto archivos guardados."
                : $"Lista actualizada: {_testerFiles.Count} archivo(s).";
        } catch (Exception ex) {
            _testerFileProgressPercent = 0;
            _testerFileStatusMessage = BuildUserErrorMessage(ex, "No se pudo actualizar la lista de archivos.");
        } finally {
            _isTesterFileBusy = false;
        }
    }

    /// <summary>
    /// [POR QUÉ EXISTE]
    /// Esta función existe para descargar y abrir un archivo del tester en el editor.
    ///
    /// [QUIÉN LA LLAMA]
    /// La llama el botón Abrir de cada archivo remoto.
    ///
    /// [CUÁNDO SE EJECUTA]
    /// Se ejecuta cuando el usuario quiere editar o copiar un TXT remoto.
    ///
    /// [ENTRADAS]
    /// Recibe el nombre del archivo.
    ///
    /// [SALIDAS]
    /// Devuelve `Task`.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Descarga el archivo, llena el editor y marca la copia local.
    ///
    /// [FLUJO ACURATEX]
    /// UI -> OpenTesterFileAsync -> FILE_GET -> editor.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a leer un archivo externo y cargarlo en un buffer editable.
    ///
    /// [SI NO EXISTIERA]
    /// No se podrían abrir archivos remotos para editarlos.
    /// </summary>
    /// <summary>
    /// [POR QUE EXISTE]
    /// Este metodo existe para descargar un archivo remoto y abrirlo en el editor.
    ///
    /// [QUIEN LO LLAMA]
    /// Lo llama el boton Abrir de cada fila remota.
    ///
    /// [CUANDO SE EJECUTA]
    /// Se ejecuta cuando el operador quiere editar o copiar un TXT del tester.
    ///
    /// [ENTRADAS]
    /// Recibe el nombre del archivo remoto.
    ///
    /// [SALIDAS]
    /// Devuelve una tarea asincrona.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Descarga el texto, llena el editor y marca la copia local temporal.
    ///
    /// [FLUJO ACURATEX]
    /// UI -> `OpenTesterFileAsync()` -> `FILE_GET` -> editor.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a leer un archivo externo y cargarlo en un buffer editable.
    ///
    /// [SI NO EXISTIERA]
    /// No se podrian abrir archivos remotos para editarlos.
    /// </summary>
    private async Task OpenTesterFileAsync(string fileName)
    {
        // [ACURATEX] Abrir un remoto significa descargarlo, mostrarlo y recordar su copia local.
        // [ACURATEX] Abrir un archivo remoto significa descargarlo y llevarlo al editor local.
        // [FLUJO] Click Abrir -> DownloadFileAsync -> FILE_GET -> editor de texto.
        // [EQUIV MCU] Es como cargar un bloque de memoria externa en un buffer editable.
        if (!CanManageTesterFiles || _isTesterFileBusy || !State.IsConnected) {
            return;
        }

        if (!await ConfirmDiscardTesterFileChangesAsync()) {
            return;
        }

        _isTesterFileBusy = true;
        _testerFileProgressPercent = 10;
        _testerFileStatusMessage = $"Descargando {fileName} desde el tester...";
        // [C#] `InvokeAsync(StateHasChanged)` vuelve a pintar la UI antes de iniciar la descarga.
        await InvokeAsync(StateHasChanged);

        try {
            CommandFileDownloadResult result = await CommandFileTransferService.DownloadFileAsync(
                fileName,
                CancellationToken.None);

            if (!result.Success) {
                _testerFileProgressPercent = 0;
                _testerFileStatusMessage = result.ErrorMessage ?? "No se pudo descargar el archivo del tester.";
                return;
            }

            _selectedTesterFileName = result.FileName;
            _openedTesterFileName = result.FileName;
            _testerFileEditorText = result.Text;
            _testerFileOriginalText = result.Text;
            _testerFileTempPath = result.TempPath;
            _testerFileEditorOrigin = "Archivo abierto desde tester";
            _testerFileDownloadTimes[result.FileName] = DateTime.Now;
            _testerFiles = ApplyLocalDownloadTimes(_testerFiles);
            _testerFileProgressPercent = 100;
            _testerFileStatusMessage = "Archivo abierto desde tester.";
        } catch (Exception ex) {
            _testerFileProgressPercent = 0;
            _testerFileStatusMessage = BuildUserErrorMessage(ex, "No se pudo abrir el archivo del tester.");
        } finally {
            _isTesterFileBusy = false;
        }
    }

    // [ACURATEX] Selecciona un archivo remoto como activo en el tester.
    /// <summary>
    /// [POR QUE EXISTE]
    /// Este metodo existe para marcar un archivo remoto como activo en el tester sin abrirlo en el editor.
    ///
    /// [QUIEN LO LLAMA]
    /// Lo llama el boton Seleccionar de cada archivo remoto.
    ///
    /// [CUANDO SE EJECUTA]
    /// Se ejecuta cuando el operador quiere cambiar el archivo activo sin editarlo.
    ///
    /// [ENTRADAS]
    /// Recibe el nombre del archivo remoto.
    ///
    /// [SALIDAS]
    /// Devuelve una tarea asincrona.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Envia `SelectFileAsync` y actualiza la fila seleccionada en pantalla.
    ///
    /// [FLUJO ACURATEX]
    /// UI -> `SelectTesterFileAsync()` -> `FILE_SELECT` -> tester activo.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a seleccionar qué programa queda activo en una memoria de control.
    ///
    /// [SI NO EXISTIERA]
    /// La UI no podria cambiar el archivo activo sin abrirlo.
    /// </summary>
    private async Task SelectTesterFileAsync(string fileName)
    {
        // [ACURATEX] Seleccionar un archivo remoto solo cambia el activo en el tester; no abre el editor.
        // [ACURATEX] Esta accion solo marca un archivo como activo en el tester.
        // [FLUJO] Click Seleccionar -> SelectFileAsync -> tester confirma archivo activo.
        if (!CanManageTesterFiles || _isTesterFileBusy || !State.IsConnected) {
            return;
        }

        _isTesterFileBusy = true;
        _testerFileProgressPercent = 25;
        _testerFileStatusMessage = $"Seleccionando {fileName} en el tester...";
        // [ACURATEX] El estado cambia primero para que el operador vea que la orden ya fue enviada.
        await InvokeAsync(StateHasChanged);

        try {
            bool selected = await CommandFileTransferService.SelectFileAsync(fileName, CancellationToken.None);
            if (!selected) {
                _testerFileProgressPercent = 0;
                _testerFileStatusMessage = "El tester no confirmo la seleccion del archivo.";
                return;
            }

            _testerFiles = _testerFiles
                .Select(entry => entry with
                {
                    IsSelected = string.Equals(entry.FileName, fileName, StringComparison.OrdinalIgnoreCase)
                })
                .ToArray();
            _selectedTesterFileName = fileName;
            _testerFileProgressPercent = 100;
            _testerFileStatusMessage = "Archivo seleccionado en tester correctamente.";
        } catch (Exception ex) {
            _testerFileProgressPercent = 0;
            _testerFileStatusMessage = BuildUserErrorMessage(ex, "No se pudo seleccionar el archivo en el tester.");
        } finally {
            _isTesterFileBusy = false;
        }
    }

    // [ACURATEX] Guarda en tester el archivo actualmente abierto.
    /// <summary>
    /// [POR QUE EXISTE]
    /// Este metodo existe para guardar el archivo que ya esta abierto usando su mismo nombre.
    ///
    /// [QUIEN LO LLAMA]
    /// Lo llama el boton Guardar del editor.
    ///
    /// [CUANDO SE EJECUTA]
    /// Se ejecuta cuando el operador quiere sobrescribir el mismo archivo abierto.
    ///
    /// [ENTRADAS]
    /// No recibe parametros.
    ///
    /// [SALIDAS]
    /// Devuelve una tarea asincrona.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Reutiliza el nombre abierto y delega el guardado real al helper comun.
    ///
    /// [FLUJO ACURATEX]
    /// Editor -> `SaveOpenTesterFileAsync()` -> `SaveTesterFileTextAsync()`.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a presionar Save en un editor clasico sin cambiar el nombre del archivo.
    ///
    /// [SI NO EXISTIERA]
    /// Guardar tendria que duplicar la logica de "guardar como".
    /// </summary>
    private async Task SaveOpenTesterFileAsync()
    {
        // [ACURATEX] Guardar reutiliza el nombre ya abierto, igual que presionar Save en un editor clásico.
        // [ACURATEX] Guardar usa el nombre actualmente abierto.
        // [FLUJO] El texto ya editado se reenvía sin volver a pedir el archivo.
        if (_openedTesterFileName is null) {
            return;
        }

        // [ACURATEX] El editor no duplica el flujo de guardado; llama al helper que ya conoce el nombre.
        await SaveTesterFileTextAsync(_openedTesterFileName);
    }

    // [ACURATEX] Guarda el texto actual con otro nombre.
    /// <summary>
    /// [POR QUE EXISTE]
    /// Este metodo existe para guardar el texto del editor con un nombre nuevo elegido por el usuario.
    ///
    /// [QUIEN LO LLAMA]
    /// Lo llama el boton Guardar como.
    ///
    /// [CUANDO SE EJECUTA]
    /// Se ejecuta cuando el operador decide guardar una copia con otro nombre.
    ///
    /// [ENTRADAS]
    /// No recibe parametros directos; pide el nuevo nombre al navegador.
    ///
    /// [SALIDAS]
    /// Devuelve una tarea asincrona.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Pide un nombre por `prompt`, valida y reusa el flujo de guardado.
    ///
    /// [FLUJO ACURATEX]
    /// Editor -> `SaveOpenTesterFileAsAsync()` -> nombre nuevo -> `SaveTesterFileTextAsync()`.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a escribir un archivo con otro nombre en una memoria externa.
    ///
    /// [SI NO EXISTIERA]
    /// No se podria hacer una copia con nombre distinto desde el editor.
    /// </summary>
    private async Task SaveOpenTesterFileAsAsync()
    {
        // [ACURATEX] Guardar como pide un nombre nuevo y luego vuelve a usar el flujo común de guardado.
        // [ACURATEX] "Guardar como" solicita un nombre nuevo antes de subir el contenido.
        // [C#] `is null` evita confundir un nombre vacio con ausencia real de archivo abierto.
        if (_openedTesterFileName is null || _isTesterFileBusy || !State.IsConnected) {
            return;
        }

        // [C#] `JS.InvokeAsync<string?>("prompt", ...)` pide texto al navegador hospedado por Blazor.
        string? requestedName = await JS.InvokeAsync<string?>("prompt", "Guardar como", _openedTesterFileName);
        if (requestedName is null) {
            return;
        }

        string newName = NormalizeTesterFileName(requestedName);
        string? validationError = ValidateTesterFileNameForUi(newName);
        if (!string.IsNullOrWhiteSpace(validationError)) {
            _testerFileStatusMessage = validationError;
            await AlertService.ShowAsync("Guardar como", validationError, AppAlertKind.Warning);
            return;
        }

        await SaveTesterFileTextAsync(newName);
    }

    /// <summary>
    /// [POR QUÉ EXISTE]
    /// Esta función existe para subir al tester el texto del editor, ya sea como guardar
    /// normal o guardar como.
    ///
    /// [QUIÉN LA LLAMA]
    /// La llaman los botones de guardado del editor.
    ///
    /// [CUÁNDO SE EJECUTA]
    /// Se ejecuta cuando el usuario decide persistir cambios.
    ///
    /// [ENTRADAS]
    /// Recibe el nombre destino.
    ///
    /// [SALIDAS]
    /// Devuelve `Task`.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Llama al servicio FILE_* y actualiza el estado del editor.
    ///
    /// [FLUJO ACURATEX]
    /// Editor -> SaveTesterFileTextAsync -> FILE_* -> firmware.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a regrabar un bloque de memoria externa con el texto modificado.
    ///
    /// [SI NO EXISTIERA]
    /// El editor no podría guardar sus cambios en el tester.
    /// </summary>
    /// <summary>
    /// [POR QUE EXISTE]
    /// Este metodo existe para subir al tester el texto que quedo en el editor.
    ///
    /// [QUIEN LO LLAMA]
    /// Lo llaman Guardar y Guardar como.
    ///
    /// [CUANDO SE EJECUTA]
    /// Se ejecuta cuando el usuario decide persistir cambios en el tester.
    ///
    /// [ENTRADAS]
    /// Recibe el nombre de destino.
    ///
    /// [SALIDAS]
    /// Devuelve una tarea asincrona.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Envía `FILE_*`, actualiza estado del editor y refresca listados.
    ///
    /// [FLUJO ACURATEX]
    /// Editor -> `SaveTesterFileTextAsync()` -> `FILE_BEGIN/DATA/END` -> firmware.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a regrabar un bloque de memoria externa con el texto modificado.
    ///
    /// [SI NO EXISTIERA]
    /// El editor no podría guardar sus cambios en el tester.
    /// </summary>
    private async Task SaveTesterFileTextAsync(string fileName)
    {
        // [ACURATEX] El texto del editor es una copia de trabajo; esta rutina lo sube al tester.
        // [FLUJO] Editor -> SaveTesterFileTextAsync -> FILE_BEGIN/DATA/END -> firmware.
        if (!CanManageTesterFiles || _isTesterFileBusy || !State.IsConnected) {
            return;
        }

        string? validationError = ValidateTesterFileNameForUi(fileName);
        if (!string.IsNullOrWhiteSpace(validationError)) {
            _testerFileStatusMessage = validationError;
            await AlertService.ShowAsync("Guardar archivo", validationError, AppAlertKind.Warning);
            return;
        }

        int byteCount = Encoding.UTF8.GetByteCount(_testerFileEditorText);
        if (byteCount > MaxCommandFileSizeBytes) {
            _testerFileStatusMessage = $"El archivo supera {MaxCommandFileSizeBytes} bytes en UTF-8.";
            await AlertService.ShowAsync("Guardar archivo", _testerFileStatusMessage, AppAlertKind.Warning);
            return;
        }

        _isTesterFileBusy = true;
        _testerFileProgressPercent = 0;
        _testerFileStatusMessage = $"Subiendo {fileName} al tester...";
        // [C#] La actualización visual ocurre antes de la E/S para que el usuario vea el cambio inmediato.
        await InvokeAsync(StateHasChanged);

        try {
            // [ACURATEX] Igual que en la subida de comando, el progreso vuelve desde el servicio como callback.
            Progress<CommandFileUploadProgress> progress = new(report =>
            {
                _testerFileProgressPercent = Math.Clamp(report.ProgressPercent, 0, 100);
                _testerFileStatusMessage = report.Stage;
                _ = InvokeAsync(StateHasChanged);
            });

            CommandFileSaveResult result = await CommandFileTransferService.SaveEditedTextAsync(
                fileName,
                _testerFileEditorText,
                progress,
                CancellationToken.None);

            if (!result.Success) {
                _testerFileProgressPercent = 0;
                _testerFileStatusMessage = result.ErrorMessage ?? "No se pudo guardar el archivo en el tester.";
                return;
            }

            _openedTesterFileName = result.FileName;
            _selectedTesterFileName = result.FileName;
            _testerFileOriginalText = _testerFileEditorText;
            _testerFileTempPath = result.TempPath;
            _testerFileEditorOrigin = "Archivo guardado en tester";
            _testerFileDownloadTimes[result.FileName] = DateTime.Now;
            await ReloadTesterFilesCoreAsync();
            if (_localTempFiles.Count > 0) {
                await RefreshLocalTempFilesCoreAsync();
            }
            _testerFileProgressPercent = 100;
            _testerFileStatusMessage = "Archivo guardado en tester correctamente.";
        } catch (Exception ex) {
            _testerFileProgressPercent = 0;
            _testerFileStatusMessage = BuildUserErrorMessage(ex, "No se pudo guardar el archivo en el tester.");
        } finally {
            _isTesterFileBusy = false;
        }
    }

    /// <summary>
    /// [POR QUÉ EXISTE]
    /// Esta función existe para borrar un archivo remoto con confirmación explícita.
    ///
    /// [QUIÉN LA LLAMA]
    /// La llama el botón Eliminar de cada archivo remoto.
    ///
    /// [CUÁNDO SE EJECUTA]
    /// Se ejecuta cuando el usuario confirma que quiere borrar el archivo.
    ///
    /// [ENTRADAS]
    /// Recibe nombre de archivo.
    ///
    /// [SALIDAS]
    /// Devuelve `Task`.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Llama `DeleteFileAsync` y refresca vistas.
    ///
    /// [FLUJO ACURATEX]
    /// UI -> DeleteTesterFileAsync -> FILE_DELETE -> firmware.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a borrar un archivo de la memoria externa bajo confirmación.
    ///
    /// [SI NO EXISTIERA]
    /// La UI no podría eliminar archivos remotos.
    /// </summary>
    /// <summary>
    /// [POR QUE EXISTE]
    /// Este metodo existe para borrar un archivo remoto con confirmacion explicita.
    ///
    /// [QUIEN LO LLAMA]
    /// Lo llama el boton Eliminar de cada fila remota.
    ///
    /// [CUANDO SE EJECUTA]
    /// Se ejecuta cuando el usuario confirma que quiere borrar el archivo.
    ///
    /// [ENTRADAS]
    /// Recibe el nombre de archivo.
    ///
    /// [SALIDAS]
    /// Devuelve una tarea asincrona.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Llama a `DeleteFileAsync` y refresca vistas.
    ///
    /// [FLUJO ACURATEX]
    /// UI -> `DeleteTesterFileAsync()` -> `FILE_DELETE` -> firmware.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a borrar un archivo de memoria externa bajo confirmacion.
    ///
    /// [SI NO EXISTIERA]
    /// La UI no podria eliminar archivos remotos.
    /// </summary>
    private async Task DeleteTesterFileAsync(string fileName)
    {
        if (!CanManageTesterFiles || _isTesterFileBusy || !State.IsConnected) {
            return;
        }

        // [ACURATEX] El `confirm` del navegador actua como barrera simple antes de una eliminacion real.
        bool confirmed = await JS.InvokeAsync<bool>("confirm", $"Eliminar archivo {fileName} del tester?");
        if (!confirmed) {
            return;
        }

        _isTesterFileBusy = true;
        _testerFileProgressPercent = 25;
        _testerFileStatusMessage = $"Eliminando {fileName} del tester...";
        await InvokeAsync(StateHasChanged);

        try {
            bool deleted = await CommandFileTransferService.DeleteFileAsync(fileName, CancellationToken.None);
            if (!deleted) {
                _testerFileProgressPercent = 0;
                _testerFileStatusMessage = "El tester no confirmo la eliminacion del archivo.";
                return;
            }

            if (IsOpenedTesterFile(fileName)) {
                ClearTesterFileEditor();
            }

            await ReloadTesterFilesCoreAsync();
            if (_localTempFiles.Count > 0) {
                await RefreshLocalTempFilesCoreAsync();
            }
            _testerFileProgressPercent = 100;
            _testerFileStatusMessage = "Archivo eliminado del tester.";
        } catch (Exception ex) {
            _testerFileProgressPercent = 0;
            _testerFileStatusMessage = BuildUserErrorMessage(ex, "No se pudo eliminar el archivo del tester.");
        } finally {
            _isTesterFileBusy = false;
        }
    }

