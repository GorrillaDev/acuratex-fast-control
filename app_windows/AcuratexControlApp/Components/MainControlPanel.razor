    /// UI -> UploadSelectedLocalTempFilesAsync -> carpeta local -> FILE_* -> firmware.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a enviar varios bloques de datos guardados localmente a una memoria externa.
    ///
    /// [SI NO EXISTIERA]
    /// No habría una subida por lotes desde archivos temporales.
    /// </summary>
    /// <summary>
    /// [POR QUE EXISTE]
    /// Este metodo existe para subir al tester los archivos temporales que el operador selecciono.
    ///
    /// [QUIEN LO LLAMA]
    /// Lo llama el boton de subir archivos locales.
    ///
    /// [CUANDO SE EJECUTA]
    /// Se ejecuta cuando el usuario confirma una subida por lotes.
    ///
    /// [ENTRADAS]
    /// No recibe parametros.
    ///
    /// [SALIDAS]
    /// Devuelve una tarea asincrona.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Consulta si hay duplicados, abre un dialogo de conflicto o inicia la subida secuencial.
    ///
    /// [FLUJO ACURATEX]
    /// UI -> `UploadSelectedLocalTempFilesAsync()` -> archivos locales -> `FILE_*` -> firmware.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a tomar varios bloques de una carpeta local y escribirlos en memoria externa.
    ///
    /// [SI NO EXISTIERA]
    /// La UI no tendria una accion central para subir varios TXT temporales.
    /// </summary>
    private async Task UploadSelectedLocalTempFilesAsync()
    {
        if (!CanManageTesterFiles || _isLocalTempBusy || _isTesterFileBusy) {
            return;
        }

        if (!State.IsConnected) {
            _localTempStatusMessage = "Conecta el tester antes de subir archivos.";
            return;
        }

        IReadOnlyList<LocalTempFileEntry> selectedFiles = _localTempFiles
            .Where(static file => file.IsSelected && file.IsValid)
            .ToArray();
        if (selectedFiles.Count == 0) {
            _localTempStatusMessage = "Selecciona al menos un archivo temporal valido.";
            return;
        }

        _isLocalTempBusy = true;
        _isTesterFileBusy = true;
        _localTempGlobalProgressPercent = 5;
        _localTempCurrentFileProgressPercent = 0;
        _localTempStatusMessage = "Consultando archivos existentes en tester...";
        await InvokeAsync(StateHasChanged);

        try {
            HashSet<string> testerNames = await GetTesterFileNameSetAsync();
            selectedFiles = selectedFiles
                .Select(file => file with { ExistsOnTester = testerNames.Contains(file.FileName) })
                .ToArray();

            _localTempFiles = _localTempFiles
                .Select(file => file with { ExistsOnTester = testerNames.Contains(file.FileName) })
                .ToArray();

            IReadOnlyList<LocalTempFileEntry> duplicates = selectedFiles
                .Where(static file => file.ExistsOnTester)
                .ToArray();

            if (duplicates.Count > 0) {
                _duplicateUploadDialog = new LocalTempDuplicateDialog(selectedFiles, duplicates);
                _localTempGlobalProgressPercent = 0;
                _localTempStatusMessage = "Hay archivos seleccionados que ya existen en el tester.";
                return;
            }

            await UploadLocalTempFilesSequentialAsync(selectedFiles, omittedCount: 0);
        } catch (Exception ex) {
            _localTempGlobalProgressPercent = 0;
            _localTempStatusMessage = BuildUserErrorMessage(ex, "No se pudo iniciar la subida seleccionada.");
        } finally {
            _isLocalTempBusy = false;
            _isTesterFileBusy = false;
        }
    }

    // [ACURATEX] Sobrescribe los duplicados detectados en el tester.
    /// <summary>
    /// [POR QUE EXISTE]
    /// Este metodo existe para volver a intentar la subida cuando el operador decide sobrescribir duplicados.
    ///
    /// [QUIEN LO LLAMA]
    /// Lo llama el dialogo de duplicados.
    ///
    /// [CUANDO SE EJECUTA]
    /// Se ejecuta cuando el operador confirma que quiere reemplazar archivos ya existentes.
    ///
    /// [ENTRADAS]
    /// No recibe parametros.
    ///
    /// [SALIDAS]
    /// Devuelve una tarea asincrona.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Reutiliza la misma lista seleccionada y arranca la subida secuencial.
    ///
    /// [FLUJO ACURATEX]
    /// Dialogo duplicados -> `OverwriteDuplicateLocalTempFilesAsync()` -> subida.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a reescribir un bloque de memoria ya ocupado.
    ///
    /// [SI NO EXISTIERA]
    /// El usuario no tendria una ruta directa para sobrescribir duplicados.
    /// </summary>
    private async Task OverwriteDuplicateLocalTempFilesAsync()
    {
        if (_duplicateUploadDialog is null) {
            return;
        }

        IReadOnlyList<LocalTempFileEntry> files = _duplicateUploadDialog.SelectedFiles;
        _duplicateUploadDialog = null;
        await UploadLocalTempFilesSequentialAsync(files, omittedCount: 0);
    }

    // [ACURATEX] Omite los duplicados detectados y sube solo lo nuevo.
    /// <summary>
    /// [POR QUE EXISTE]
    /// Este metodo existe para continuar la subida saltando los archivos que ya existen en el tester.
    ///
    /// [QUIEN LO LLAMA]
    /// Lo llama el dialogo de duplicados cuando el operador elige omitir.
    ///
    /// [CUANDO SE EJECUTA]
    /// Se ejecuta al confirmar la omision de duplicados.
    ///
    /// [ENTRADAS]
    /// No recibe parametros.
    ///
    /// [SALIDAS]
    /// Devuelve una tarea asincrona.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Marca duplicados como omitidos y lanza la subida solo de los nuevos.
    ///
    /// [FLUJO ACURATEX]
    /// Dialogo duplicados -> `SkipDuplicateLocalTempFilesAsync()` -> solo nuevos -> firmware.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a saltar bloques ya escritos y continuar con los pendientes.
    ///
    /// [SI NO EXISTIERA]
    /// La UI no podria continuar una carga parcial sin sobrescribir.
    /// </summary>
    private async Task SkipDuplicateLocalTempFilesAsync()
    {
        if (_duplicateUploadDialog is null) {
            return;
        }

        IReadOnlyList<LocalTempFileEntry> duplicates = _duplicateUploadDialog.Duplicates;
        IReadOnlyList<LocalTempFileEntry> files = _duplicateUploadDialog.SelectedFiles
            .Where(static file => !file.ExistsOnTester)
            .ToArray();
        _duplicateUploadDialog = null;

        SetLocalTempUploadState(duplicates.Select(static file => file.FileName), "Omitido");
        if (files.Count == 0) {
            _localTempGlobalProgressPercent = 100;
            _localTempCurrentFileProgressPercent = 0;
            _localTempStatusMessage = $"Subida finalizada: 0 correctos, {duplicates.Count} omitido(s), 0 errores.";
            return;
        }

        await UploadLocalTempFilesSequentialAsync(files, omittedCount: duplicates.Count);
    }

    // [ACURATEX] Cancela la subida por conflicto de duplicados.
    /// <summary>
    /// [POR QUE EXISTE]
