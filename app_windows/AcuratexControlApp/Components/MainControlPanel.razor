    /// [EFECTOS SECUNDARIOS]
    /// Puede mostrar una confirmacion en el navegador.
    ///
    /// [FLUJO ACURATEX]
    /// Cambio de archivo -> `ConfirmDiscardTesterFileChangesAsync()` -> confirmar o cancelar.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a un aviso antes de perder una copia de trabajo en RAM.
    ///
    /// [SI NO EXISTIERA]
    /// El usuario podria perder edicion sin darse cuenta.
    /// </summary>
    private async Task<bool> ConfirmDiscardTesterFileChangesAsync()
    {
        // [ACURATEX] Descartar cambios es una barrera de seguridad para no perder edición manual.
        if (!IsTesterFileEditorDirty) {
            return true;
        }

        return await JS.InvokeAsync<bool>("confirm", "Hay cambios sin guardar. Descartarlos?");
