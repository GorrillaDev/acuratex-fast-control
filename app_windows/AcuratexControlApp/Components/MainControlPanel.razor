    // [ACURATEX] Devuelve la clase CSS de un archivo remoto según su estado.
    /// <summary>
    /// [POR QUE EXISTE]
    /// Este metodo existe para decidir que clase CSS corresponde a cada archivo remoto.
    ///
    /// [QUIEN LO USA]
    /// Lo usa el listado de archivos del tester.
    ///
    /// [CUANDO SE EJECUTA]
    /// Se ejecuta al renderizar cada fila remota.
    ///
    /// [ENTRADAS]
    /// Recibe la fila del archivo.
    ///
    /// [SALIDAS]
    /// Devuelve una clase CSS.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// No tiene.
    ///
    /// [FLUJO ACURATEX]
    /// Fila remota -> `TesterFileEntryClass()` -> estilo visible.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a encender un LED de estado según un flag.
    ///
    /// [SI NO EXISTIERA]
    /// La UI no resaltaria de forma uniforme cada archivo.
    /// </summary>
    private string TesterFileEntryClass(TesterFileEntry file)
    {
        // [ACURATEX] La clase CSS refleja selección y también si el archivo ya fue marcado como activo.
        string css = "tester-file-entry";
        if (string.Equals(_selectedTesterFileName, file.FileName, StringComparison.OrdinalIgnoreCase)) {
            css += " selected";
        }

        if (file.IsSelected) {
            css += " active";
        }

        return css;
    }

    // [ACURATEX] Devuelve la clase CSS de un archivo local temporal.
    private static string LocalTempEntryClass(LocalTempFileEntry file)
    {
        string css = "local-temp-entry";
        if (file.IsSelected) {
            css += " selected";
        }

        if (!file.IsValid) {
            css += " invalid";
        }

        return css;
    }

    // [ACURATEX] Resume el estado visual de un archivo temporal local.
    private static string BuildLocalTempStatus(LocalTempFileEntry file)
    {
        if (!file.IsValid) {
            return "Invalido";
        }

        if (file.UploadState is "Pendiente" or "Subiendo" or "Subido correctamente" or "Omitido" or "Error") {
            return file.UploadState;
        }

        if (file.IsSelected) {
            return "Seleccionado";
        }

        if (DateTime.Now - file.LastModified <= TimeSpan.FromMinutes(30)) {
            return "Modificado recientemente";
        }

        return file.ExistsOnTester ? "Existe en tester" : "Nuevo";
    }

    // [ACURATEX] Devuelve la clase CSS del indicador de estado local.
    private static string LocalTempStatusBadgeClass(LocalTempFileEntry file)
    {
        string status = BuildLocalTempStatus(file);
        return status switch
        {
            "Invalido" or "Error" => "local-temp-status-badge danger",
            "Subido correctamente" => "local-temp-status-badge success",
            "Existe en tester" or "Omitido" => "local-temp-status-badge warning",
            "Seleccionado" or "Subiendo" or "Pendiente" => "local-temp-status-badge selected",
            _ => "local-temp-status-badge"
        };
    }

