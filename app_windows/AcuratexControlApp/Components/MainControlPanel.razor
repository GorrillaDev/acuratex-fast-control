    /// <summary>
    /// [POR QUÉ EXISTE]
    /// Esta función existe para cargar la lista de programas de cabezal desde el tester y
    /// mostrarlos por sistema.
    ///
    /// [QUIÉN LA LLAMA]
    /// La llaman el botón de actualizar y el evento de estado.
    ///
    /// [CUÁNDO SE EJECUTA]
    /// Se ejecuta al refrescar el catálogo de programas.
    ///
    /// [ENTRADAS]
    /// No recibe parámetros.
    ///
    /// [SALIDAS]
    /// Devuelve `Task`.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Cambia listas de programas unificados y modulares.
    ///
    /// [FLUJO ACURATEX]
    /// UI -> RefreshHeadProgramsAsync -> HeadProfileService -> catálogos.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a consultar un catálogo de perfiles desde una memoria externa.
    ///
    /// [SI NO EXISTIERA]
    /// El panel no podría mostrar programas de cabezal.
    /// </summary>
    private async Task RefreshHeadProgramsAsync()
    {
        // [ACURATEX] Este refresco solo consulta el tester; no altera el perfil activo.
        // [FLUJO] Boton refrescar -> HeadProfileService.ListProgramsAsync -> listas locales.
        if (!CanManageHeadPrograms || _isHeadProgramBusy) {
            return;
        }

        if (!State.IsConnected) {
            _headProgramStatusMessage = "Conecta el tester para actualizar programas de cabezal.";
            return;
        }

        _isHeadProgramBusy = true;
        _headProgramStatusMessage = "Consultando programas de cabezal en el tester...";
        await InvokeAsync(StateHasChanged);

        try {
            Task<IReadOnlyList<HeadProgramInfo>> unifiedTask = HeadProfileService.ListProgramsAsync(HeadSystemKind.Unified, CancellationToken.None);
            Task<IReadOnlyList<HeadProgramInfo>> modularTask = HeadProfileService.ListProgramsAsync(HeadSystemKind.Modular, CancellationToken.None);
            await Task.WhenAll(unifiedTask, modularTask);

            _unifiedHeadPrograms = unifiedTask.Result;
            _modularHeadPrograms = modularTask.Result;
            _headProgramStatusMessage =
                $"Programas cargados. UNI={_unifiedHeadPrograms.Count}, MOD={_modularHeadPrograms.Count}.";
        } catch (Exception ex) {
            _headProgramStatusMessage = BuildUserErrorMessage(ex, "No se pudieron actualizar los programas de cabezal.");
        } finally {
            _isHeadProgramBusy = false;
        }
    }

    /// <summary>
    /// [POR QUÉ EXISTE]
    /// Esta función existe para aplicar el programa elegido al sistema de cabezal correcto.
    ///
    /// [QUIÉN LA LLAMA]
    /// La llama el botón Aplicar de cada programa.
    ///
    /// [CUÁNDO SE EJECUTA]
    /// Se ejecuta al seleccionar un programa de cabezal.
    ///
    /// [ENTRADAS]
    /// Recibe sistema y nombre de archivo.
    ///
    /// [SALIDAS]
    /// Devuelve `Task`.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Activa el perfil en firmware y refresca los listados.
    ///
    /// [FLUJO ACURATEX]
    /// UI -> ApplyHeadProgramAsync -> HeadProfileService -> firmware.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a elegir y activar un programa operativo guardado.
    ///
    /// [SI NO EXISTIERA]
    /// El panel no podría activar programas.
    /// </summary>
    private async Task ApplyHeadProgramAsync(HeadSystemKind systemKind, string fileName)
    {
        // [ACURATEX] Aplicar un programa de cabezal significa pedirle al servicio que lo valide
        // y luego lo deje activo en firmware y en la UI.
        // [FLUJO] Boton aplicar -> HeadProfileService.ApplyProgramAsync -> HEAD_PROGRAM_SELECT.
        if (!CanManageHeadPrograms || _isHeadProgramBusy) {
            return;
        }

        if (!State.IsConnected) {
            _headProgramStatusMessage = "Conecta el tester antes de aplicar un programa de cabezal.";
            return;
        }

        _isHeadProgramBusy = true;
        _headProgramStatusMessage = $"Aplicando {fileName} en {BuildSystemLabel(systemKind)}...";
        await InvokeAsync(StateHasChanged);

        try {
            HeadProfileLoadResult result = await HeadProfileService.ApplyProgramAsync(systemKind, fileName, CancellationToken.None);
            _headProgramStatusMessage = result.Warnings.Count > 0
                ? $"{result.Message} Advertencias: {result.Warnings.Count}."
                : result.Message;

            Task<IReadOnlyList<HeadProgramInfo>> unifiedTask = HeadProfileService.ListProgramsAsync(HeadSystemKind.Unified, CancellationToken.None);
            Task<IReadOnlyList<HeadProgramInfo>> modularTask = HeadProfileService.ListProgramsAsync(HeadSystemKind.Modular, CancellationToken.None);
            await Task.WhenAll(unifiedTask, modularTask);
            _unifiedHeadPrograms = unifiedTask.Result;
            _modularHeadPrograms = modularTask.Result;
        } catch (Exception ex) {
            _headProgramStatusMessage = BuildUserErrorMessage(ex, "No se pudo aplicar el programa de cabezal.");
        } finally {
            _isHeadProgramBusy = false;
        }
    }

