    // [ACURATEX] Valida el archivo elegido desde el navegador antes de leerlo.
    private static string? ValidateCommandFileSelection(string fileName, long fileSize)
    {
        // [ACURATEX] Se valida igual que en el tester: nombre limpio, extensión TXT y tamaño razonable.
        // [C#] `Contains(..., StringComparison.Ordinal)` impide confundir secuencias peligrosas con texto normal.
        if (string.IsNullOrWhiteSpace(fileName)
            || fileName.Length > 48
            || fileName.Contains('/')
            || fileName.Contains('\\')
            || fileName.Contains('|')
            || fileName.Contains("..", StringComparison.Ordinal)
            || fileName.Contains('\r')
            || fileName.Contains('\n')
            || string.Equals(fileName, ".selected", StringComparison.OrdinalIgnoreCase)
            || string.Equals(fileName, ".upload.tmp", StringComparison.OrdinalIgnoreCase)) {
            return "Nombre de archivo invalido";
        }

        if (!fileName.EndsWith(".txt", StringComparison.OrdinalIgnoreCase)) {
            return "Solo se permiten archivos .txt";
        }

        if (fileSize <= 0) {
            return "El archivo esta vacio";
        }

        if (fileSize > MaxCommandFileSizeBytes) {
            return $"El archivo supera {MaxCommandFileSizeBytes} bytes";
        }

        return null;
    }

    // [ACURATEX] Lee bytes del archivo del navegador sin cargarlo completo fuera de control.
    private static async Task<byte[]> ReadBrowserFileAsync(IBrowserFile file, CancellationToken cancellationToken)
    {
        // [ACURATEX] El archivo del navegador se lee con límite para no cargar bytes ilimitados en memoria.
        await using Stream input = file.OpenReadStream(MaxCommandFileSizeBytes, cancellationToken);
        using MemoryStream buffer = new((int)Math.Min(file.Size, MaxCommandFileSizeBytes));
        await input.CopyToAsync(buffer, cancellationToken);
        return buffer.ToArray();
    }

    // [ACURATEX] Construye una vista previa textual del archivo seleccionado.
    private static (int LineCount, IReadOnlyList<string> PreviewLines) BuildFilePreview(byte[] fileBytes)
    {
        // [ACURATEX] La vista previa enseña solo un resumen, no todo el archivo.
        string content = Encoding.UTF8.GetString(fileBytes);
        using StringReader reader = new(content);

        int lineCount = 0;
        List<string> preview = new(CommandFilePreviewLimit);
        string? line;

        while ((line = reader.ReadLine()) != null) {
            lineCount++;
            if (preview.Count < CommandFilePreviewLimit) {
                preview.Add(line);
            }
        }

        if (lineCount == 0 && fileBytes.Length > 0) {
            lineCount = 1;
            preview.Add(content);
        }

        return (lineCount, preview);
    }

    // [ACURATEX] Formatea la vista previa para mostrar líneas numeradas.
    private static string BuildPreviewText(IReadOnlyList<string> lines)
    {
        // [ACURATEX] Esta función convierte la vista previa en texto numerado para leerlo rápido.
        if (lines == null || lines.Count == 0) {
            return "(sin contenido visible)";
        }

        StringBuilder builder = new();
        for (int i = 0; i < lines.Count; i++) {
            if (i > 0) {
                builder.AppendLine();
            }

            builder.Append((i + 1).ToString("00"));
            builder.Append(": ");
            builder.Append(lines[i]);
        }

        return builder.ToString();
    }

