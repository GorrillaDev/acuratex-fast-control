    /// [EFECTOS SECUNDARIOS]
    /// No tiene.
    ///
    /// [FLUJO ACURATEX]
    /// Vista activa -> SidebarButtonClass -> estilo visual.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a iluminar un LED de menú según la posición actual.
    ///
    /// [SI NO EXISTIERA]
    /// Habría lógica duplicada en cada botón para saber si está activo.
    /// </summary>
    // [ACURATEX] Devuelve la clase CSS del botón lateral según la vista activa.
    private string SidebarButtonClass(MainPanelView view)
    {
        return _currentView == view
            ? "sidebar-icon-active p-3 text-blue-400"
            : "p-3 text-gray-400 hover:text-white";
    }

    /// <summary>
    /// [POR QUÉ EXISTE]
    /// Esta función existe para guardar el modo de conexión seleccionado por el operador.
    ///
    /// [QUIÉN LA LLAMA]
    /// La llama el combo de modo de conexión.
    ///
    /// [CUÁNDO SE EJECUTA]
    /// Se ejecuta cuando el usuario cambia el tipo de enlace.
    ///
    /// [ENTRADAS]
    /// Recibe el valor del evento de UI.
    ///
    /// [SALIDAS]
    /// Devuelve una tarea asíncrona.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Actualiza el estado compartido del host.
    ///
    /// [FLUJO ACURATEX]
    /// Combo -> OnModeChanged -> Host.SetConnectionModeAsync().
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a reconfigurar el periférico de comunicación antes de usarlo.
    ///
    /// [SI NO EXISTIERA]
    /// El panel no tendría forma centralizada de cambiar el modo de conexión.
    /// </summary>
    // [ACURATEX] Cambia el modo de conexión a través del host principal.
    /// <summary>
    /// [POR QUE EXISTE]
    /// Este metodo existe para guardar el modo de conexion elegido por el operador.
    ///
    /// [QUIEN LO LLAMA]
    /// Lo llama el selector de tipo de conexion.
    ///
    /// [CUANDO SE EJECUTA]
    /// Se ejecuta cuando el usuario cambia entre USB y WiFi.
    ///
    /// [ENTRADAS]
    /// Recibe el valor seleccionado en la UI.
    ///
    /// [SALIDAS]
    /// Devuelve una tarea asincrona.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Actualiza el estado compartido del host.
    ///
    /// [FLUJO ACURATEX]
    /// Combo de modo -> `OnModeChanged()` -> `Host.SetConnectionModeAsync()`.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a reconfigurar el periférico de comunicación antes de usarlo.
    ///
    /// [SI NO EXISTIERA]
    /// El panel no tendria forma centralizada de cambiar el modo de conexion.
    /// </summary>
    private async Task OnModeChanged(ChangeEventArgs args)
    {
        // [ACURATEX] El modo seleccionado reconfigura qué campos de conexión tienen sentido.
        // [ACURATEX] El selector solo actualiza el modo; la conexion real ocurre despues.
        // [FLUJO] Combo de modo -> Host.SetConnectionModeAsync -> estado compartido.
        // [EQUIV MCU] Se parece a cambiar un bit de configuración antes de iniciar un periférico.
        if (Enum.TryParse(args.Value?.ToString(), out ConnectionMode mode)) {
            await Host.SetConnectionModeAsync(mode);
        }
    }

    /// <summary>
