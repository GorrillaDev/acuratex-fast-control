    // [ACURATEX] Borra la copia local en caché sin comprometer la fuente oficial remota.
    private void TryDeleteTesterFileCache(string fileName)
    {
        // [ACURATEX] Borrar la copia local no altera la verdad del tester, solo limpia la cache.
        try {
            // [C#] `Path.Combine` construye una ruta temporal coherente con Windows.
            string cachePath = Path.Combine(Path.GetTempPath(), "AccuratexControlApp", "firmware-files", fileName);
            if (File.Exists(cachePath)) {
                File.Delete(cachePath);
            }

            _testerFileDownloadTimes.Remove(fileName);
        } catch {
            // La cache local no es fuente oficial; FILE_LIST del tester sigue siendo la verdad.
        }
    }

