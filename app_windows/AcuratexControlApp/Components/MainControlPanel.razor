@* [ACURATEX] Esta es la pantalla principal de trabajo.
   [ACURATEX] Aquí convergen conexión, login, consola, archivos locales y acceso a sistemas.
   [ACURATEX] La vista no calcula el protocolo: solo dispara servicios y refleja estado. *@
@implements IDisposable
@using Microsoft.AspNetCore.Components.Forms
@using System.IO
@using System.Text
@inject IMainControlPanelHost Host
@inject IJSRuntime JS
@inject PermissionService PermissionService
@inject AuthStateService AuthState
@inject IAppAlertService AlertService
@inject ICommandFileTransferService CommandFileTransferService
@inject IHeadProfileService HeadProfileService
@inject ILocalTempFileService LocalTempFileService

@* [ACURATEX] Esta pantalla es el centro de control principal.
   [FLUJO] Usuario -> Razor -> Host WinForms -> servicios -> firmware.
   [EQUIV MCU] Se parece a la pantalla principal de una HMI embebida. *@

<main class="h-full flex flex-col overflow-hidden bg-slate-100">
    <AcuratexWindowChrome />

    <div class="flex flex-1 min-h-0 overflow-hidden">
        <aside class="w-16 bg-[#2d3748] flex flex-col items-center py-4 gap-6 shrink-0">
                        @* [FLUJO] El panel lateral solo cambia la vista actual, no manda comandos de firmware. *@
                        <button class="@SidebarButtonClass(MainPanelView.Dashboard)"
                    type="button"
                    data-purpose="nav-dashboard"
                    title="Conectividad"
                    @onclick='() => SelectView(MainPanelView.Dashboard)'>
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                </svg>
            </button>

            @if (CanOpenUsersView)
            {
                <button class="@SidebarButtonClass(MainPanelView.Users)"
                        type="button"
                        data-purpose="nav-users"
                        title="Usuarios"
                        @onclick='() => SelectView(MainPanelView.Users)'>
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                        <circle cx="9" cy="7" r="4" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></circle>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                    </svg>
                </button>
            }

            @if (CanSeeConsole)
            {
                <button class="@SidebarButtonClass(MainPanelView.Console)"
                        type="button"
                        data-purpose="nav-terminal"
                        title="Terminal"
                        @onclick='() => SelectView(MainPanelView.Console)'>
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                    </svg>
                </button>
            }

            <div class="mt-auto flex flex-col gap-6">
                @if (CanViewConfig)
                {
                    <button class="@SidebarButtonClass(MainPanelView.Config)"
                            type="button"
                            data-purpose="nav-settings"
                            title="Configuracion"
                            @onclick='() => SelectView(MainPanelView.Config)'>
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                            <path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                        </svg>
                    </button>
                }
            </div>
        </aside>

        <section class="login-dashboard-shell flex-1 min-h-0 overflow-y-auto p-5 md:p-6 bg-[#f8fafc] custom-scrollbar">
            <div class="dashboard-soft-bg max-w-6xl mx-auto space-y-5">
                @if (IsAuthenticated)
                {
                    <section class="session-header-card bg-white rounded-lg border border-gray-200 p-3 card-shadow flex flex-wrap items-center justify-between gap-3">
                        <div class="session-user-info text-sm text-gray-700">
                            <span class="font-semibold">@CurrentUsername</span>
                            <span class="text-gray-500"> | </span>
                            <span class="font-medium">@CurrentRoleLabel</span>
                        </div>
                        <div class="session-collab-brand" aria-label="Colaboracion PUCP">
                            <span class="session-collab-text">En colaboraci&oacute;n con</span>
                            <img src="img/pucp-mecatronica-logo.png"
                                 class="session-pucp-logo"
                                 alt="Logo PUCP"
                                 loading="lazy" />
                        </div>
                        <button class="bg-white border border-gray-300 text-gray-700 px-4 py-1.5 rounded text-sm hover:bg-gray-50"
                                type="button"
                                @onclick="HandleLogoutAsync">
                            Cerrar sesion
                        </button>
                    </section>
                }
                else
                {
                    <section class="bg-white rounded-lg border border-gray-200 p-4 card-shadow flex flex-wrap items-center justify-between gap-4">
                        <div>
                            <h2 class="text-sm font-semibold text-gray-800">Sin sesion iniciada</h2>
                            <p class="text-xs text-gray-500">Conectividad disponible. Inicia sesion para habilitar comandos, pruebas y vistas segun rol.</p>
                        </div>
                        <button class="bg-[#086d90] hover:bg-cyan-800 text-white px-5 py-2 rounded-md font-semibold transition-colors"
                                type="button"
                                @onclick="HandleLoginAsync">
                            Iniciar sesion
                        </button>
                    </section>
                }

                @if (_currentView == MainPanelView.Dashboard)
                {
                    <div class="space-y-5">
                        <section class="bg-white rounded-lg border border-gray-200 p-4 card-shadow flex items-center justify-between gap-4" data-purpose="connection-type-selector">
                            <div class="flex items-center gap-3">
                                <div class="bg-blue-50 p-2 rounded text-blue-600">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                                    </svg>
                                </div>
                                <label class="font-medium text-gray-700" for="connection-mode">Tipo conexi&oacute;n</label>
                            </div>

                            <div class="w-48">
                                <select id="connection-mode"
                                        aria-label="Tipo conexi&oacute;n"
                                        class="w-full bg-gray-50 border border-gray-200 rounded px-3 py-1.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                        value="@State.Mode"
                                        @onchange="OnModeChanged"
                                        disabled="@State.IsBusy">
                                    <option value="@ConnectionMode.Usb">USB</option>
                                    <option value="@ConnectionMode.Wifi">WiFi</option>
                                </select>
                            </div>
                        </section>

                        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                            <section class="bg-white rounded-lg border-2 border-blue-400 p-6 card-shadow @(State.IsUsbPanelEnabled ? "" : "opacity-60")" data-purpose="usb-config-card">
                                <div class="flex items-center gap-3 mb-6">
                                    <div class="text-blue-600">
                                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                            <path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                                        </svg>
                                    </div>
                                    <h2 class="font-bold text-lg text-gray-800">@State.UsbPanelTitle</h2>
                                </div>

                                <div class="space-y-4">
                                    <div class="flex items-center gap-4 min-w-0">
                                        <label class="w-24 shrink-0 text-sm font-medium text-gray-600" for="endpoint-select">@State.EndpointLabel</label>

                                        <div class="device-row flex flex-1 min-w-0 gap-2">
                                            <select id="endpoint-select"
                                                    aria-label="@State.EndpointLabel"
                                                    class="usb-device-select flex-1 bg-gray-50 border border-gray-200 rounded px-3 py-2 text-xs text-gray-700 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                                    title="@State.SelectedEndpointId"
                                                    value="@State.SelectedEndpointId"
                                                    @onchange="OnEndpointChanged"
                                                    disabled="@(!State.IsUsbPanelEnabled || State.IsBusy)">
                                                @if (State.Endpoints.Count == 0)
                                                {
                                                    <option value="">Sin dispositivos</option>
                                                }
                                                else
                                                {
                                                    @foreach (MainEndpointOption endpoint in State.Endpoints)
                                                    {
                                                        <option value="@endpoint.Id" title="@endpoint.Id">@endpoint.Label</option>
                                                    }
                                                }
                                            </select>

                                            <button class="shrink-0 bg-[#0e7490] hover:bg-cyan-800 text-white px-6 py-2 rounded text-sm font-semibold transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                                                    type="button"
                                                    disabled="@(!State.CanRefreshEndpoint)"
                                                    @onclick="Host.RefreshEndpointsAsync">
                                                Buscar
                                            </button>
                                        </div>
                                    </div>

                                    <div class="flex items-center gap-4">
                                        <label class="w-24 text-sm font-medium text-gray-600" for="baud-field">@State.BaudLabel</label>

                                        <div class="flex-1 relative">
                                            <input id="baud-field"
                                                   class="w-full bg-gray-50 border border-gray-200 rounded pl-3 pr-10 py-2 text-xs font-mono text-gray-500 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                                   value="@State.BaudValue"
                                                   @oninput="OnBaudChanged"
                                                   readonly="@State.BaudReadOnly"
                                                   disabled="@(!State.IsUsbPanelEnabled)" />

                                            <span class="absolute right-3 top-2.5 text-gray-400 pointer-events-none" aria-hidden="true">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                                                </svg>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </section>

                            <section class="bg-white rounded-lg border border-gray-200 p-6 card-shadow @(State.IsWifiPanelEnabled ? "" : "opacity-70")" data-purpose="wifi-config-card">
                                <div class="flex items-center gap-3 mb-6">
                                    <div class="@(State.IsWifiPanelEnabled ? "text-sky-600" : "text-gray-400")">
                                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                            <path d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                                        </svg>
                                    </div>
                                    <h2 class="font-bold text-lg @(State.IsWifiPanelEnabled ? "text-gray-800" : "text-gray-400")">Conexi&oacute;n WiFi</h2>
                                </div>

                                <div class="space-y-4">
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                        <div class="flex items-center gap-2">
                                            <label class="text-sm font-medium text-gray-500" for="host-field">Host</label>
                                            <input id="host-field"
                                                   class="flex-1 bg-gray-50 border border-gray-200 rounded px-3 py-2 text-xs focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                                   value="@State.Host"
                                                   @oninput="OnHostChanged"
                                                   disabled="@(!State.IsWifiPanelEnabled || State.IsBusy)" />
                                        </div>

                                        <div class="flex items-center gap-2">
                                            <label class="text-sm font-medium text-gray-500" for="port-field">Port</label>
                                            <input id="port-field"
                                                   class="flex-1 bg-gray-50 border border-gray-200 rounded px-3 py-2 text-xs focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                                   value="@State.Port"
                                                   @oninput="OnPortChanged"
                                                   disabled="@(!State.IsWifiPanelEnabled || State.IsBusy)" />
                                        </div>
                                    </div>

                                    <p class="text-[10px] text-gray-400">
                                        Usa esto cuando el <span class="font-bold">ESP</span> este en la misma red o hotspot fijo.
                                    </p>

                                    <div class="flex justify-end">
                                        <button class="bg-[#0e7490] hover:bg-cyan-800 text-white px-6 py-2 rounded text-sm font-semibold transition-colors disabled:bg-gray-100 disabled:text-gray-400 disabled:cursor-not-allowed"
                                                type="button"
                                                disabled="@(!State.CanDiscoverWifi)"
                                                @onclick="Host.DiscoverWifiAsync">
                                            @State.DiscoverButtonText
                                        </button>
                                    </div>
                                </div>
                            </section>
                        </div>

                        <section class="bg-white rounded-lg border border-gray-200 p-3 card-shadow flex flex-wrap items-center justify-between gap-4" data-purpose="status-bar">
                            <div class="flex gap-3">
                                @* [ACURATEX] Conectar y desconectar pasan por Host, que es la ventana principal. *@
                                <button class="bg-red-600 hover:bg-red-700 text-white px-6 py-2 rounded font-bold transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                                        type="button"
                                        disabled="@(!State.CanConnect)"
                                        @onclick="Host.ConnectAsync">
                                    Conectar
                                </button>

                                <button class="bg-white border border-gray-300 text-gray-600 px-6 py-2 rounded font-medium hover:bg-gray-50 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                                        type="button"
                                        disabled="@(!State.CanDisconnect)"
                                        @onclick="Host.DisconnectAsync">
                                    Desconectar
                                </button>
                            </div>

                            <div class="flex items-center gap-2 text-sm">
                                <span class="text-gray-700">Estado:</span>
                                <div class="flex items-center gap-2 @(State.IsConnected ? "text-emerald-600" : "text-red-600") font-bold">
                                    <span class="w-2.5 h-2.5 rounded-full @(State.IsConnected ? "bg-emerald-600" : "bg-red-600")"></span>
                                    @State.StatusText
                                </div>
                            </div>
                        </section>
                    </div>
                }
                else if (_currentView == MainPanelView.Console)
                {
                    <TerminalView Command="@State.Command"
                                  CanSend="@(State.CanSend && CanUseManualCommand)"
                                  CanSendPreset="@(State.CanSendPreset && CanUsePresetCommands)"
                                  ShowCommandSection="@ShowCommandSection"
                                  CanUseManualCommand="@CanUseManualCommand"
                                  CanLaunchGraphicInterface="@CanLaunchGraphicInterface"
                                  ShowRawCommandButton="@ShowRawCommandButton"
                                  CanSendRawCommand="@CanSendRawCommand"
                                  ShowClearLogsButton="@ShowClearLogsButton"
                                  CanClearLogs="@CanClearLogs"
                                  ShowDevModeButton="@ShowDevModeButton"
                                  CanEnableDevMode="@CanEnableDevMode"
                                  Logs="@State.Logs"
                                  CommandChanged="OnCommandChanged"
                                  SendManualLineClicked="Host.SendManualLineAsync"
                                  SendStartClicked="SendStartAsync"
                                  SendStopClicked="SendStopAsync"
                                  SendTestClicked="SendTestAsync"
                                  LaunchGuiClicked="Host.LaunchGuiAsync"
                                  SendRawCommandClicked="HandleSendRawCommandAsync"
                                  ClearLogsClicked="HandleClearLogsAsync"
                                  EnableDevModeClicked="HandleEnableDevModeAsync" />
                }
                else if (_currentView == MainPanelView.Users)
                {
                    @if (CanOpenUsersView)
                    {
                        <UserManagementView />
                    }
                    else
                    {
                        <section class="bg-white rounded-lg border border-gray-200 p-5 card-shadow">
                            No tienes permisos para acceder a la gestion de usuarios.
                        </section>
                    }
                }
                else
                {
                    <section class="bg-white rounded-lg border border-gray-200 p-5 card-shadow space-y-3">
                        <h2 class="text-lg font-bold text-gray-800">Configuracion</h2>
                        <p class="text-sm text-gray-600">Panel de ajustes y utilidades de mantenimiento.</p>
                        <div class="text-xs text-gray-500">Permisos detectados:</div>
                        <div class="flex flex-wrap gap-2">
                            @if (PermissionService.HasPermission(UserPermission.ConfigView))
                            {
                                <span class="inline-flex items-center rounded border border-gray-300 bg-white px-2 py-1 text-[11px] font-mono text-gray-700">CONFIG_VIEW</span>
                            }
                            @if (PermissionService.HasPermission(UserPermission.ConfigEditBasic))
                            {
                                <span class="inline-flex items-center rounded border border-gray-300 bg-white px-2 py-1 text-[11px] font-mono text-gray-700">CONFIG_EDIT_BASIC</span>
                            }
                            @if (PermissionService.HasPermission(UserPermission.ConfigEditCritical))
                            {
                                <span class="inline-flex items-center rounded border border-gray-300 bg-white px-2 py-1 text-[11px] font-mono text-gray-700">CONFIG_EDIT_CRITICAL</span>
                            }
                            @if (PermissionService.HasPermission(UserPermission.CommandScriptUpload))
                            {
                                <span class="inline-flex items-center rounded border border-red-300 bg-red-50 px-2 py-1 text-[11px] font-mono text-red-700">COMMAND_SCRIPT_UPLOAD</span>
                            }
                            @if (PermissionService.HasPermission(UserPermission.SystemFileAccess))
                            {
                                <span class="inline-flex items-center rounded border border-sky-300 bg-sky-50 px-2 py-1 text-[11px] font-mono text-sky-700">SYSTEM_FILE_ACCESS</span>
                            }
                        </div>
                    </section>

                    <section class="head-program-admin-card bg-white rounded-lg border border-gray-200 p-5 card-shadow space-y-4">
                        <div class="flex flex-wrap items-start justify-between gap-3">
                            <div>
                                <h3 class="text-base font-bold text-gray-800">Programas de Cabezal (UNI / MOD)</h3>
                                <p class="text-sm text-gray-600">
                                    Administra los programas maestros del cabezal por sistema. Solo se aceptan archivos con formato cbz.uni.progX.txt o cbz.mod.progX.txt.
                                </p>
                            </div>

                            @if (CanManageHeadPrograms)
                            {
                                <button class="rounded bg-[#0e7490] px-4 py-2 text-sm font-semibold text-white hover:bg-cyan-800 disabled:cursor-not-allowed disabled:opacity-50"
                                        type="button"
                                        @onclick="RefreshHeadProgramsAsync"
                                        disabled="@(!CanRefreshHeadPrograms)">
                                    @(_isHeadProgramBusy ? "Actualizando..." : "Actualizar programas")
                                </button>
                            }
                            else
                            {
                                <span class="inline-flex items-center rounded border border-amber-300 bg-amber-50 px-2 py-1 text-[11px] font-semibold text-amber-700">
                                    Solo SUPER ROOT
                                </span>
                            }
                        </div>

                        @if (!CanManageHeadPrograms)
                        {
                            <p class="rounded border border-amber-200 bg-amber-50 px-3 py-2 text-sm text-amber-700">
                                No tiene permisos para administrar programas de cabezal.
                            </p>
                        }
                        else
                        {
                            <div class="head-program-admin-status text-xs text-gray-600">@_headProgramStatusMessage</div>

                            <div class="head-program-admin-grid">
                                <section class="head-program-admin-system-card">
                                    <div class="head-program-admin-system-header">
                                        <div class="head-program-admin-system-title">Sistema Unificado</div>
                                        <div class="head-program-admin-system-active">@BuildActiveHeadProgramSummary(HeadSystemKind.Unified)</div>
                                    </div>

                                    @if (_unifiedHeadPrograms.Count == 0)
                                    {
                                        <div class="head-program-admin-empty">No se encontraron programas cbz.uni.progX.txt.</div>
                                    }
                                    else
                                    {
                                        <div class="head-program-admin-list">
                                            @foreach (HeadProgramInfo program in _unifiedHeadPrograms)
                                            {
                                                <article class="@HeadProgramRowClass(program)">
                                                    <div class="head-program-admin-row-main">
                                                        <div class="head-program-admin-row-title">
                                                            <span>@program.DisplayName</span>
                                                            @if (program.IsActive)
                                                            {
                                                                <span class="head-program-active-badge">activo</span>
                                                            }
                                                        </div>
                                                        <div class="head-program-admin-row-file">@program.FileName</div>
                                                        <div class="head-program-admin-row-meta">
                                                            <span>Perfil: @(program.ProfileName ?? "(sin PROFILE_NAME)")</span>
                                                            <span>Bindings: @program.BindingCount</span>
                                                            <span>Modulos: @program.ModuleCount</span>
                                                        </div>
                                                        @if (!program.IsValid && !string.IsNullOrWhiteSpace(program.ValidationError))
                                                        {
                                                            <div class="head-program-admin-row-error">@program.ValidationError</div>
                                                        }
                                                        @if (program.Warnings.Count > 0)
                                                        {
                                                            <div class="head-program-admin-row-warning">
                                                                <span>Advertencias:</span>
                                                                @foreach (string warning in program.Warnings)
                                                                {
                                                                    <div>@warning</div>
                                                                }
                                                            </div>
                                                        }
                                                    </div>

                                                    <div class="head-program-admin-row-actions">
                                                        <button type="button"
                                                                class="tester-file-action-button primary"
                                                                @onclick="() => ApplyHeadProgramAsync(HeadSystemKind.Unified, program.FileName)"
                                                                disabled="@(_isHeadProgramBusy || !program.IsValid)">
                                                            Aplicar
                                                        </button>
                                                    </div>
                                                </article>
                                            }
                                        </div>
                                    }
                                </section>

                                <section class="head-program-admin-system-card">
                                    <div class="head-program-admin-system-header">
                                        <div class="head-program-admin-system-title">Sistema Modular</div>
                                        <div class="head-program-admin-system-active">@BuildActiveHeadProgramSummary(HeadSystemKind.Modular)</div>
                                    </div>

                                    @if (_modularHeadPrograms.Count == 0)
                                    {
                                        <div class="head-program-admin-empty">No se encontraron programas cbz.mod.progX.txt.</div>
                                    }
                                    else
                                    {
                                        <div class="head-program-admin-list">
                                            @foreach (HeadProgramInfo program in _modularHeadPrograms)
                                            {
                                                <article class="@HeadProgramRowClass(program)">
                                                    <div class="head-program-admin-row-main">
                                                        <div class="head-program-admin-row-title">
                                                            <span>@program.DisplayName</span>
                                                            @if (program.IsActive)
                                                            {
                                                                <span class="head-program-active-badge">activo</span>
                                                            }
                                                        </div>
                                                        <div class="head-program-admin-row-file">@program.FileName</div>
                                                        <div class="head-program-admin-row-meta">
                                                            <span>Perfil: @(program.ProfileName ?? "(sin PROFILE_NAME)")</span>
                                                            <span>Bindings: @program.BindingCount</span>
                                                            <span>Modulos: @program.ModuleCount</span>
                                                        </div>
                                                        @if (!program.IsValid && !string.IsNullOrWhiteSpace(program.ValidationError))
                                                        {
                                                            <div class="head-program-admin-row-error">@program.ValidationError</div>
                                                        }
                                                        @if (program.Warnings.Count > 0)
                                                        {
                                                            <div class="head-program-admin-row-warning">
                                                                <span>Advertencias:</span>
                                                                @foreach (string warning in program.Warnings)
                                                                {
                                                                    <div>@warning</div>
                                                                }
                                                            </div>
                                                        }
                                                    </div>

                                                    <div class="head-program-admin-row-actions">
                                                        <button type="button"
                                                                class="tester-file-action-button primary"
                                                                @onclick="() => ApplyHeadProgramAsync(HeadSystemKind.Modular, program.FileName)"
                                                                disabled="@(_isHeadProgramBusy || !program.IsValid)">
                                                            Aplicar
                                                        </button>
                                                    </div>
                                                </article>
                                            }
                                        </div>
                                    }
                                </section>
                            </div>
                        }
                    </section>

                    <section class="bg-white rounded-lg border border-gray-200 p-5 card-shadow space-y-4">
                        <div class="flex flex-wrap items-center justify-between gap-3">
                            <div>
                                <h3 class="text-base font-bold text-gray-800">Archivo de comandos</h3>
                                <p class="text-sm text-gray-600">Carga un archivo .txt al tester para usarlo posteriormente en pruebas de Cabezal.</p>
                            </div>
                            @if (!CanUploadCommandScript)
                            {
                                <span class="inline-flex items-center rounded border border-amber-300 bg-amber-50 px-2 py-1 text-[11px] font-semibold text-amber-700">
                                    Solo SUPER ROOT
                                </span>
                            }
                        </div>

                        @if (!CanUploadCommandScript)
                        {
                            <p class="rounded border border-amber-200 bg-amber-50 px-3 py-2 text-sm text-amber-700">
                                No tiene permisos para cargar archivos de comandos.
                            </p>
                        }
                        else
                        {
                            <div class="flex flex-wrap items-center gap-2">
                                <label class="inline-flex cursor-pointer items-center rounded bg-[#0e7490] px-4 py-2 text-sm font-semibold text-white hover:bg-cyan-800">
                                    Seleccionar archivo .txt
                                    <InputFile OnChange="OnCommandFileSelectedAsync"
                                               accept=".txt,text/plain"
                                               disabled="@_isUploadingCommandFile"
                                               class="hidden" />
                                </label>

                                <button class="rounded border border-gray-300 bg-white px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 disabled:cursor-not-allowed disabled:opacity-50"
                                        type="button"
                                        @onclick="ClearSelectedCommandFile"
                                        disabled="@(_selectedCommandFile is null || _isUploadingCommandFile)">
                                    Quitar seleccion
                                </button>

                                <button class="rounded bg-red-600 px-4 py-2 text-sm font-semibold text-white hover:bg-red-700 disabled:cursor-not-allowed disabled:opacity-50"
                                        type="button"
                                        @onclick="UploadSelectedCommandFileAsync"
                                        disabled="@(!CanUploadSelectedCommandFile)">
                                    @(_isUploadingCommandFile ? "Subiendo..." : "Subir al tester")
                                </button>

                                <button class="rounded border border-indigo-300 bg-indigo-50 px-3 py-2 text-sm font-semibold text-indigo-700 hover:bg-indigo-100 disabled:cursor-not-allowed disabled:opacity-50"
                                        type="button"
                                        @onclick="RunMinimalFileUploadTestAsync"
                                        disabled="@(_isUploadingCommandFile || !State.IsConnected)">
                                    Probar subida minima FILE
                                </button>
                            </div>

                            @if (_selectedCommandFile is not null)
                            {
                                <div class="grid grid-cols-1 gap-3 rounded border border-gray-200 bg-gray-50 p-3 text-sm md:grid-cols-3">
                                    <div>
                                        <div class="text-[11px] uppercase tracking-wide text-gray-500">Nombre</div>
                                        <div class="font-mono text-gray-800">@_selectedCommandFile.FileName</div>
                                    </div>
                                    <div>
                                        <div class="text-[11px] uppercase tracking-wide text-gray-500">Tamano</div>
                                        <div class="font-mono text-gray-800">@_selectedCommandFile.SizeBytes bytes</div>
                                    </div>
                                    <div>
                                        <div class="text-[11px] uppercase tracking-wide text-gray-500">Lineas</div>
                                        <div class="font-mono text-gray-800">@_selectedCommandFile.LineCount</div>
                                    </div>
                                </div>

                                <div class="space-y-2">
                                    <div class="text-xs font-semibold uppercase tracking-wide text-gray-500">Vista previa (primeras 10 lineas)</div>
                                    <pre class="max-h-64 overflow-auto rounded border border-gray-200 bg-[#0f172a] p-3 text-xs leading-5 text-slate-100">@BuildPreviewText(_selectedCommandFile.PreviewLines)</pre>
                                </div>
                            }

                            <div class="space-y-2">
                                <div class="h-2 w-full overflow-hidden rounded bg-gray-200">
                                    <div class="h-full bg-red-600 transition-all duration-200"
                                         style="@($"width: {_uploadProgressPercent}%;")"></div>
                                </div>
                                <div class="flex items-center justify-between text-xs">
                                    <span class="text-gray-600">@_uploadStatusMessage</span>
                                    <span class="font-mono text-gray-700">@_uploadProgressPercent%</span>
                                </div>
                            </div>
                        }
                    </section>

                    <section class="tester-file-explorer-card bg-white rounded-lg border border-gray-200 p-5 card-shadow space-y-4">
                        <div class="flex flex-wrap items-start justify-between gap-3">
                            <div class="space-y-1">
                                <h3 class="text-base font-bold text-gray-800">Archivos del tester</h3>
                                <p class="max-w-3xl text-sm text-gray-600">
                                    Administra archivos guardados en el tester. Los archivos se muestran como una carpeta virtual mediante el protocolo FILE_*.
                                </p>
                            </div>

                            @if (CanManageTesterFiles)
                            {
                                <button class="rounded bg-[#0e7490] px-4 py-2 text-sm font-semibold text-white hover:bg-cyan-800 disabled:cursor-not-allowed disabled:opacity-50"
                                        type="button"
                                        @onclick="RefreshTesterFilesAsync"
                                        disabled="@(!CanRefreshTesterFiles)">
                                    @(_isTesterFileBusy ? "Actualizando..." : "Actualizar lista")
                                </button>
                            }
                            else
                            {
                                <span class="inline-flex items-center rounded border border-amber-300 bg-amber-50 px-2 py-1 text-[11px] font-semibold text-amber-700">
                                    Solo SUPER ROOT
                                </span>
                            }
                        </div>

                        @if (!CanManageTesterFiles)
                        {
                            <p class="rounded border border-amber-200 bg-amber-50 px-3 py-2 text-sm text-amber-700">
                                No tiene permisos para administrar archivos del tester.
                            </p>
                        }
                        else
                        {
                            <div class="tester-file-status-row">
                                <div class="h-2 w-full overflow-hidden rounded bg-gray-200">
                                    <div class="h-full bg-[#0e7490] transition-all duration-200"
                                         style="@($"width: {_testerFileProgressPercent}%;")"></div>
                                </div>
                                <div class="flex flex-wrap items-center justify-between gap-2 text-xs">
                                    <span class="text-gray-600">@_testerFileStatusMessage</span>
                                    <span class="font-mono text-gray-700">@_testerFileProgressPercent%</span>
                                </div>
                            </div>

                            <div class="local-temp-folder-panel">
                                <div class="local-temp-header">
                                    <div class="min-w-0">
                                        <div class="text-sm font-bold text-gray-800">Carpeta temporal local</div>
                                        <div class="truncate font-mono text-xs text-gray-600" title="@LocalTempFolderPath">
                                            %TEMP%\AccuratexControlApp\firmware-files\
                                        </div>
                                    </div>
                                    <span class="rounded border border-gray-200 bg-white px-2 py-1 text-xs text-gray-600">
                                        @SelectedLocalTempFileCount archivo(s) seleccionado(s)
                                    </span>
                                </div>

                                <div class="local-temp-toolbar">
                                    <button type="button"
                                            class="tester-file-action-button"
                                            @onclick="OpenLocalTempFolderAsync"
                                            disabled="@_isLocalTempBusy">
                                        Ver carpeta temporal
                                    </button>
                                    <button type="button"
                                            class="tester-file-action-button"
                                            @onclick="CopyLocalTempFolderPathAsync"
                                            disabled="@_isLocalTempBusy">
                                        Copiar ruta
                                    </button>
                                    <button type="button"
                                            class="tester-file-action-button"
                                            @onclick="RefreshLocalTempFilesAsync"
                                            disabled="@(!CanRefreshLocalTempFiles)">
                                        Actualizar lista temporal
                                    </button>
                                    <button type="button"
                                            class="tester-file-action-button"
                                            @onclick="SelectAllLocalTempFiles"
                                            disabled="@(_isLocalTempBusy || !_localTempFiles.Any(static file => file.IsValid))">
                                        Seleccionar todos
                                    </button>
                                    <button type="button"
                                            class="tester-file-action-button"
                                            @onclick="DeselectAllLocalTempFiles"
                                            disabled="@(_isLocalTempBusy || SelectedLocalTempFileCount == 0)">
                                        Deseleccionar todos
                                    </button>
                                    <button type="button"
                                            class="tester-file-action-button primary"
                                            @onclick="UploadSelectedLocalTempFilesAsync"
                                            disabled="@(!CanUploadSelectedLocalTempFiles)">
                                        Subir seleccionados al tester
                                    </button>
                                </div>

                                <div class="local-temp-progress">
                                    <div class="h-2 w-full overflow-hidden rounded bg-gray-200">
                                        <div class="h-full bg-red-600 transition-all duration-200"
                                             style="@($"width: {_localTempGlobalProgressPercent}%;")"></div>
                                    </div>
                                    <div class="flex flex-wrap items-center justify-between gap-2 text-xs">
                                        <span class="text-gray-600">@_localTempStatusMessage</span>
                                        <span class="font-mono text-gray-700">
                                            Archivo @_localTempCurrentFileIndex de @_localTempTotalFiles | Global @_localTempGlobalProgressPercent% | Actual @_localTempCurrentFileProgressPercent%
                                        </span>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(_localTempCurrentFileName))
                                    {
                                        <div class="text-xs text-gray-500">Actual: <span class="font-mono">@_localTempCurrentFileName</span></div>
                                    }
                                </div>

                                @if (_localTempFiles.Count == 0)
                                {
                                    <div class="local-temp-empty">
                                        Presiona Actualizar lista temporal para leer los .txt de la cache local.
                                    </div>
                                }
                                else
                                {
                                    <div class="local-temp-list">
                                        @foreach (LocalTempFileEntry file in _localTempFiles)
                                        {
                                            <article class="@LocalTempEntryClass(file)">
                                                <label class="local-temp-check">
                                                    <input type="checkbox"
                                                           checked="@file.IsSelected"
                                                           disabled="@(!file.IsValid || _isLocalTempBusy)"
                                                           @onchange="args => ToggleLocalTempSelection(file.FileName, args)" />
                                                </label>

                                                <div class="local-temp-main">
                                                    <div class="tester-file-name-row">
                                                        <span class="tester-file-name">@file.FileName</span>
                                                        <span class="@LocalTempStatusBadgeClass(file)">@BuildLocalTempStatus(file)</span>
                                                    </div>
                                                    <div class="tester-file-meta">
                                                        <span>@FormatFileSize(file.SizeBytes)</span>
                                                        <span>@file.LastModified.ToString("yyyy-MM-dd HH:mm:ss")</span>
                                                        @if (!file.IsValid)
                                                        {
                                                            <span class="text-red-700">@file.ValidationError</span>
                                                        }
                                                    </div>
                                                </div>

                                                <div class="local-temp-actions">
                                                    <button type="button"
                                                            class="tester-file-action-button"
                                                            @onclick="() => OpenLocalTempFileInEditorAsync(file.FileName)"
                                                            disabled="@(!file.IsValid || _isLocalTempBusy)">
                                                        Abrir en editor
                                                    </button>
                                                </div>
                                            </article>
                                        }
                                    </div>
                                }

                                @if (_localTempUploadIssues.Count > 0)
                                {
                                    <div class="local-temp-errors">
                                        <div class="text-xs font-semibold uppercase tracking-wide text-red-700">Archivos con error</div>
                                        @foreach (LocalTempUploadIssue issue in _localTempUploadIssues)
                                        {
                                            <div><span class="font-mono">@issue.FileName</span>: @issue.Message</div>
                                        }
                                    </div>
                                }
                            </div>

                            @if (_duplicateUploadDialog is not null)
                            {
                                <div class="local-temp-modal-backdrop">
                                    <div class="local-temp-modal">
                                        <h4>Archivos existentes en el tester</h4>
                                        <p>Algunos archivos seleccionados ya existen en el tester. Deseas sobrescribirlos?</p>
                                        <div class="local-temp-duplicate-list">
                                            @foreach (LocalTempFileEntry file in _duplicateUploadDialog.Duplicates)
                                            {
                                                <div class="local-temp-duplicate-row">
                                                    <span class="font-mono">@file.FileName</span>
                                                    <span>@FormatFileSize(file.SizeBytes)</span>
                                                    <span>Ya existe en tester</span>
                                                    <span>Sobrescribir / Omitir</span>
                                                </div>
                                            }
                                        </div>
                                        <div class="local-temp-modal-actions">
                                            <button type="button"
                                                    class="rounded bg-red-600 px-4 py-2 text-sm font-semibold text-white hover:bg-red-700"
                                                    @onclick="OverwriteDuplicateLocalTempFilesAsync">
                                                Sobrescribir todos
                                            </button>
                                            <button type="button"
                                                    class="rounded border border-gray-300 bg-white px-3 py-2 text-sm text-gray-700 hover:bg-gray-50"
                                                    @onclick="SkipDuplicateLocalTempFilesAsync">
                                                Omitir existentes y subir solo nuevos
                                            </button>
                                            <button type="button"
                                                    class="rounded border border-gray-300 bg-white px-3 py-2 text-sm text-gray-700 hover:bg-gray-50"
                                                    @onclick="CancelDuplicateLocalTempUpload">
                                                Cancelar
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }

                            <div class="tester-file-workspace">
                                <div class="tester-file-list-panel">
                                    <div class="tester-file-panel-header">
                                        <div>
                                            <div class="text-xs font-semibold uppercase tracking-wide text-gray-500">Carpeta virtual</div>
                                            <div class="font-mono text-sm text-gray-800">/fs</div>
                                        </div>
                                        <span class="rounded border border-gray-200 bg-gray-50 px-2 py-1 text-xs text-gray-600">@_testerFiles.Count archivo(s)</span>
                                    </div>

                                    @if (_testerFiles.Count == 0)
                                    {
                                        <div class="tester-file-empty">
                                            Presiona Actualizar lista para consultar FILE_LIST.
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="tester-file-list">
                                            @foreach (TesterFileEntry file in _testerFiles)
                                            {
                                                <article class="@TesterFileEntryClass(file)"
                                                         title="@file.FileName"
                                                         @onclick="() => SelectTesterFileRow(file.FileName)">
                                                    <div class="tester-file-icon" aria-hidden="true">
                                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                                                            <path d="M14 2v6h6" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                                                            <path d="M8 13h8M8 17h5" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                                                        </svg>
                                                    </div>

                                                    <div class="tester-file-main">
                                                        <div class="tester-file-name-row">
                                                            <span class="tester-file-name">@file.FileName</span>
                                                            @if (file.IsSelected)
                                                            {
                                                                <span class="tester-file-selected-badge">activo</span>
                                                            }
                                                            @if (IsOpenedTesterFile(file.FileName))
                                                            {
                                                                <span class="tester-file-open-badge">abierto</span>
                                                            }
                                                        </div>
                                                        <div class="tester-file-meta">
                                                            <span>@FormatFileSize(file.SizeBytes)</span>
                                                            <span>@FormatLocalDownload(file)</span>
                                                        </div>
                                                    </div>

                                                    <div class="tester-file-actions">
                                                        <button type="button"
                                                                class="tester-file-action-button"
                                                                @onclick="() => OpenTesterFileAsync(file.FileName)"
                                                                @onclick:stopPropagation="true"
                                                                disabled="@(_isTesterFileBusy || !State.IsConnected)">
                                                            Abrir
                                                        </button>
                                                        <button type="button"
                                                                class="tester-file-action-button"
                                                                @onclick="() => SelectTesterFileAsync(file.FileName)"
                                                                @onclick:stopPropagation="true"
                                                                disabled="@(_isTesterFileBusy || !State.IsConnected || file.IsSelected)">
                                                            Seleccionar en tester
                                                        </button>
                                                        @if (IsOpenedTesterFile(file.FileName))
                                                        {
                                                            <button type="button"
                                                                    class="tester-file-action-button"
                                                                    @onclick="SaveOpenTesterFileAsync"
                                                                    @onclick:stopPropagation="true"
                                                                    disabled="@(!CanSaveTesterFile)">
                                                                Guardar cambios
                                                            </button>
                                                            <button type="button"
                                                                    class="tester-file-action-button"
                                                                    @onclick="SaveOpenTesterFileAsAsync"
                                                                    @onclick:stopPropagation="true"
                                                                    disabled="@(_isTesterFileBusy || !State.IsConnected)">
                                                                Guardar como
                                                            </button>
                                                        }
                                                        <button type="button"
                                                                class="tester-file-action-button danger"
                                                                @onclick="() => DeleteTesterFileAsync(file.FileName)"
                                                                @onclick:stopPropagation="true"
                                                                disabled="@(_isTesterFileBusy || !State.IsConnected)">
                                                            Eliminar
                                                        </button>
                                                    </div>
                                                </article>
                                            }
                                        </div>
                                    }
                                </div>

                                <div class="tester-file-editor-panel">
                                    @if (_openedTesterFileName is null)
                                    {
                                        <div class="tester-file-editor-empty">
                                            Selecciona Abrir sobre un archivo del tester para descargarlo y editarlo aqui.
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="tester-file-editor-header">
                                            <div class="min-w-0">
                                                <div class="text-xs font-semibold uppercase tracking-wide text-gray-500">Editor de texto</div>
                                                <div class="truncate font-mono text-sm font-semibold text-gray-800">@_openedTesterFileName</div>
                                                @if (!string.IsNullOrWhiteSpace(_testerFileEditorOrigin))
                                                {
                                                    <div class="truncate text-[11px] font-semibold text-sky-700">@_testerFileEditorOrigin</div>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(_testerFileTempPath))
                                                {
                                                    <div class="truncate text-[11px] text-gray-500">@_testerFileTempPath</div>
                                                }
                                            </div>
                                            <span class="@(IsTesterFileEditorDirty ? "tester-file-dirty-badge" : "tester-file-clean-badge")">
                                                @(IsTesterFileEditorDirty ? "modificado" : "limpio")
                                            </span>
                                        </div>

                                        <div class="tester-file-editor-stats">
                                            <span>@TesterFileEditorLineCount linea(s)</span>
                                            <span>@TesterFileEditorByteCount bytes UTF-8</span>
                                        </div>

                                        <textarea class="tester-file-editor"
                                                  value="@_testerFileEditorText"
                                                  @oninput="OnTesterFileEditorInput"
                                                  disabled="@_isTesterFileBusy"
                                                  spellcheck="false"></textarea>

                                        <div class="tester-file-editor-actions">
                                            <button class="rounded bg-red-600 px-4 py-2 text-sm font-semibold text-white hover:bg-red-700 disabled:cursor-not-allowed disabled:opacity-50"
                                                    type="button"
                                                    @onclick="SaveOpenTesterFileAsync"
                                                    disabled="@(!CanSaveTesterFile)">
                                                Guardar en tester
                                            </button>
                                            <button class="rounded border border-gray-300 bg-white px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 disabled:cursor-not-allowed disabled:opacity-50"
                                                    type="button"
                                                    @onclick="SaveOpenTesterFileAsAsync"
                                                    disabled="@(_isTesterFileBusy || !State.IsConnected)">
                                                Guardar como
                                            </button>
                                            <button class="rounded border border-gray-300 bg-white px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 disabled:cursor-not-allowed disabled:opacity-50"
                                                    type="button"
                                                    @onclick="DiscardTesterFileChanges"
                                                    disabled="@(!IsTesterFileEditorDirty || _isTesterFileBusy)">
                                                Descartar cambios
                                            </button>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </section>
                }
            </div>
        </section>
    </div>

    <div class="h-2 bg-[#1e293b] shrink-0"></div>

    <AppAlertModal />
</main>

@code {
    private const int MaxCommandFileSizeBytes = 65536;
    private const int CommandFilePreviewLimit = 10;

    private bool _pendingLogScroll;
    private readonly Dictionary<string, DateTime> _pendingCriticalActionConfirmations = new(StringComparer.OrdinalIgnoreCase);
    private MainPanelView _currentView = MainPanelView.Dashboard;
    private SelectedCommandFile? _selectedCommandFile;
    private bool _isUploadingCommandFile;
    private int _uploadProgressPercent;
    private string _uploadStatusMessage = "Sin archivo seleccionado.";
    private IReadOnlyList<TesterFileEntry> _testerFiles = Array.Empty<TesterFileEntry>();
    private readonly Dictionary<string, DateTime> _testerFileDownloadTimes = new(StringComparer.OrdinalIgnoreCase);
    private bool _isTesterFileBusy;
    private int _testerFileProgressPercent;
    private string _testerFileStatusMessage = "Lista sin actualizar.";
    private string? _selectedTesterFileName;
    private string? _openedTesterFileName;
    private string? _testerFileTempPath;
    private string _testerFileEditorOrigin = string.Empty;
    private string _testerFileEditorText = string.Empty;
    private string _testerFileOriginalText = string.Empty;
    private IReadOnlyList<LocalTempFileEntry> _localTempFiles = Array.Empty<LocalTempFileEntry>();
    private bool _isLocalTempBusy;
    private string _localTempStatusMessage = "Carpeta temporal sin actualizar.";
    private int _localTempGlobalProgressPercent;
    private int _localTempCurrentFileProgressPercent;
    private int _localTempCurrentFileIndex;
    private int _localTempTotalFiles;
    private string _localTempCurrentFileName = string.Empty;
    private IReadOnlyList<LocalTempUploadIssue> _localTempUploadIssues = Array.Empty<LocalTempUploadIssue>();
    private LocalTempDuplicateDialog? _duplicateUploadDialog;
    private IReadOnlyList<HeadProgramInfo> _unifiedHeadPrograms = Array.Empty<HeadProgramInfo>();
    private IReadOnlyList<HeadProgramInfo> _modularHeadPrograms = Array.Empty<HeadProgramInfo>();
    private bool _isHeadProgramBusy;
    private string _headProgramStatusMessage = "Programas de cabezal sin actualizar.";

    private MainControlPanelState State => Host.State;

    private bool IsAuthenticated => AuthState.IsAuthenticated;

    private bool CanOpenUsersView =>
        IsAuthenticated
        && PermissionService.CanViewUsers();

    private bool CanSeeConsole =>
        IsAuthenticated
        && PermissionService.HasPermission(UserPermission.LogViewSession);

    private bool CanViewConfig =>
        IsAuthenticated
        && PermissionService.HasPermission(UserPermission.ConfigView);

    private bool CanUploadCommandScript =>
        IsAuthenticated
        && PermissionService.HasPermission(UserPermission.CommandScriptUpload);

    private bool CanManageTesterFiles =>
        IsAuthenticated
        && PermissionService.CurrentUserIsSuperRoot()
        && PermissionService.HasAllPermissions(UserPermission.SystemFileAccess, UserPermission.CommandScriptUpload);

    private bool CanManageHeadPrograms => CanManageTesterFiles;

    private bool CanRefreshHeadPrograms =>
        CanManageHeadPrograms
        && !_isHeadProgramBusy
        && !_isTesterFileBusy
        && !_isLocalTempBusy;

    private bool CanUploadSelectedCommandFile =>
        CanUploadCommandScript
        && _selectedCommandFile is not null
        && !_isUploadingCommandFile
        && State.IsConnected;

    private bool CanRefreshTesterFiles =>
        CanManageTesterFiles
        && State.IsConnected
        && !_isTesterFileBusy;

    private bool CanRefreshLocalTempFiles =>
        CanManageTesterFiles
        && !_isLocalTempBusy
        && !_isTesterFileBusy;

    private bool CanUploadSelectedLocalTempFiles =>
        CanManageTesterFiles
        && State.IsConnected
        && !_isLocalTempBusy
        && !_isTesterFileBusy
        && SelectedLocalTempFileCount > 0;

    private int SelectedLocalTempFileCount =>
        _localTempFiles.Count(static file => file.IsSelected);

    private string LocalTempFolderPath => LocalTempFileService.GetTempFolderPath();

    private bool IsTesterFileEditorDirty =>
        _openedTesterFileName is not null
        && !string.Equals(_testerFileEditorText, _testerFileOriginalText, StringComparison.Ordinal);

    private bool CanSaveTesterFile =>
        CanManageTesterFiles
        && State.IsConnected
        && !_isTesterFileBusy
        && _openedTesterFileName is not null
        && IsTesterFileEditorDirty;

    private int TesterFileEditorByteCount => Encoding.UTF8.GetByteCount(_testerFileEditorText);

    private int TesterFileEditorLineCount => CountTextLines(_testerFileEditorText);

    private bool CanUsePresetCommands =>
        IsAuthenticated
        && PermissionService.HasPermission(UserPermission.CommandSendPreset);

    private bool CanUseManualCommand =>
        IsAuthenticated
        && PermissionService.HasPermission(UserPermission.CommandSendManualAllowed);

    private bool ShowCommandSection =>
        IsAuthenticated
        && (CanUseManualCommand || CanUsePresetCommands);

    // Seguridad visual: firmware/backend debe validar permisos antes de ejecutar acciones criticas.
    private bool ShowRawCommandButton =>
        ShowCommandSection
        && PermissionService.HasPermission(UserPermission.CommandSendRaw);

    private bool CanSendRawCommand => State.CanSend && ShowRawCommandButton;

    private bool ShowClearLogsButton =>
        IsAuthenticated
        && PermissionService.HasPermission(UserPermission.LogClear);

    private bool CanClearLogs => ShowClearLogsButton;

    private bool ShowDevModeButton =>
        IsAuthenticated
        && PermissionService.HasPermission(UserPermission.SystemDevMode);

    private bool CanEnableDevMode => ShowDevModeButton;

    private bool CanLaunchGraphicInterface =>
        IsAuthenticated
        && PermissionService.HasPermission(UserPermission.TestOpenGraphicInterface);

    private string CurrentUsername => AuthState.CurrentUser?.DisplayName ?? AuthState.CurrentUser?.Username ?? "Sin sesion";

    private string CurrentRoleLabel => AuthState.CurrentRole?.Name ?? "Sin rol";

    private enum MainPanelView
    {
        Dashboard,
        Console,
        Users,
        Config
    }

    /// <summary>
    /// [POR QUÉ EXISTE]
    /// Esta función existe para enganchar la vista a los eventos externos al arrancar.
    ///
    /// [QUIÉN LA LLAMA]
    /// La llama Blazor al crear el componente.
    ///
    /// [CUÁNDO SE EJECUTA]
    /// Se ejecuta una vez al inicializar la pantalla principal.
    ///
    /// [ENTRADAS]
    /// No recibe parámetros.
    ///
    /// [SALIDAS]
    /// No devuelve valor.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Suscribe eventos y valida qué vista puede verse.
    ///
    /// [FLUJO ACURATEX]
    /// Blazor -> OnInitialized -> eventos y permisos.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a registrar interrupciones y estado inicial en `setup()`.
    ///
    /// [SI NO EXISTIERA]
    /// La pantalla no reaccionaría a cambios de conexión o perfil.
    /// </summary>
    protected override void OnInitialized()
    {
        // [ACURATEX] La vista se suscribe antes del primer render para reaccionar a cambios del host y de la sesión.
        Host.StateChanged += HandleStateChanged;
        AuthState.StateChanged += HandleAuthStateChanged;
        HeadProfileService.StateChanged += HandleHeadProfileStateChanged;
        EnsureViewIsAllowedForRole();
    }

    // [ACURATEX] Después de pintar, la vista puede pedir scroll del log si hace falta.
    /// <summary>
    /// [POR QUE EXISTE]
    /// Este metodo existe para mover el log al final cuando la consola ya se dibujo.
    ///
    /// [QUIEN LO LLAMA]
    /// Lo llama Blazor despues de un render.
    ///
    /// [CUANDO SE EJECUTA]
    /// Se ejecuta despues del primer pintado o cuando una bandera interna pide scroll.
    ///
    /// [ENTRADAS]
    /// Recibe la bandera `firstRender`.
    ///
    /// [SALIDAS]
    /// Devuelve una tarea asincrona.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Puede invocar JavaScript para hacer scroll en la terminal.
    ///
    /// [FLUJO ACURATEX]
    /// Render de consola -> `OnAfterRenderAsync()` -> scroll del log.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a reubicar el cursor de un monitor serial al final de la traza.
    ///
    /// [SI NO EXISTIERA]
    /// El usuario no veria automaticamente las ultimas lineas del log.
    /// </summary>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_currentView != MainPanelView.Console) {
            return;
        }

        if (!firstRender && !_pendingLogScroll) {
            return;
        }

        _pendingLogScroll = false;

        try {
            await JS.InvokeVoidAsync("acuratexMainPanel.scrollLog", "main-log");
        } catch {
            // The host page can still be initializing during the first hybrid render.
        }
    }

    /// <summary>
    /// [POR QUÉ EXISTE]
    /// Esta función existe para centralizar el repintado cuando cambia el estado del host.
    ///
    /// [QUIÉN LA LLAMA]
    /// La llama la suscripción a `StateChanged`.
    ///
    /// [CUÁNDO SE EJECUTA]
    /// Se ejecuta cada vez que cambia la conexión, el log o una bandera visual importante.
    ///
    /// [ENTRADAS]
    /// No recibe entradas.
    ///
    /// [SALIDAS]
    /// No devuelve valor.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Puede pedir refresco de programas y fuerza `StateHasChanged`.
    ///
    /// [FLUJO ACURATEX]
    /// Host.StateChanged -> HandleStateChanged -> refresco/repaint.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a una ISR de “cambio de condición” que obliga a recomponer el panel.
    ///
    /// [SI NO EXISTIERA]
    /// Cada botón tendría que repintar por su cuenta y la UI quedaría inconsistente.
    /// </summary>
    // [ACURATEX] Reacciona a cambios de estado sin duplicar lógica en cada botón.
    private void HandleStateChanged()
    {
        // [C#] `InvokeAsync(StateHasChanged)` lleva el repintado al hilo correcto de Blazor.
        // [ACURATEX] El host cambia estado y esta vista solo pide repintado.
        // [FLUJO] Host.StateChanged -> MainControlPanel -> StateHasChanged.
        if (_currentView == MainPanelView.Config
            && CanManageHeadPrograms
            && State.IsConnected
            && !_isHeadProgramBusy
            && _unifiedHeadPrograms.Count == 0
            && _modularHeadPrograms.Count == 0) {
            _ = RefreshHeadProgramsAsync();
        }

        _pendingLogScroll = _currentView == MainPanelView.Console;
        _ = InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// [POR QUÉ EXISTE]
    /// Esta función existe para revisar qué vistas y listas siguen permitidas cuando cambia
    /// la sesión.
    ///
    /// [QUIÉN LA LLAMA]
    /// La llama la suscripción a cambios de autenticación.
    ///
    /// [CUÁNDO SE EJECUTA]
    /// Se ejecuta después de un login o logout.
    ///
    /// [ENTRADAS]
    /// No recibe entradas.
    ///
    /// [SALIDAS]
    /// No devuelve valor.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Puede vaciar listas y volver al dashboard.
    ///
    /// [FLUJO ACURATEX]
    /// AuthState -> HandleAuthStateChanged -> permisos -> vista visible.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a volver a evaluar una máscara de habilitación tras cambiar de operador.
    ///
    /// [SI NO EXISTIERA]
    /// La pantalla podría quedarse mostrando funciones que ya no están autorizadas.
    /// </summary>
    // [ACURATEX] Reacciona cuando cambia la sesión o el rol activo.
    private void HandleAuthStateChanged()
    {
        // [ACURATEX] Un login o logout puede quitar permisos y ocultar partes enteras del panel.
        // [ACURATEX] Un cambio de login puede ocultar vistas completas.
        // [FLUJO] AuthState -> permisos -> vista permitida.
        EnsureViewIsAllowedForRole();
        if (!CanManageHeadPrograms) {
            _unifiedHeadPrograms = Array.Empty<HeadProgramInfo>();
            _modularHeadPrograms = Array.Empty<HeadProgramInfo>();
        }
        _ = InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// [POR QUÉ EXISTE]
    /// Esta función existe para refrescar la sección de programas cuando cambia el perfil de
    /// cabezal activo.
    ///
    /// [QUIÉN LA LLAMA]
    /// La llama la suscripción al `StateChanged` del servicio de perfiles.
    ///
    /// [CUÁNDO SE EJECUTA]
    /// Se ejecuta cuando el perfil activo se carga, cambia o se limpia.
    ///
    /// [ENTRADAS]
    /// No recibe entradas.
    ///
    /// [SALIDAS]
    /// No devuelve valor.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Puede iniciar una recarga de programas o repintar la UI.
    ///
    /// [FLUJO ACURATEX]
    /// HeadProfileService -> HandleHeadProfileStateChanged -> lista de programas.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a actualizar la tabla de presets cuando cambia el programa activo.
    ///
    /// [SI NO EXISTIERA]
    /// La vista de configuración podría quedarse con datos viejos.
    /// </summary>
    // [ACURATEX] Reacciona cuando cambia el perfil activo de cabezal.
    private void HandleHeadProfileStateChanged()
    {
        // [ACURATEX] El perfil de cabezal cambia botones visibles, programas y estado de configuración.
        // [ACURATEX] Cuando cambia el perfil activo, la seccion de configuracion debe refrescarse.
        // [FLUJO] HeadProfileService -> config -> repintado.
        if (_currentView == MainPanelView.Config && CanManageHeadPrograms && State.IsConnected && !_isHeadProgramBusy) {
            _ = RefreshHeadProgramsAsync();
        } else {
            _ = InvokeAsync(StateHasChanged);
        }
    }

    /// <summary>
    /// [POR QUÉ EXISTE]
    /// Esta función existe para pedir al host WinForms que abra el formulario de login.
    ///
    /// [QUIÉN LA LLAMA]
    /// La llama el botón de acceso del panel.
    ///
    /// [CUÁNDO SE EJECUTA]
    /// Se ejecuta cuando el usuario pulsa iniciar sesión.
    ///
    /// [ENTRADAS]
    /// No recibe entradas.
    ///
    /// [SALIDAS]
    /// Devuelve la tarea de apertura.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Abre una ventana externa controlada por el host.
    ///
    /// [FLUJO ACURATEX]
    /// Botón login -> HandleLoginAsync -> Host.OpenLoginAsync().
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a pedirle a la máquina que cambie a una pantalla de autenticación.
    ///
    /// [SI NO EXISTIERA]
    /// La UI no podría iniciar sesión sin conocer WinForms.
    /// </summary>
    // [ACURATEX] Pide al host WinForms que abra el login.
    /// <summary>
    /// [POR QUE EXISTE]
    /// Este metodo existe para pedir al host WinForms que abra la ventana de login.
    ///
    /// [QUIEN LO LLAMA]
    /// Lo llama el boton de iniciar sesion.
    ///
    /// [CUANDO SE EJECUTA]
    /// Se ejecuta cuando el operador quiere autenticarse de nuevo.
    ///
    /// [ENTRADAS]
    /// No recibe parametros.
    ///
    /// [SALIDAS]
    /// Devuelve una tarea asincrona.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Dispara la apertura del formulario de login en el host.
    ///
    /// [FLUJO ACURATEX]
    /// Boton login -> `HandleLoginAsync()` -> `Host.OpenLoginAsync()`.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a pedir un cambio de pantalla a un menu de arranque.
    ///
    /// [SI NO EXISTIERA]
    /// La UI no podria iniciar sesion sin conocer WinForms.
    /// </summary>
    private async Task HandleLoginAsync()
    {
        // [ACURATEX] La vista delega el inicio de sesión al host para no mezclar UI con lógica WinForms.
        // [ACURATEX] La vista no abre el formulario directamente: se lo pide al host.
        // [FLUJO] Boton login -> Host.OpenLoginAsync() -> ventana WinForms.
        // [EQUIV MCU] Se parece a pedirle al sistema que cambie a una pantalla de acceso.
        await Host.OpenLoginAsync();
    }

    /// <summary>
    /// [POR QUÉ EXISTE]
    /// Esta función existe para cerrar la sesión y volver a evaluar permisos y vistas.
    ///
    /// [QUIÉN LA LLAMA]
    /// La llama el botón de salir.
    ///
    /// [CUÁNDO SE EJECUTA]
    /// Se ejecuta cuando el operador pulsa cerrar sesión.
    ///
    /// [ENTRADAS]
    /// No recibe entradas.
    ///
    /// [SALIDAS]
    /// Devuelve `Task` ya completada.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Limpia la sesión, vuelve al dashboard y puede disparar repintado.
    ///
    /// [FLUJO ACURATEX]
    /// Botón logout -> AuthState.Logout() -> EnsureViewIsAllowedForRole() -> UI.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a borrar el contexto del operador antes de volver al menú principal.
    ///
    /// [SI NO EXISTIERA]
    /// La sesión quedaría activa hasta que otra parte la invalidara.
    /// </summary>
    // [ACURATEX] Cierra sesión y vuelve a validar qué vistas están permitidas.
    /// <summary>
    /// [POR QUE EXISTE]
    /// Este metodo existe para cerrar la sesion actual y volver a evaluar permisos y vistas.
    ///
    /// [QUIEN LO LLAMA]
    /// Lo llama el boton de cerrar sesion.
    ///
    /// [CUANDO SE EJECUTA]
    /// Se ejecuta cuando el operador decide salir.
    ///
    /// [ENTRADAS]
    /// No recibe parametros.
    ///
    /// [SALIDAS]
    /// Devuelve una tarea ya completada.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Limpia la sesion y obliga a reevaluar vistas permitidas.
    ///
    /// [FLUJO ACURATEX]
    /// Boton logout -> `AuthState.Logout()` -> reevaluacion de panel.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a borrar el contexto del operador antes de volver al menu principal.
    ///
    /// [SI NO EXISTIERA]
    /// La sesion quedaria activa hasta que otra parte la invalidara.
    /// </summary>
    private Task HandleLogoutAsync()
    {
        // [ACURATEX] Cerrar sesión hace que la UI vuelva a evaluar qué vistas siguen permitidas.
        // [ACURATEX] Cerrar sesion limpia permisos y fuerza reevaluacion visual.
        // [FLUJO] Logout -> AuthState -> permisos -> panel principal.
        // [EQUIV MCU] Se parece a borrar el contexto del operador antes de volver al menu.
        AuthState.Logout();
        EnsureViewIsAllowedForRole();
        return Task.CompletedTask;
    }

    /// <summary>
    /// [POR QUÉ EXISTE]
    /// Esta función existe para asegurar que la vista visible siga siendo válida para el rol
    /// actual.
    ///
    /// [QUIÉN LA LLAMA]
    /// La llaman los cambios de autenticación y logout.
    ///
    /// [CUÁNDO SE EJECUTA]
    /// Se ejecuta cuando cambia la sesión o el rol activo.
    ///
    /// [ENTRADAS]
    /// No recibe entradas.
    ///
    /// [SALIDAS]
    /// No devuelve valor.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Puede volver al dashboard y limpiar la bandera de scroll.
    ///
    /// [FLUJO ACURATEX]
    /// AuthState -> EnsureViewIsAllowedForRole -> vista permitida.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a un firmware que fuerza volver a un menú seguro cuando cambia el modo.
    ///
    /// [SI NO EXISTIERA]
    /// La UI podría quedarse en una pantalla que el rol actual ya no permite.
    /// </summary>
    // [ACURATEX] Evita que una vista permanezca abierta cuando el rol ya no la permite.
    private void EnsureViewIsAllowedForRole()
    {
        if (!IsAuthenticated && _currentView != MainPanelView.Dashboard) {
            _currentView = MainPanelView.Dashboard;
            _pendingLogScroll = false;
            return;
        }

        if (_currentView == MainPanelView.Console && !CanSeeConsole) {
            _currentView = MainPanelView.Dashboard;
            _pendingLogScroll = false;
            return;
        }

        if (_currentView == MainPanelView.Users && !CanOpenUsersView) {
            _currentView = MainPanelView.Dashboard;
            _pendingLogScroll = false;
            return;
        }

        if (_currentView == MainPanelView.Config && !CanViewConfig) {
            _currentView = MainPanelView.Dashboard;
            _pendingLogScroll = false;
        }
    }

    /// <summary>
    /// [POR QUÉ EXISTE]
    /// Esta función existe para cambiar la pestaña visible sin tocar la conexión ni el
    /// protocolo.
    ///
    /// [QUIÉN LA LLAMA]
    /// La llaman los botones laterales del panel.
    ///
    /// [CUÁNDO SE EJECUTA]
    /// Se ejecuta cuando el operador navega entre vistas.
    ///
    /// [ENTRADAS]
    /// Recibe la vista destino.
    ///
    /// [SALIDAS]
    /// No devuelve valor.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Cambia la pestaña visible y, si corresponde, refresca programas de cabezal.
    ///
    /// [FLUJO ACURATEX]
    /// Botón lateral -> SelectView -> vista activa.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a cambiar de página en un menú de supervisión sin alterar el estado del
    /// periférico.
    ///
    /// [SI NO EXISTIERA]
    /// La navegación entre secciones no estaría centralizada.
    /// </summary>
    // [ACURATEX] Cambia la pestaña visible sin afectar el protocolo ni la conexión.
    private void SelectView(MainPanelView view)
    {
        // [FLUJO] La navegación lateral solo cambia la vista activa; no toca el firmware.
        if (view == MainPanelView.Dashboard) {
            if (_currentView != MainPanelView.Dashboard) {
                _currentView = MainPanelView.Dashboard;
                _pendingLogScroll = false;
            }

            return;
        }

        if (!IsAuthenticated) {
            return;
        }

        if (view == MainPanelView.Console && !CanSeeConsole) {
            return;
        }

        if (view == MainPanelView.Users && !CanOpenUsersView) {
            return;
        }

        if (view == MainPanelView.Config && !CanViewConfig) {
            return;
        }

        if (_currentView == view) {
            return;
        }

        _currentView = view;
        _pendingLogScroll = view == MainPanelView.Console;

        if (view == MainPanelView.Config
            && CanManageHeadPrograms
            && State.IsConnected
            && !_isHeadProgramBusy) {
            _ = RefreshHeadProgramsAsync();
        }
    }

    /// <summary>
    /// [POR QUÉ EXISTE]
    /// Esta función existe para decidir qué clase CSS recibe cada botón lateral según la
    /// vista activa.
    ///
    /// [QUIÉN LA LLAMA]
    /// La llaman los fragmentos Razor que pintan el menú lateral.
    ///
    /// [CUÁNDO SE EJECUTA]
    /// Se ejecuta durante el render del panel.
