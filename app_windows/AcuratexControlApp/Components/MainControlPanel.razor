    /// <summary>
    /// [POR QUÉ EXISTE]
    /// Esta función existe para recibir el archivo .txt elegido en el navegador y preparar su
    /// subida al tester.
    ///
    /// [QUIÉN LA LLAMA]
    /// La llama `<InputFile>` cuando el usuario selecciona un archivo.
    ///
    /// [CUÁNDO SE EJECUTA]
    /// Se ejecuta al elegir un archivo para subir.
    ///
    /// [ENTRADAS]
    /// Recibe `InputFileChangeEventArgs`.
    ///
    /// [SALIDAS]
    /// Devuelve `Task`.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Lee el archivo, valida nombre y tamaño, y prepara una vista previa.
    ///
    /// [FLUJO ACURATEX]
    /// Navegador -> OnCommandFileSelectedAsync -> preview -> subida posterior.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a leer un archivo desde SD antes de pasarlo a un buffer de envío.
    ///
    /// [SI NO EXISTIERA]
    /// La UI no podría preparar la carga de comandos desde el navegador.
    /// </summary>
    private async Task OnCommandFileSelectedAsync(InputFileChangeEventArgs args)
    {
        // [ACURATEX] Elegir un archivo no lo manda todavía; primero se valida y se prepara la vista previa.
        // [ACURATEX] El navegador entrega el archivo, pero la vista todavía no lo sube: solo lo valida y prepara.
        if (!CanUploadCommandScript || _isUploadingCommandFile) {
            return;
        }

        if (args.FileCount == 0) {
            ClearSelectedCommandFile();
            _uploadStatusMessage = "Sin archivo seleccionado.";
            return;
        }

        IBrowserFile file = args.File;
        string fileName = Path.GetFileName(file.Name ?? string.Empty).Trim();
        string? validationError = ValidateCommandFileSelection(fileName, file.Size);
        if (!string.IsNullOrEmpty(validationError)) {
            ClearSelectedCommandFile();
            _uploadStatusMessage = validationError;
            return;
        }

        try {
            // [ACURATEX] Primero se lee todo el archivo para poder mostrar una vista previa local.
            byte[] bytes = await ReadBrowserFileAsync(file, CancellationToken.None);
            if (bytes.Length == 0) {
                ClearSelectedCommandFile();
                _uploadStatusMessage = "El archivo esta vacio";
                return;
            }

            if (bytes.Length > MaxCommandFileSizeBytes) {
                ClearSelectedCommandFile();
                _uploadStatusMessage = $"El archivo supera {MaxCommandFileSizeBytes} bytes";
                return;
            }

            (int lineCount, IReadOnlyList<string> previewLines) = BuildFilePreview(bytes);

            // [ACURATEX] Este estado queda listo para que el boton de subir use exactamente el mismo contenido.
            _selectedCommandFile = new SelectedCommandFile(
                fileName,
                bytes,
                bytes.Length,
                lineCount,
                previewLines);

            _uploadProgressPercent = 0;
            _uploadStatusMessage = "Archivo listo para subir al tester.";
        } catch {
            ClearSelectedCommandFile();
            _uploadStatusMessage = "No se pudo leer el archivo";
        }
    }

    /// <summary>
    /// [POR QUÉ EXISTE]
    /// Esta función existe para subir el archivo .txt que quedó seleccionado.
    ///
    /// [QUIÉN LA LLAMA]
    /// La llama el botón de subir archivo de comandos.
    ///
    /// [CUÁNDO SE EJECUTA]
    /// Se ejecuta cuando el usuario confirma que quiere subir el TXT.
    ///
    /// [ENTRADAS]
    /// No recibe parámetros.
    ///
    /// [SALIDAS]
    /// Devuelve `Task`.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Usa `CommandFileTransferService.UploadTextFileAsync` y actualiza la barra de progreso.
    ///
    /// [FLUJO ACURATEX]
    /// UI -> UploadSelectedCommandFileAsync -> FILE_* -> firmware.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a grabar un bloque de datos en memoria externa.
    ///
    /// [SI NO EXISTIERA]
    /// No se podría subir el archivo preparado desde la UI.
    /// </summary>
    private async Task UploadSelectedCommandFileAsync()
    {
        // [ACURATEX] La subida real usa el archivo ya validado y lo entrega al servicio de FILE_*.
        // [ACURATEX] La subida real solo ocurre cuando ya hay un archivo seleccionado y validado.
        if (!CanUploadSelectedCommandFile || _selectedCommandFile is null) {
            return;
        }

        _isUploadingCommandFile = true;
        _uploadProgressPercent = 0;
        _uploadStatusMessage = "Preparando subida al tester...";
        // [C#] `InvokeAsync(StateHasChanged)` pide un repintado seguro desde Blazor antes de iniciar la carga.
        await InvokeAsync(StateHasChanged);

        try {
            // [C#] `Progress<T>` encapsula una lambda que recibe actualizaciones de avance.
            // [ACURATEX] El servicio de transferencia llama a este callback cada vez que cambia el progreso.
            Progress<CommandFileUploadProgress> progress = new(report =>
            {
                // [FLUJO] El progreso viene del servicio y solo se refleja en pantalla.
                _uploadProgressPercent = Math.Clamp(report.ProgressPercent, 0, 100);
                _uploadStatusMessage = report.Stage;
                _ = InvokeAsync(StateHasChanged);
            });

            CommandFileUploadResult result = await CommandFileTransferService.UploadTextFileAsync(
                _selectedCommandFile.FileName,
                _selectedCommandFile.FileBytes,
                progress,
                CancellationToken.None);

            _uploadProgressPercent = 100;
            _uploadStatusMessage = result.Message;
        } catch (Exception ex) {
            _uploadStatusMessage = string.IsNullOrWhiteSpace(ex.Message)
                ? "No se pudo completar la subida al tester"
                : ex.Message;
        } finally {
            _isUploadingCommandFile = false;
        }
    }

