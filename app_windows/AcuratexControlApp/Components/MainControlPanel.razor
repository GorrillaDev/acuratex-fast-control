    // [ACURATEX] Cuenta líneas de texto sin usar el parser de archivos completo.
    private static int CountTextLines(string text)
    {
        if (string.IsNullOrEmpty(text)) {
            return 0;
        }

        int count = 1;
        foreach (char c in text) {
            if (c == '\n') {
                count++;
            }
        }

        return count;
    }

    // [ACURATEX] Normaliza el nombre para el flujo "guardar como".
    private static string NormalizeTesterFileName(string fileName)
    {
        string cleanName = (fileName ?? string.Empty).Trim();
        if (cleanName.Length > 0 && Path.GetExtension(cleanName).Length == 0) {
            cleanName += ".txt";
        }

        return cleanName;
    }

    // [ACURATEX] Valida nombres de archivo desde la UI antes de mandar FILE_*.
    private static string? ValidateTesterFileNameForUi(string fileName)
    {
        // [ACURATEX] La UI bloquea nombres peligrosos antes de que lleguen al protocolo FILE_*.
        // [C#] `string.IsNullOrWhiteSpace` cubre null, vacio y espacios.
        if (string.IsNullOrWhiteSpace(fileName)
            || fileName.Length > 48
            || fileName.Contains('/')
            || fileName.Contains('\\')
            || fileName.Contains('|')
            || fileName.Contains("..", StringComparison.Ordinal)
            || fileName.Contains('\r')
            || fileName.Contains('\n')
            || string.Equals(fileName, ".selected", StringComparison.OrdinalIgnoreCase)
            || string.Equals(fileName, ".upload.tmp", StringComparison.OrdinalIgnoreCase)) {
            return "Nombre de archivo invalido.";
        }

        return null;
    }

