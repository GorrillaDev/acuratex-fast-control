    // [ACURATEX] Selecciona todos los archivos temporales válidos.
    private void SelectAllLocalTempFiles()
    {
        if (_isLocalTempBusy) {
            return;
        }

        // [C#] `static` en la lambda indica que no necesita capturar variables del entorno.
        // [ACURATEX] Solo se marcan como seleccionables los archivos locales que realmente son validos.
        _localTempFiles = _localTempFiles
            .Select(static file => file.IsValid
                ? file with { IsSelected = true, UploadState = "Seleccionado" }
                : file with { IsSelected = false })
            .ToArray();
        _localTempStatusMessage = $"{SelectedLocalTempFileCount} archivo(s) seleccionado(s).";
    }

    // [ACURATEX] Limpia la selección temporal.
    private void DeselectAllLocalTempFiles()
    {
        if (_isLocalTempBusy) {
            return;
        }

        // [C#] `with` crea una copia del registro/record cambiando solo las propiedades indicadas.
        // [ACURATEX] Se conserva si ya existia en tester o si es nuevo, solo se quita la marca visual de seleccion.
        _localTempFiles = _localTempFiles
            .Select(static file => file with { IsSelected = false, UploadState = file.ExistsOnTester ? "Existe en tester" : "Nuevo" })
            .ToArray();
        _localTempStatusMessage = "Seleccion temporal limpiada.";
    }

    // [ACURATEX] Cambia la selección de un archivo local concreto.
    private void ToggleLocalTempSelection(string fileName, ChangeEventArgs args)
    {
        if (_isLocalTempBusy) {
            return;
        }

        // [C#] `is bool value && value` extrae el booleano del evento si el DOM realmente lo entrego asi.
        bool selected = args.Value is bool value && value;
        _localTempFiles = _localTempFiles
            .Select(file =>
            {
                // [ACURATEX] Solo cambia el archivo que coincide por nombre y ademas sea utilizable.
                if (!string.Equals(file.FileName, fileName, StringComparison.OrdinalIgnoreCase) || !file.IsValid) {
                    return file;
                }

                return file with
                {
                    IsSelected = selected,
                    UploadState = selected ? "Seleccionado" : (file.ExistsOnTester ? "Existe en tester" : "Nuevo")
                };
            })
            .ToArray();
    }

