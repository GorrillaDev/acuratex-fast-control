    // [ACURATEX] Núcleo de recarga remota de archivos.
    private async Task ReloadTesterFilesCoreAsync()
    {
        // [ACURATEX] Esta rutina concentra la recarga remota para no repetir la misma secuencia en varios botones.
        IReadOnlyList<TesterFileEntry> files = await CommandFileTransferService.ListTesterFilesAsync(CancellationToken.None);
        _testerFiles = ApplyLocalDownloadTimes(files);

        if (_selectedTesterFileName is not null
            && !_testerFiles.Any(entry => string.Equals(entry.FileName, _selectedTesterFileName, StringComparison.OrdinalIgnoreCase))) {
            _selectedTesterFileName = null;
        }
    }

    // [ACURATEX] Núcleo de recarga de la carpeta temporal local.
    private async Task RefreshLocalTempFilesCoreAsync()
    {
        // [ACURATEX] La carpeta temporal se reconstruye combinando disco local con nombres remotos del tester.
        // [ACURATEX] El estado de la carpeta temporal se reconstruye a partir de disco y del tester.
        // [FLUJO] carpeta local + nombres remotos -> tabla visual combinada.
        Dictionary<string, LocalTempFileEntry> previous = _localTempFiles.ToDictionary(
            static file => file.FileName,
            StringComparer.OrdinalIgnoreCase);
        HashSet<string> testerNames = State.IsConnected
            ? await GetTesterFileNameSetAsync()
            : new HashSet<string>(_testerFiles.Select(static file => file.FileName), StringComparer.OrdinalIgnoreCase);

        IReadOnlyList<LocalTempFileEntry> localFiles = await LocalTempFileService.ListTempFilesAsync(CancellationToken.None);
        _localTempFiles = localFiles
            .Select(file =>
            {
                previous.TryGetValue(file.FileName, out LocalTempFileEntry? old);
                bool existsOnTester = testerNames.Contains(file.FileName);
                bool keepSelected = old?.IsSelected == true && file.IsValid;
                string uploadState = old is null
                    ? (existsOnTester ? "Existe en tester" : "Nuevo")
                    : KeepLocalTempUploadState(old.UploadState, existsOnTester);

                return file with
                {
                    ExistsOnTester = existsOnTester,
                    IsSelected = keepSelected,
                    UploadState = keepSelected ? "Seleccionado" : uploadState
                };
            })
            .ToArray();
    }

    // [ACURATEX] Obtiene nombres remotos para comparar con la carpeta local.
    private async Task<HashSet<string>> GetTesterFileNameSetAsync()
    {
        // [C#] `CancellationToken.None` significa que esta consulta puntual no se cancela desde la UI.
        IReadOnlyList<string> testerFiles = await CommandFileTransferService.ListFilesAsync(CancellationToken.None);
        // [ACURATEX] Se guarda en `HashSet` para comparar nombres rapido al actualizar estados visuales.
        return new HashSet<string>(testerFiles, StringComparer.OrdinalIgnoreCase);
    }

    // [ACURATEX] Conserva el estado visual de subida cuando refresca la lista.
    private static string KeepLocalTempUploadState(string uploadState, bool existsOnTester)
    {
        // [C#] El `switch` por expresion transforma estados conocidos sin repetir `if` encadenados.
        return uploadState switch
        {
            "Pendiente" or "Subiendo" or "Subido correctamente" or "Omitido" or "Error" => uploadState,
            _ => existsOnTester ? "Existe en tester" : "Nuevo"
        };
    }

    // [ACURATEX] Aplica un estado de subida a varios archivos locales a la vez.
    private void SetLocalTempUploadState(IEnumerable<string> fileNames, string uploadState)
    {
        // [C#] `IEnumerable<string>` permite recibir cualquier secuencia de nombres sin exigir un tipo concreto.
        HashSet<string> names = new(fileNames, StringComparer.OrdinalIgnoreCase);
        _localTempFiles = _localTempFiles
            .Select(file => names.Contains(file.FileName)
                ? file with { UploadState = uploadState, IsSelected = uploadState is "Seleccionado" or "Pendiente" or "Subiendo" }
                : file)
            .ToArray();
    }

    // [ACURATEX] Aplica un estado de subida a un archivo local concreto.
    private void UpdateLocalTempUploadState(string fileName, string uploadState)
    {
        // [ACURATEX] Este helper cambia solo un registro para que el progreso individual se vea correcto.
        _localTempFiles = _localTempFiles
            .Select(file => string.Equals(file.FileName, fileName, StringComparison.OrdinalIgnoreCase)
                ? file with { UploadState = uploadState, IsSelected = uploadState is "Pendiente" or "Subiendo" }
                : file)
            .ToArray();
    }

    // [ACURATEX] Convierte progreso por archivo en progreso agregado de lote.
    private static int CalculateBatchProgress(int completedFileCount, int totalFiles, int currentFileProgress)
    {
        if (totalFiles <= 0) {
            return 0;
        }

        // [C#] `Math.Clamp` mantiene el porcentaje dentro de 0..100 aunque el calculo intermedio se salga.
        double progress = (completedFileCount + Math.Clamp(currentFileProgress, 0, 100) / 100d) * 100d / totalFiles;
        return Math.Clamp((int)Math.Round(progress), 0, 100);
    }

    // [ACURATEX] Vuelve a pegar la hora local de descarga sobre la lista remota.
    private IReadOnlyList<TesterFileEntry> ApplyLocalDownloadTimes(IReadOnlyList<TesterFileEntry> files)
    {
        // [ACURATEX] La marca temporal local no viene del tester; se pega aqui desde memoria temporal de la UI.
        return files
            .Select(entry => entry with
            {
                LocalDownloadedAt = _testerFileDownloadTimes.TryGetValue(entry.FileName, out DateTime downloadedAt)
                    ? downloadedAt
                    : null
            })
            .ToArray();
    }

    // [ACURATEX] Pide confirmación antes de perder cambios no guardados.
