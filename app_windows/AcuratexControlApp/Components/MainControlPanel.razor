    /// <summary>
    /// [POR QUÉ EXISTE]
    /// Esta función existe para aplicar una segunda pulsación de confirmación sobre acciones
    /// críticas.
    ///
    /// [QUIÉN LA LLAMA]
    /// La llaman los botones críticos de la sección de consola.
    ///
    /// [CUÁNDO SE EJECUTA]
    /// Se ejecuta al intentar una acción peligrosa o irreversible.
    ///
    /// [ENTRADAS]
    /// Recibe una clave de acción y una etiqueta de usuario.
    ///
    /// [SALIDAS]
    /// Devuelve `bool` indicando si la acción ya está confirmada.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Guarda expiración temporal y muestra una alerta de confirmación.
    ///
    /// [FLUJO ACURATEX]
    /// Botón crítico -> EnsureCriticalActionConfirmedAsync -> confirmación -> acción final.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a una doble validación antes de activar una salida peligrosa.
    ///
    /// [SI NO EXISTIERA]
    /// Las acciones críticas no tendrían barrera de seguridad de doble click.
    /// </summary>
    /// <summary>
    /// [POR QUE EXISTE]
    /// Este metodo existe para pedir una confirmacion doble antes de ejecutar acciones criticas.
    ///
    /// [QUIEN LO LLAMA]
    /// Lo llaman los botones de RAW, borrar logs y modo desarrollo.
    ///
    /// [CUANDO SE EJECUTA]
    /// Se ejecuta cuando una accion marcada como critica esta por dispararse.
    ///
    /// [ENTRADAS]
    /// Recibe la clave de la accion y su etiqueta visible.
    ///
    /// [SALIDAS]
    /// Devuelve `true` si ya esta confirmada o `false` si apenas se pidio la primera pulsacion.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Puede mostrar una alerta y guardar una ventana temporal de confirmacion.
    ///
    /// [FLUJO ACURATEX]
    /// Boton critico -> `EnsureCriticalActionConfirmedAsync()` -> confirmacion -> accion final.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a una doble validacion antes de activar una salida peligrosa.
    ///
    /// [SI NO EXISTIERA]
    /// Las acciones criticas no tendrian barrera de seguridad de doble click.
    /// </summary>
    private async Task<bool> EnsureCriticalActionConfirmedAsync(string actionKey, string actionLabel)
    {
        // [ACURATEX] `TryGetValue` evita crear una confirmación falsa y permite recordar la primera pulsación.
        // [C#] `TryGetValue` evita crear entradas falsas cuando no hay confirmacion previa.
        if (!PermissionService.RequiresConfirmation(actionKey)) {
            return true;
        }

        // [ACURATEX] La primera pulsación solo arma una ventana temporal; la segunda dentro del plazo autoriza la acción.
        DateTime now = DateTime.UtcNow;
        if (_pendingCriticalActionConfirmations.TryGetValue(actionKey, out DateTime expiresAt) && expiresAt > now) {
            _pendingCriticalActionConfirmations.Remove(actionKey);
            return true;
        }

        _pendingCriticalActionConfirmations[actionKey] = now.AddSeconds(12);
        await AlertService.ShowAsync(
            "Confirmacion requerida",
            $"Accion critica: {actionLabel}. Presiona de nuevo en los proximos 12 segundos para confirmar.",
            AppAlertKind.Warning);
        return false;
    }

    // [ACURATEX] Desuscribe eventos cuando el componente sale de vida.
    /// <summary>
    /// [POR QUE EXISTE]
    /// Este metodo existe para desuscribir eventos cuando el componente sale de vida.
    ///
    /// [QUIEN LO LLAMA]
    /// Lo llama el ciclo de vida de Blazor al destruir el componente.
    ///
    /// [CUANDO SE EJECUTA]
    /// Se ejecuta al cerrar el panel o al cambiar la pagina hospedada.
    ///
    /// [ENTRADAS]
    /// No recibe parametros.
    ///
    /// [SALIDAS]
    /// No devuelve valor.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Elimina los handlers de sesión y host para evitar callbacks sobre un componente muerto.
    ///
    /// [FLUJO ACURATEX]
    /// Cierre del panel -> `Dispose()` -> desuscripcion -> no mas callbacks.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a quitar interrupciones registradas antes de apagar un modulo.
    ///
    /// [SI NO EXISTIERA]
    /// Quedarian handlers colgados intentando repintar la UI.
    /// </summary>
    public void Dispose()
    {
        // [ACURATEX] Se quitan las suscripciones para no dejar callbacks vivos cuando el panel ya no existe.
        // [ACURATEX] Quitamos la suscripcion para no disparar StateHasChanged en un componente muerto.
        // [C#] `-=` elimina el handler que se registro con `+=` durante la inicializacion.
        Host.StateChanged -= HandleStateChanged;
        AuthState.StateChanged -= HandleAuthStateChanged;
        HeadProfileService.StateChanged -= HandleHeadProfileStateChanged;
    }

