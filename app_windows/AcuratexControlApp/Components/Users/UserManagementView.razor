    // [ACURATEX] La UI refresca solo despues de que el servicio cambio la sesion.
    // [C#] `InvokeAsync(StateHasChanged)` evita tocar el render fuera del hilo de Blazor.
    /// <summary>
    /// [POR QUE EXISTE]
    /// Esta funcion existe para refrescar la lista visible cuando cambia la sesion activa.
    ///
    /// [QUIEN LA LLAMA]
    /// La llama el evento `StateChanged` de `AuthStateService`.
    ///
    /// [CUANDO SE EJECUTA]
    /// Se ejecuta cuando cambia el usuario o el rol autenticado.
    ///
    /// [ENTRADAS]
    /// No recibe entradas.
    ///
    /// [SALIDAS]
    /// No devuelve valor.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Reconstruye la lista y pide un repintado asincrono.
    ///
    /// [FLUJO ACURATEX]
    /// AuthState cambia -> `HandleAuthStateChanged()` -> lista nueva -> `StateHasChanged`.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a una interrupcion de cambio de perfil que obliga a refrescar la HMI.
    ///
    /// [SI NO EXISTIERA]
    /// La pantalla no reaccionaria cuando cambia la sesion activa.
    /// </summary>
    private void HandleAuthStateChanged()
    {
        // [FLUJO] Servicio de auth -> nueva lista visible -> repintado del componente.
        ReloadVisibleUsers();
        _ = InvokeAsync(StateHasChanged);
    }

    // [ACURATEX] Se desuscribe al destruir la vista.
    // [FLUJO] Dispose -> quita suscripcion -> no quedan callbacks vivos.
    /// <summary>
    /// [POR QUE EXISTE]
    /// Esta funcion existe para desuscribirse del estado de autenticacion cuando el componente
    /// deja de existir.
    ///
    /// [QUIEN LA LLAMA]
    /// La llama Blazor al destruir el componente.
    ///
    /// [CUANDO SE EJECUTA]
    /// Se ejecuta al salir de la vista o cerrar la pagina.
    ///
    /// [ENTRADAS]
    /// No recibe entradas.
    ///
    /// [SALIDAS]
    /// No devuelve valor.
    ///
    /// [EFECTOS SECUNDARIOS]
    /// Quita la suscripcion a `StateChanged`.
    ///
    /// [FLUJO ACURATEX]
    /// Cierre de componente -> `Dispose()` -> desuscripcion.
    ///
    /// [EQUIVALENCIA MCU]
    /// Se parece a retirar un callback de una interrupcion antes de apagar un modulo.
    ///
    /// [SI NO EXISTIERA]
    /// La vista podria seguir recibiendo eventos despues de cerrarse.
    /// </summary>
    public void Dispose()
    {
        // [ACURATEX] Sin esta baja, el componente seguiria recibiendo eventos luego de salir.
        AuthState.StateChanged -= HandleAuthStateChanged;
    }
