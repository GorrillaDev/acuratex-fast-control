    private bool CanExecuteHeadAction(bool allowDuringEmergency = false, bool allowDuringAlarm = false)







    {







        // [ACURATEX] El perfil activo actua como interlock; sin programa no se toca el tablero.







        if (!HasActiveHeadProgram) {







            _headProgramStatus = NoActiveProgramMessage;







            ResetHeadVisualStateToNeutral();







            _ = InvokeAsync(StateHasChanged);







            return false;







        }















        if (IsEmergencyLocked && !allowDuringEmergency) {
            return false;
        }

        if (_alarmHaltActive && !allowDuringAlarm) {
            return false;
        }

        return true;







    }















    private void ResetHeadVisualStateToNeutral()







    {







        StopAllMotorRuns();







        StopAllJAnimations(restore: false);















        foreach (CabezalMotorTarjetas motor in _denMotors) {







            motor.Position = 0;







            motor.SelectedPositionNumber = 0;







            motor.RunMode = string.Empty;







        }















        foreach (CabezalMotorTarjetas motor in _sicMotors) {







            motor.Position = 0;







            motor.SelectedPositionNumber = 0;







            motor.RunMode = string.Empty;







        }















        foreach (CabezalJGroupTarjetas group in _jGroups) {







            group.Register = 0xFF;







        }















        foreach (CabezalOutputBlockTarjetas block in AllBlocks()) {







            for (int index = 0; index < block.States.Length; index++) {







                block.States[index] = false;







            }







        }







    }















