    private async Task ToggleJPinAsync(CabezalJGroupTarjetas group, int pinIndex)







    {







        if (!CanExecuteHeadAction()) {







            return;







        }















        // [ACURATEX] La vista calcula el registro siguiente y lo refleja de inmediato.







        bool nextState = !group.IsPinOn(pinIndex);







        byte previousRegister = group.Register;







        group.SetPin(pinIndex, nextState);







        byte nextRegister = group.Register;















        bool sent = await SendJRegisterAsync(group, nextRegister);







        if (!sent) {







            group.Register = previousRegister;







        }















        await InvokeAsync(StateHasChanged);







    }















    private async Task SetJAllAsync(CabezalJGroupTarjetas group, bool on)







    {







        if (!CanExecuteHeadAction()) {







            return;







        }















        byte previousRegister = group.Register;







        bool wasRunning = IsJRunning(group.Number);







        if (wasRunning) {







            StopJAnimation(group.Number, restore: false);







        }















        byte nextRegister = on ? (byte)0x00 : (byte)0xFF;







        group.Register = nextRegister;















        bool sent = await SendJRegisterAsync(group, nextRegister);







        if (!sent) {







            group.Register = previousRegister;







            if (wasRunning) {







                StartJAnimation(group.Number);







            }







        }















        await InvokeAsync(StateHasChanged);







    }















    private async Task ToggleBlockPinAsync(CabezalBlockPinChangeTarjetas change)







    {







        if (!CanExecuteHeadAction()) {







            return;







        }















        CabezalOutputBlockTarjetas? block = FindBlock(change.BlockKey);







        if (block == null || change.PinIndex < 1 || change.PinIndex > block.PinCount) {







            return;







        }















        block.States[change.PinIndex - 1] = change.On;
        await InvokeAsync(StateHasChanged);

        string line = CabezalDashboardTarjetasProtocol.FormatBlockPinLine(change.BlockKey, change.PinIndex, change.On);







        await SendTrackedAsync("CAN", line, token => CommandService.SendBlockPinAsync(change.BlockKey, change.PinIndex, change.On, token));







    }















    private async Task SetBlockAllAsync(CabezalBlockAllChangeTarjetas change)







    {







        if (!CanExecuteHeadAction()) {







            return;







        }















        CabezalOutputBlockTarjetas? block = FindBlock(change.BlockKey);







        if (block == null) {







            return;







        }















        StopBlockVisualRun(block.Key);
        Array.Fill(block.States, change.On);
        await InvokeAsync(StateHasChanged);

        for (int pin = 1; pin <= block.PinCount; pin++) {







            string line = CabezalDashboardTarjetasProtocol.FormatBlockPinLine(block.Key, pin, change.On);







            await SendTrackedAsync("CAN", line, token => CommandService.SendBlockPinAsync(block.Key, pin, change.On, token));







        }







    }















    private async Task OffAllCoreAsync()







    {







        StopAllMotorRuns();







        StopAllJAnimations(restore: false);
        StopAllBlockVisualRuns(_yarnBlocks);
        StopAllBlockVisualRuns(_stitchBlocks);















        foreach (CabezalJGroupTarjetas group in _jGroups) {







            byte previousRegister = group.Register;







            group.Register = 0xFF;







            bool sent = await SendJRegisterAsync(group, 0xFF);







            if (!sent) {







                group.Register = previousRegister;







            }







        }















        foreach (CabezalOutputBlockTarjetas block in AllBlocks()) {







            await SetBlockAllCoreAsync(block, on: false);







        }







    }















