@* [ACURATEX] Dashboard del cabezal para sistema modular.







   [FLUJO] UI modular -> callbacks -> servicios -> conexion -> firmware.







   [EQUIV MCU] Se parece al mismo tablero fisico con otra tabla de mapeo. *@







@implements IDisposable







@inject ICabezalDashboardTarjetasCommandService CommandService







@inject IConnectionController Connection







@inject PermissionService PermissionService







@inject IJSRuntime JS







@inject IHeadProfileService HeadProfileService







@inject IHeadStateEventParser HeadStateEventParser







@inject IEmergencyStopService EmergencyStop

@inject CanAlarmDetector CanAlarmDetector

<main class="cabezal-dashboard">







    @* [ACURATEX] La barra superior filtra programa activo, estado de emergencia y acciones globales. *@







    <section class="head-toolbar">







        <div class="head-program-selector">







            <label for="head-program-select-modular" class="head-program-selector-label">Programa de Cabezal</label>







            <div class="head-program-selector-row">







                <select id="head-program-select-modular"







                        class="head-program-selector-input"







                        value="@(_selectedHeadProgramFile ?? string.Empty)"







                        @onchange="OnHeadProgramChangedAsync"







                        disabled="@(!CanChangeHeadProgram)">







                    <option value="">Seleccionar programa de cabezal...</option>







                    @foreach (HeadProgramInfo program in _headPrograms.Where(static item => item.IsValid))







                    {







                        <option value="@program.FileName">@program.DisplayName</option>







                    }







                </select>







                <button class="mini-btn" type="button" @onclick="RefreshHeadProgramsAsync" disabled="@(!CanRefreshHeadPrograms)">Actualizar</button>







            </div>







            <div class="head-program-selector-status">@_headProgramStatus</div>







        </div>















        <div class="can-rx-launcher">

            <button class="mini-btn" type="button" @onclick="SendCheckAsync">CHECK</button>

            <button class="primary can-rx-button" type="button" @onclick="OpenCanRxHistoryAsync">Ver CAN recibido (@CanRxHistoryCount)</button>

            <button class="mini-btn" type="button" @onclick="OpenCanAlarmHistoryAsync">Historial de alertas (@CanAlarmHistoryCount)</button>

            @if (_alarmHaltActive) {
                <span class="alarm-halt-pill">HALT por alarma CAN</span>
            }

        </div>















                <button class="success" type="button" @onclick="SendTesteoAsync" disabled="@(_headTestBusy || IsHeadUiBlocked)">TESTEO</button>

        <div class="head-test-state">
            <div class="head-test-state-top">
                <span class="head-test-state-label">TESTEO</span>
                <span class="head-test-state-pill">@_headTestStatus</span>
            </div>
            <div class="head-test-state-message">@_headTestMessage</div>
            @if (_headTestLastResult is not null)
            {
                <div class="head-test-state-detail">
                    <div>@($"Hora: {_headTestLastResult.ReceivedAt:HH:mm:ss.fff} | Bus: {_headTestLastResult.Bus} | ID: 0x{_headTestLastResult.CanId:X3} | DLC: {_headTestLastResult.Dlc} | DATA: {FormatCanRxData(_headTestLastResult.Data)}")</div>
                    <div>@($"Secuencia: {_headTestLastResult.FramesValue.Count} tramas | A1: {CountHeadTestFrames(_headTestLastResult, 0xA1)} | A2: {CountHeadTestFrames(_headTestLastResult, 0xA2)}")</div>
                    <div>@($"Primer codigo util: {FormatHeadTestCode(GetHeadTestFirstCode(_headTestLastResult))} | Ultimo codigo util: {FormatHeadTestCode(GetHeadTestLastCode(_headTestLastResult))}")</div>
                </div>
            }

            <div class="head-test-actions">
                <button class="mini-btn" type="button" @onclick="OpenHeadTestDetailAsync" disabled="@(_headTestLastResult is null)">Ver detalle de TESTEO</button>
            </div>
        </div>
        @* [ACURATEX] Estos botones no tocan el hardware directamente: piden la intencion al servicio. *@







        <button class="success" type="button" disabled="@IsHeadUiBlocked" @onclick="SendInitAsync">INIT</button>







        <button class="danger" type="button" disabled="@IsHeadUiBlocked" @onclick="OffAllAsync">OFF ALL</button>







        <button class="success" type="button" disabled="@IsHeadUiBlocked" @onclick="OnAllAsync">ON ALL</button>







        <button class="primary" type="button" disabled="@IsHeadUiBlocked" @onclick="SendStatusAsync">STATUS</button>















        <button type="button" disabled="@IsHeadUiBlocked" @onclick="RunAllJAsync">RUN ALL (J)</button>







        <button type="button" disabled="@IsHeadUiBlocked" @onclick="StopAllJAsync">STOP ALL (J)</button>















        <button type="button" disabled="@IsHeadUiBlocked" @onclick="RunAllYarnAsync">RUN ALL (YARN)</button>







        <button type="button" disabled="@IsHeadUiBlocked" @onclick="StopAllYarnAsync">STOP ALL (YARN)</button>















        <button type="button" disabled="@IsHeadUiBlocked" @onclick="RunAllStitchAsync">RUN ALL (STITCH)</button>







        <button type="button" disabled="@IsHeadUiBlocked" @onclick="StopAllStitchAsync">STOP ALL (STITCH)</button>







    </section>















    @if (!HasActiveHeadProgram)







    {







        <section class="system-program-inline">







            @NoActiveProgramMessage







        </section>







    }















    @if (IsEmergencyLocked)







    {







        <section class="system-emergency-inline">







            PARADA DE EMERGENCIA ACTIVADA. Acciones bloqueadas hasta ejecutar INIT.







        </section>







    }















    <section class="@LockScopeClass">















    @if (ShowAdvancedDiagnostics)







    {







        <section class="head-status-grid">







            <section class="rx-panel head-status-card">







                <div class="panel-title">RX / STATUS</div>







                <div>@_lastRx</div>







                <div class="panel-small">Lectura desde la conexion activa USB/TCP.</div>







            </section>















            <section class="trace-box head-trace-card">







                <div class="trace-title">







                    <span>TRACE local</span>







                    <button class="mini-btn" type="button" @onclick="ClearTrace">Clear</button>







                </div>







                <div class="trace-list">







                    @if (_trace.Count == 0)







                    {







                        <div class="trace-empty">Sin comandos.</div>







                    }







                    else







                    {







                        @foreach (CabezalTraceEntryTarjetas entry in _trace)







                        {







                            <div class="trace-item">







                                <div class="trace-time">@entry.Timestamp.ToString("HH:mm:ss")</div>







                                <div class="@TraceDirectionClass(entry.Direction)">@entry.Direction</div>







                                <div class="trace-msg">@entry.Message</div>







                            </div>







                        }







                    }







                </div>







            </section>







        </section>















        <section class="manual-row head-command-row">







            <input placeholder="CAN directo: 320 07 | 370 FD 06 11 00"







                   @bind="_manualCanLine"







                   @bind:event="oninput"







                   disabled="@IsHeadUiBlocked"







                   @onkeydown="HandleManualCanKeyDownAsync" />







            <button class="primary" type="button" @onclick="SendManualCanAsync" disabled="@IsHeadUiBlocked">SEND CAN</button>















            <input class="do-input"







                   placeholder="DO logico: init, status, j_run_1"







                   @bind="_manualDoCommand"







                   @bind:event="oninput"







                   disabled="@IsHeadUiBlocked"







                   @onkeydown="HandleManualDoKeyDownAsync" />







            <button class="primary" type="button" @onclick="SendManualDoAsync" disabled="@IsHeadUiBlocked">SEND DO</button>







        </section>







    }















    <section class="section-title">







        DEN







    </section>







    <section class="motor-grid">







        @foreach (CabezalMotorTarjetas motor in _denMotors)







        {







            <CabezalMotorCardTarjetas Motor="motor"







                                      PositionClicked="@((int positionNumber) => SetDenPositionAsync(motor, positionNumber))"







                                      SliderCommitted="@((int position) => SetDenSliderAsync(motor, position))"







                                      RunClicked="@(() => StartDenRunAsync(motor))"







                                      StopClicked="@(() => StopDenRunAsync(motor))"







                                      Run1Clicked="@(() => StartDenRun1Async(motor))"







                                      Stop1Clicked="@(() => StopDenRunAsync(motor))"







                                      ActionsDisabled="@IsHeadUiBlocked" />







        }







    </section>















    <section class="section-title">







        SIC







    </section>







    <section class="motor-grid">







        @foreach (CabezalMotorTarjetas motor in _sicMotors)







        {







            <CabezalMotorCardTarjetas Motor="motor"







                                      PositionClicked="@((int positionNumber) => SetSicPositionAsync(motor, positionNumber))"







                                      SliderCommitted="@((int position) => SetSicSliderAsync(motor, position))"







                                      RunClicked="@(() => StartSicRunAsync(motor))"







                                      StopClicked="@(() => StopSicRunAsync(motor))"







                                      ActionsDisabled="@IsHeadUiBlocked" />







        }







    </section>















    <section class="section-title">







        J1..J8







    </section>







    <section class="j-grid">







        @foreach (CabezalJGroupTarjetas group in _jGroups)







        {







            <section class="j-card">







                <div class="j-head">







                    <div class="j-title">@($"J{group.Number}")</div>







                </div>







                <div class="j-actions">







                    @* [EQUIV MCU] OFF/ON ALL equivale a escribir todo un registro logico de grupo. *@







                    <button class="mini-btn" type="button" @onclick="() => SetJAllAsync(group, false)" disabled="@IsHeadUiBlocked">OFF ALL</button>







                    <button class="mini-btn" type="button" @onclick="() => SetJAllAsync(group, true)" disabled="@IsHeadUiBlocked">ON ALL</button>







                </div>







                <div class="j-actions">







                    <button class="@JRunButtonClass(group.Number)" type="button" @onclick='() => SendDoCommandAsync($"j_run_{group.Number}")' disabled="@IsHeadUiBlocked">RUN</button>







                    <button class="mini-btn stop" type="button" @onclick='() => SendDoCommandAsync($"j_stop_{group.Number}")' disabled="@IsHeadUiBlocked">STOP</button>







                </div>







                <div class="j-pins">







                    @for (int pin = 1; pin <= 8; pin++)







                    {







                        int currentPin = pin;







                        @* [ACURATEX] Cada boton J representa un canal logico, no una salida cableada en la vista. *@







                        <button class="@JPinClass(group, currentPin)"







                                type="button"







                                disabled="@IsHeadUiBlocked"







                                @onclick="() => ToggleJPinAsync(group, currentPin)">







                            @currentPin







                        </button>







                    }







                </div>







            </section>







        }







    </section>















    <section class="section-title">







        Yarn







    </section>







    <section class="block-grid">







        @foreach (CabezalOutputBlockTarjetas block in _yarnBlocks)







        {







            <CabezalBlockTarjetas Block="block"







                                  PinClicked="ToggleBlockPinAsync"







                                  AllClicked="SetBlockAllAsync"







                                  RunClicked="SendDoCommandAsync"







                                  StopClicked="SendDoCommandAsync"







                                  ActionsDisabled="@IsHeadUiBlocked" />







        }







    </section>















    <section class="section-title">







        Stitch







    </section>







    <section class="block-grid">







        @foreach (CabezalOutputBlockTarjetas block in _stitchBlocks)







        {







            <CabezalBlockTarjetas Block="block"







                                  PinClicked="ToggleBlockPinAsync"







                                  AllClicked="SetBlockAllAsync"







                                  RunClicked="SendDoCommandAsync"







                                  StopClicked="SendDoCommandAsync"







                                  ActionsDisabled="@IsHeadUiBlocked" />







        }







    </section>















    @if (ShowAdvancedDiagnostics)







    {







        <section class="log-box">@_logLine</section>







        <section class="last-command">Ultimo comando: <code>@_lastCommand</code></section>







    }







    </section>















    @if (_showCanRxHistoryModal)







    {







        <div class="can-rx-overlay" @onclick="CloseCanRxHistoryAsync">







            <section class="can-rx-modal" @onclick:stopPropagation="true">







                <header class="can-rx-header">







                    <div>







                        <div class="can-rx-title">Tramas CAN recibidas</div>







                        <div class="can-rx-count">@CanRxHistoryCount tramas en memoria</div>







                    </div>







                    <button class="mini-btn" type="button" @onclick="CloseCanRxHistoryAsync">Cerrar</button>







                </header>







                <div class="can-rx-table-wrap">







                    <table class="can-rx-table">







                        <thead>







                            <tr>







                                <th>Hora</th>







                                <th>Bus</th>







                                <th>ID</th>







                                <th>DLC</th>







                                <th>Datos</th>







                            </tr>







                        </thead>







                        <tbody>







                            @foreach (CanRxFrame frame in GetCanRxHistorySnapshot())







                            {







                                <tr>







                                    <td>@frame.ReceivedAt.ToString("HH:mm:ss.fff")</td>







                                    <td>@frame.Bus</td>







                                    <td>@($"0x{frame.Id:X3}")</td>







                                    <td>@frame.Dlc</td>







                                    <td>@FormatCanRxData(frame.Data)</td>







                                </tr>







                            }







                        </tbody>







                    </table>







                </div>







                <div class="can-rx-actions">







                    <button class="mini-btn" type="button" @onclick="ClearCanRxHistoryAsync">Limpiar historial</button>







                    <button class="mini-btn" type="button" @onclick="CopyCanRxHistoryAsync">Copiar todo</button>







                </div>







            </section>







        </div>







    }







    @if (_showCanAlarmHistoryModal)
    {
        <div class="alert-history-overlay" @onclick="CloseCanAlarmHistoryAsync">
            <section class="alert-history-modal" @onclick:stopPropagation="true">
                <header class="alert-history-header">
                    <div>
                        <div class="alert-history-title">Historial de alertas</div>
                        <div class="alert-history-count">@CanAlarmHistoryCount alertas en memoria</div>
                    </div>
                    <button class="mini-btn" type="button" @onclick="CloseCanAlarmHistoryAsync">Cerrar</button>
                </header>

                <div class="alert-history-layout">
                    <div class="alert-history-table-wrap">
                        <table class="alert-history-table">
                            <thead>
                                <tr>
                                    <th>Hora</th>
                                    <th>Estado</th>
                                    <th>Tipo</th>
                                    <th>Bus</th>
                                    <th>ID</th>
                                    <th>DLC</th>
                                    <th>DATA</th>
                                    <th>Descripcion</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (CanAlarmHistoryItem item in GetCanAlarmHistorySnapshot())
                                {
                                    <tr class="@(ReferenceEquals(_selectedCanAlarmHistoryItem, item) ? "selected" : string.Empty)" @onclick="() => SelectCanAlarmHistoryItem(item)">
                                        <td>@item.DetectedAt.ToString("HH:mm:ss.fff")</td>
                                        <td>@item.Status</td>
                                        <td>@item.AlarmType</td>
                                        <td>@item.Bus</td>
                                        <td>@($"0x{item.CanId:X3}")</td>
                                        <td>@item.Dlc</td>
                                        <td>@FormatCanRxData(item.Data)</td>
                                        <td>@item.Title</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <aside class="alert-history-detail">
                        @if (_selectedCanAlarmHistoryItem is not null)
                        {
                            <div class="alert-history-detail-title">Detalle</div>
                            <div><strong>Hora detectada:</strong> @_selectedCanAlarmHistoryItem.DetectedAt.ToString("HH:mm:ss.fff")</div>
                            <div><strong>Hora cerrada:</strong> @(_selectedCanAlarmHistoryItem.ClosedAt?.ToString("HH:mm:ss.fff") ?? "-")</div>
                            <div><strong>Estado:</strong> @_selectedCanAlarmHistoryItem.Status</div>
                            <div><strong>Tipo:</strong> @_selectedCanAlarmHistoryItem.AlarmType</div>
                            <div><strong>Titulo:</strong> @_selectedCanAlarmHistoryItem.Title</div>
                            <div><strong>Descripcion:</strong> @_selectedCanAlarmHistoryItem.Description</div>
                            <div><strong>Bus:</strong> @_selectedCanAlarmHistoryItem.Bus</div>
                            <div><strong>ID:</strong> @($"0x{_selectedCanAlarmHistoryItem.CanId:X3}")</div>
                            <div><strong>DLC:</strong> @_selectedCanAlarmHistoryItem.Dlc</div>
                            <div><strong>DATA:</strong> @FormatCanRxData(_selectedCanAlarmHistoryItem.Data)</div>
                            <div><strong>Linea CAN_RX:</strong></div>
                            <pre class="alert-history-raw">@_selectedCanAlarmHistoryItem.RawLine</pre>
                        }
                        else
                        {
                            <div class="alert-history-empty">Sin alertas seleccionadas.</div>
                        }
                    </aside>
                </div>

                <div class="alert-history-actions">
                    <button class="mini-btn" type="button" @onclick="ClearCanAlarmHistoryAsync">Limpiar historial</button>
                    <button class="mini-btn" type="button" @onclick="CopyCanAlarmHistoryAsync">Copiar todo</button>
                </div>
            </section>
        </div>
    }
    @if (_showHeadTestDetailModal && _headTestLastResult is not null)
    {
        <div class="head-test-detail-overlay" @onclick="CloseHeadTestDetailAsync">
            <section class="head-test-detail-modal" @onclick:stopPropagation="true">
                <header class="head-test-detail-header">
                    <div>
                        <div class="head-test-detail-title">Detalle de TESTEO</div>
                        <div class="head-test-detail-subtitle">Secuencia recibida y placas detectadas en memoria durante esta ejecucion.</div>
                    </div>
                    <button class="mini-btn" type="button" @onclick="CloseHeadTestDetailAsync">Cerrar</button>
                </header>

                <div class="head-test-detail-body">
                    <div class="head-test-detail-grid">
                        <section class="head-test-detail-card">
                            <div class="head-test-detail-card-title">Resultado</div>
                            <div class="head-test-detail-lines">
                                <div><strong>Estado general:</strong> @_headTestLastResult.GeneralStatus</div>
                                <div><strong>Titulo:</strong> @_headTestLastResult.Title</div>
                                <div><strong>Codigo general:</strong> @($"0x{_headTestLastResult.StatusCode:X2}")</div>
                                <div><strong>Descripcion:</strong> @_headTestLastResult.Description</div>
                            </div>
                        </section>

                        <section class="head-test-detail-card">
                            <div class="head-test-detail-card-title">Trama final</div>
                            <div class="head-test-detail-lines">
                                <div><strong>Hora:</strong> @_headTestLastResult.ReceivedAt.ToString("HH:mm:ss.fff")</div>
                                <div><strong>Bus:</strong> @_headTestLastResult.Bus</div>
                                <div><strong>ID CAN:</strong> @($"0x{_headTestLastResult.CanId:X3}")</div>
                                <div><strong>DLC:</strong> @_headTestLastResult.Dlc</div>
                                <div><strong>DATA:</strong> @FormatCanRxData(_headTestLastResult.Data)</div>
                                <div><strong>Primer codigo util:</strong> @FormatHeadTestCode(GetHeadTestFirstCode(_headTestLastResult))</div>
                                <div><strong>Ultimo codigo util:</strong> @FormatHeadTestCode(GetHeadTestLastCode(_headTestLastResult))</div>
                                <div><strong>Tramas recibidas:</strong> @_headTestLastResult.FramesValue.Count</div>
                            </div>
                        </section>
                    </div>

                    <div class="head-test-detail-grid">
                        <section class="head-test-detail-card">
                            <div class="head-test-detail-card-title">Grupo A1</div>
                            <div class="head-test-detail-lines">
                                <div><strong>Presentes:</strong> @FormatHeadTestBoards(_headTestLastResult.PresentA1BoardsValue)</div>
                                <div><strong>Faltantes:</strong> @FormatHeadTestBoards(_headTestLastResult.MissingA1BoardsValue)</div>
                            </div>
                        </section>

                        <section class="head-test-detail-card">
                            <div class="head-test-detail-card-title">Grupo A2</div>
                            <div class="head-test-detail-lines">
                                <div><strong>Presentes:</strong> @FormatHeadTestBoards(_headTestLastResult.PresentA2BoardsValue)</div>
                                <div><strong>Faltantes:</strong> @FormatHeadTestBoards(_headTestLastResult.MissingA2BoardsValue)</div>
                            </div>
                        </section>

                        <section class="head-test-detail-card">
                            <div class="head-test-detail-card-title">Expansion</div>
                            <div class="head-test-detail-lines">
                                <div><strong>Presentes:</strong> @FormatHeadTestBoards(_headTestLastResult.PresentExpansionBoardsValue)</div>
                                <div><strong>Faltantes:</strong> @FormatHeadTestBoards(_headTestLastResult.MissingExpansionBoardsValue)</div>
                            </div>
                        </section>
                    </div>

                    <section class="head-test-detail-card">
                        <div class="head-test-detail-card-title">Secuencia de tramas</div>
                        @if (_headTestLastResult.FramesValue.Count > 0)
                        {
                            <div class="head-test-detail-table-wrap">
                                <table class="head-test-detail-table">
                                    <thead>
                                        <tr>
                                            <th>#</th>
                                            <th>Hora</th>
                                            <th>Bus</th>
                                            <th>ID</th>
                                            <th>DLC</th>
                                            <th>DATA</th>
                                            <th>Codigo</th>
                                            <th>Interpretacion</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (HeadTestFrameTrace trace in _headTestLastResult.FramesValue)
                                        {
                                            <tr>
                                                <td>@trace.Sequence</td>
                                                <td>@trace.ReceivedAt.ToString("HH:mm:ss.fff")</td>
                                                <td>@trace.Bus</td>
                                                <td>@($"0x{trace.CanId:X3}")</td>
                                                <td>@trace.Dlc</td>
                                                <td>@FormatCanRxData(trace.Data)</td>
                                                <td>@(trace.Code.HasValue ? $"0x{trace.Code.Value:X2}" : "-")</td>
                                                <td>@trace.Interpretation</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="head-test-detail-empty">No hay secuencia almacenada.</div>
                        }
                    </section>
                </div>
            </section>
        </div>
    }
    @if (_showCanAlarmModal && _activeCanAlarm is not null)
    {
        <div class="can-alarm-overlay" @onclick="CloseCanAlarmAsync">
            <section class="can-alarm-modal" @onclick:stopPropagation="true">
                <header class="can-alarm-header">
                    <div>
                        <div class="can-alarm-title">ALERTA CAN</div>
                        <div class="can-alarm-count">@_activeCanAlarm.Title</div>
                    </div>
                    <button class="mini-btn" type="button" @onclick="CloseCanAlarmAsync">Cerrar alerta</button>
                </header>

                <div class="can-alarm-body">
                    <div><strong>Hora:</strong> @_activeCanAlarm.DetectedAt.ToString("HH:mm:ss.fff")</div>
                    <div><strong>Bus:</strong> @_activeCanAlarm.Bus</div>
                    <div><strong>ID:</strong> @($"0x{_activeCanAlarm.Id:X3}")</div>
                    <div><strong>DLC:</strong> @_activeCanAlarm.Dlc</div>
                    <div><strong>DATA:</strong> @FormatCanRxData(_activeCanAlarm.Data)</div>
                    <div><strong>Tipo:</strong> @_activeCanAlarm.AlarmType</div>
                    <pre class="can-alarm-message">@_activeCanAlarm.Message</pre>
                </div>

                @if (_canAlarmPendingCount > 0)
                {
                    <div class="can-alarm-pending">@_canAlarmPendingCount alertas pendientes</div>
                }

                <div class="can-alarm-activity">
                    @foreach (string note in GetCanAlarmActivitySnapshot())
                    {
                        <div>@note</div>
                    }
                </div>

                <div class="can-alarm-actions">
                    <button class="mini-btn" type="button" @onclick="CopyCanAlarmAsync">Copiar informaci�n</button>
                    <button class="mini-btn" type="button" @onclick="SendCanAlarmCheckAsync">CHECK</button>
                    <button class="mini-btn" type="button" @onclick="CloseCanAlarmAsync">Cerrar alerta</button>
                </div>
            </section>
        </div>
    }

</main>















@code {







    private const int TraceMax = 10;







    private const string NoActiveProgramMessage = "No hay programa de Cabezal activo para Sistema Modular.";







    private readonly record struct MotorVisualSnapshot(int Position, int SelectedPositionNumber, string RunMode);







// [ACURATEX] Los modelos cargan el tablero completo y permiten reflejar el estado del firmware.







    private readonly List<CabezalMotorTarjetas> _denMotors = CabezalDashboardTarjetasProtocol.CreateDenMotors().ToList();







    private readonly List<CabezalMotorTarjetas> _sicMotors = CabezalDashboardTarjetasProtocol.CreateSicMotors().ToList();







    private readonly List<CabezalJGroupTarjetas> _jGroups = Enumerable.Range(1, 8).Select(number => new CabezalJGroupTarjetas(number)).ToList();







    private readonly List<CabezalOutputBlockTarjetas> _yarnBlocks = CabezalDashboardTarjetasProtocol.CreateYarnBlocks().ToList();







    private readonly List<CabezalOutputBlockTarjetas> _stitchBlocks = CabezalDashboardTarjetasProtocol.CreateStitchBlocks().ToList();







    private readonly Dictionary<string, CancellationTokenSource> _blockVisualRunTokens = new(StringComparer.OrdinalIgnoreCase);

    private const int BlockVisualRunPeriodMs = 80;

    private const int CanRxHistoryMax = 1000;



    private readonly object _canRxHistoryLock = new();



