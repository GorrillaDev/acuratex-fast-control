    {







        // [ACURATEX] En emergencia se detienen ciclos y se apaga el tablero para no dejar acciones pendientes.







        StopAllMotorRuns();







        StopAllJAnimations(restore: false);















        if (!HasActiveHeadProgram) {







            ResetHeadVisualStateToNeutral();







            _logLine = "PARADA DE EMERGENCIA ACTIVADA";







            await InvokeAsync(StateHasChanged);







            return;







        }















        await SendDoCommandInternalAsync("j_stop_all");







        await SendDoCommandInternalAsync("y_stop_all");







        await SendDoCommandInternalAsync("s_stop_all");







        await OffAllCoreAsync();















        ResetHeadVisualStateToNeutral();







        _logLine = "PARADA DE EMERGENCIA ACTIVADA";







        await InvokeAsync(StateHasChanged);







    }















