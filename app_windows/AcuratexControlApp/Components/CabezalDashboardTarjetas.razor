    private void ProcessHeadTestFrame(CanRxFrame frame)
    {
        if (!_headTestBusy && frame.Id != 0x702) {
            return;
        }

        HeadTestResult? result = _headTestDetector.Detect(frame);
        if (result is not null) {
            FinalizeHeadTest(result, timedOut: false);
            return;
        }

        if (!_headTestBusy) {
            return;
        }

        if (frame.Id == 0x700 && frame.Dlc > 0) {
            AddTrace("TESTEO", $"[TESTEO] RX700|CODE=0x{frame.Data[0]:X2}");
        } else if (frame.Id == 0x702 && frame.Dlc >= 2) {
            AddTrace("TESTEO", "[TESTEO] Re-arm 702 3F 00");
        }

        _headTestStatus = _headTestDetector.Status;
        _headTestMessage = _headTestDetector.Description;
        _ = InvokeAsync(StateHasChanged);
    }

    private void FinalizeHeadTest(HeadTestResult result, bool timedOut)
    {
        _headTestTimeoutCts?.Cancel();
        _headTestTimeoutCts?.Dispose();
        _headTestTimeoutCts = null;
        _headTestBusy = false;
        _headTestLastResult = result;
        _headTestStatus = result.Status;
        _headTestMessage = result.Description;
        _headProgramStatus = $"TESTEO {result.Status}";
        _logLine = result.Description;

        byte code = result.Data.Length > 0 ? result.Data[0] : (byte)0;
        AddTrace("TESTEO", $"[TESTEO] Resultado={result.Status} Codigo=0x{code:X2}");
        if (timedOut) {
            AddTrace("TESTEO", "[TESTEO] Sin respuesta CAN valida");
        }

        _ = InvokeAsync(StateHasChanged);
    }


