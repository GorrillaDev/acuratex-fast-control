    private async Task ApplyLocalDoCommandAsync(string command, bool sent)







    {







        if (string.Equals(command, "y_run_all", StringComparison.OrdinalIgnoreCase)) {
            StartAllBlockVisualRuns(_yarnBlocks);
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (string.Equals(command, "y_stop_all", StringComparison.OrdinalIgnoreCase)) {
            StopAllBlockVisualRuns(_yarnBlocks);
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (string.Equals(command, "s_run_all", StringComparison.OrdinalIgnoreCase)) {
            StartAllBlockVisualRuns(_stitchBlocks);
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (string.Equals(command, "s_stop_all", StringComparison.OrdinalIgnoreCase)) {
            StopAllBlockVisualRuns(_stitchBlocks);
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (string.Equals(command, "y1_run", StringComparison.OrdinalIgnoreCase)) {
            StartBlockVisualRun("yarn1");
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (string.Equals(command, "y2_run", StringComparison.OrdinalIgnoreCase)) {
            StartBlockVisualRun("yarn2");
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (string.Equals(command, "y1_stop", StringComparison.OrdinalIgnoreCase)) {
            StopBlockVisualRun("yarn1");
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (string.Equals(command, "y2_stop", StringComparison.OrdinalIgnoreCase)) {
            StopBlockVisualRun("yarn2");
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (string.Equals(command, "s_run_1", StringComparison.OrdinalIgnoreCase)) {
            StartBlockVisualRun("stitch1");
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (string.Equals(command, "s_run_2", StringComparison.OrdinalIgnoreCase)) {
            StartBlockVisualRun("stitch2");
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (string.Equals(command, "s_run_3", StringComparison.OrdinalIgnoreCase)) {
            StartBlockVisualRun("stitch3");
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (string.Equals(command, "s_run_4", StringComparison.OrdinalIgnoreCase)) {
            StartBlockVisualRun("stitch4");
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (string.Equals(command, "s_stop_1", StringComparison.OrdinalIgnoreCase)) {
            StopBlockVisualRun("stitch1");
