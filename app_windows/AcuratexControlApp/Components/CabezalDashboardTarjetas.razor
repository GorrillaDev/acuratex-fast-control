    private async Task SendTesteoAsync()
    {
        if (!CanExecuteHeadAction()) {
            return;
        }

        if (_headTestBusy) {
            _logLine = "TESTEO ya esta en curso.";
            return;
        }

        _headTestTimeoutCts?.Cancel();
        _headTestTimeoutCts?.Dispose();
        _headTestTimeoutCts = new CancellationTokenSource();
        _showHeadTestDetailModal = false;
        _headTestLastResult = null;

        _headTestDetector.Begin("CAN1");
        _headTestBusy = true;
        _headTestLastResult = null;
        _headTestStatus = "CONSULTANDO";
        _headTestMessage = "TESTEO: consultando cabezal...";
        AddTrace("TESTEO", "[TESTEO] Inicio");
        await InvokeAsync(StateHasChanged);

        bool sent = await SendTrackedAsync("CAN", "320 07", token => CommandService.SendCanLineAsync("320 07", token));
        if (!sent) {
            _headTestBusy = false;
            _headTestStatus = "ERROR";
            _headTestMessage = "TESTEO: error enviando 320 07.";
            AddTrace("TESTEO", "[TESTEO] Error al enviar 320 07");
            return;
        }

        _ = MonitorHeadTestTimeoutAsync(_headTestTimeoutCts.Token);
    }

    private async Task MonitorHeadTestTimeoutAsync(CancellationToken cancellationToken)
    {
        try {
            await Task.Delay(HeadTestTimeoutMs, cancellationToken);
        } catch (OperationCanceledException) {
            return;
        }

        if (!_headTestDetector.TryGetTimeoutResult(out HeadTestResult timeoutResult)) {
            return;
        }

        await InvokeAsync(() => FinalizeHeadTest(timeoutResult, timedOut: true));
    }

