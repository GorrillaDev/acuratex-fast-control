            StopBlockVisualRun(block.Key);
        }
    }

    private void StartBlockVisualRun(string blockKey)
    {
        CabezalOutputBlockTarjetas? block = FindBlock(blockKey);
        if (block is null) {
            return;
        }

        StopBlockVisualRun(blockKey);

        CancellationTokenSource cts = new();
        _blockVisualRunTokens[blockKey] = cts;
        _ = RunBlockVisualAsync(block, cts.Token);
    }

    private void StopBlockVisualRun(string blockKey)
    {
        if (!_blockVisualRunTokens.TryGetValue(blockKey, out CancellationTokenSource? cts)) {
            return;
        }

        cts.Cancel();
        cts.Dispose();
        _blockVisualRunTokens.Remove(blockKey);
    }

    private async Task RunBlockVisualAsync(CabezalOutputBlockTarjetas block, CancellationToken cancellationToken)
    {
        int pinIndex = 1;
        bool nextState = true;

        try {
            while (!cancellationToken.IsCancellationRequested) {
                int currentPin = pinIndex;
                bool currentState = nextState;

                await InvokeAsync(() =>
                {
                    block.States[currentPin - 1] = currentState;
                    StateHasChanged();
                });

                await Task.Delay(BlockVisualRunPeriodMs, cancellationToken);

                pinIndex++;
                if (pinIndex > block.PinCount) {
                    pinIndex = 1;
                    nextState = !nextState;
                }
            }
        } catch (OperationCanceledException) {
        }
    }

