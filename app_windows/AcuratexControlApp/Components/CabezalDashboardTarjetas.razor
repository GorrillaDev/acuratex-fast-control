            builder.AppendLine($"Descripcion: {_activeCanAlarm.Title}");
            if (_canAlarmPendingCount > 0) {
                builder.AppendLine($"{_canAlarmPendingCount} alertas pendientes");
            }

            builder.AppendLine();
            builder.AppendLine(_activeCanAlarm.Message);

            List<string> notes = _canAlarmActivity.ToList();
            if (notes.Count > 0) {
