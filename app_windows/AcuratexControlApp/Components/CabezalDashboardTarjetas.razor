    public void Dispose()







    {







        // [ACURATEX] Se quitan handlers y se paran ciclos para no dejar trabajo vivo al cerrar.







        Connection.LineReceived -= OnLineReceived;







        HeadProfileService.StateChanged -= OnHeadProfileStateChanged;







        EmergencyStop.StateChanged -= OnEmergencyStateChanged;







        EmergencyStop.EmergencyStopTriggered -= HandleEmergencyStopAsync;







        StopAllMotorRuns();







        StopAllJAnimations(restore: false);







        CloseCanRxHistory();







        ClearCanRxHistory();







        CloseCanRxHistory();







        ClearCanRxHistory();

        _headTestTimeoutCts?.Cancel();
        _headTestTimeoutCts?.Dispose();
        _headTestTimeoutCts = null;
        _headTestDetector.Cancel();
        _headTestBusy = false;
        _headTestLastResult = null;
        _showHeadTestDetailModal = false;
        _headTestStatus = "IDLE";
        _headTestMessage = "TESTEO: listo.";
        lock (_canAlarmLock) {
            _pendingCanAlarms.Clear();
            _canAlarmActivity.Clear();
            _canAlarmDeduplication.Clear();
            _activeCanAlarm = null;
            _alarmHaltActive = false;
            _showCanAlarmModal = false;
            _canAlarmPendingCount = 0;
        }








    }







