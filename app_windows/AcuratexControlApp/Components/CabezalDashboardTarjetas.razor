            if (_canAlarmHistory.Count == 0) {
                return "Sin alertas registradas.";
            }

            System.Text.StringBuilder builder = new();
            builder.AppendLine("HISTORIAL DE ALERTAS CAN");
            foreach (CanAlarmHistoryItem item in _canAlarmHistory) {
                builder.AppendLine($"[{item.Status}] {item.DetectedAt:HH:mm:ss.fff} | {item.AlarmType} | {item.Title} | {item.Bus} | 0x{item.CanId:X3} | DLC={item.Dlc} | DATA={FormatCanRxData(item.Data)}");
