    private void ProcessCanAlarm(CanRxFrame frame)
    {
        CanAlarmInfo? alarm = CanAlarmDetector.Detect(frame);
        if (alarm is null) {
            return;
        }

        CanAlarmHistoryItem historyItem = CreateCanAlarmHistoryItem(alarm, "PENDIENTE");
        bool render = false;

        lock (_canAlarmLock) {
            string key = BuildCanAlarmKey(alarm);
            if (_canAlarmDeduplication.TryGetValue(key, out DateTime lastSeen) && (alarm.DetectedAt - lastSeen) < TimeSpan.FromMilliseconds(1200)) {
                return;
            }

            _canAlarmDeduplication[key] = alarm.DetectedAt;
            AddCanAlarmHistoryLocked(historyItem);

            if (_activeCanAlarm is null) {
                _activeCanAlarm = alarm;
                _activeCanAlarmHistoryItem = historyItem;
                _alarmHaltActive = true;
                _showCanAlarmModal = true;
                _canAlarmPendingCount = _pendingCanAlarms.Count;
                _canAlarmActivity.Clear();
                historyItem.Status = "ACTIVA";
                AppendCanAlarmActivityLocked($"[ALARM] Detectada ID=0x{alarm.Id:X3} TYPE={alarm.AlarmType}");
                AppendCanAlarmActivityLocked("[ALARM] HALT activado");
                AddTrace("ALARM", "[ALARM] HALT activado");
                render = true;
            } else {
                if (_pendingCanAlarms.Count >= CanAlarmQueueMax) {
                    var dropped = _pendingCanAlarms.Dequeue();
                    AppendCanAlarmActivityLocked("[ALARM] Cola llena: se descarto la mas antigua");
                    AddTrace("ALARM", "[ALARM] Cola llena: se descarto la mas antigua");
                }

                historyItem.Status = "PENDIENTE";
                _pendingCanAlarms.Enqueue((alarm, historyItem));
                _canAlarmPendingCount = _pendingCanAlarms.Count;
                AppendCanAlarmActivityLocked($"[ALARM] Pendiente ID=0x{alarm.Id:X3} TYPE={alarm.AlarmType}");
                AddTrace("ALARM", $"[ALARM] Pendiente ID=0x{alarm.Id:X3} TYPE={alarm.AlarmType}");
                render = true;
            }
        }

        AddTrace("ALARM", $"Detectada ID=0x{alarm.Id:X3} TYPE={alarm.AlarmType}");
        if (render) {
            _ = InvokeAsync(StateHasChanged);
        }
    }

    private static string BuildCanAlarmKey(CanAlarmInfo alarm)
    {
        if (alarm.AlarmType.Equals("HB_C1", StringComparison.OrdinalIgnoreCase)) {
            int node = checked((int)(alarm.Id - 0x700));
            return $"HB_C1|{node}";
        }

        int motor = checked((int)(alarm.Id - 0x70F));
        return $"MOTOR|{motor}|0x{alarm.Data[3]:X2}";
    }

    private static CanAlarmHistoryItem CreateCanAlarmHistoryItem(CanAlarmInfo alarm, string status)
    {
        return new CanAlarmHistoryItem
        {
            DetectedAt = alarm.DetectedAt,
            ClosedAt = null,
            Status = status,
            AlarmType = alarm.AlarmType,
            Title = alarm.Title,
            Description = alarm.Message,
            Bus = alarm.Bus,
            CanId = alarm.Id,
            Dlc = alarm.Dlc,
            Data = alarm.Data,
            RawLine = alarm.RawLine,
        };
    }

    private void AddCanAlarmHistoryLocked(CanAlarmHistoryItem item)
    {
        _canAlarmHistory.Add(item);
        while (_canAlarmHistory.Count > CanAlarmHistoryMax) {
            int removeIndex = _canAlarmHistory.FindIndex(static entry => string.Equals(entry.Status, "CERRADA", StringComparison.OrdinalIgnoreCase));
            if (removeIndex < 0) {
                removeIndex = 0;
            }

            CanAlarmHistoryItem removed = _canAlarmHistory[removeIndex];
            _canAlarmHistory.RemoveAt(removeIndex);
            if (ReferenceEquals(_selectedCanAlarmHistoryItem, removed)) {
                _selectedCanAlarmHistoryItem = null;
            }
        }
    }

    private void AppendCanAlarmActivityLocked(string entry)
    {
        if (string.IsNullOrWhiteSpace(entry)) {
            return;
        }

        _canAlarmActivity.Add(entry.Trim());
        const int alarmNoteMax = 24;
        if (_canAlarmActivity.Count > alarmNoteMax) {
            _canAlarmActivity.RemoveRange(0, _canAlarmActivity.Count - alarmNoteMax);
        }
    }

    private void AppendCanAlarmActivity(string entry)
    {
        lock (_canAlarmLock) {
            AppendCanAlarmActivityLocked(entry);
        }
    }

