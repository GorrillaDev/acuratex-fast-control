    private async Task RunDenLoopAsync(CabezalMotorTarjetas motor, IReadOnlyList<int> sequence, int periodMs, CancellationToken cancellationToken, string mode)







    {







        int step = 0;







        try {







            while (!cancellationToken.IsCancellationRequested) {







                int positionNumber = sequence[step % sequence.Count];







                CabezalPositionTarjetas option = motor.Positions.First(position => position.Number == positionNumber);















                await InvokeAsync(() =>







                {







                    motor.Position = option.Value;







                    motor.SelectedPositionNumber = option.Number;







                    motor.RunMode = mode;







                    StateHasChanged();







                    return Task.CompletedTask;







                });















                step++;







                await Task.Delay(periodMs, cancellationToken);







            }







        } catch (OperationCanceledException) {







        }







    }















    private async Task RunSicLoopAsync(CabezalMotorTarjetas motor, CancellationToken cancellationToken)







    {







        int step = 0;







        try {







            while (!cancellationToken.IsCancellationRequested) {







                int positionNumber = CabezalDashboardTarjetasProtocol.SicRunSequence[step % CabezalDashboardTarjetasProtocol.SicRunSequence.Length];







                CabezalPositionTarjetas option = motor.Positions.First(position => position.Number == positionNumber);







                await InvokeAsync(() =>







                {







                    motor.Position = option.Value;







                    motor.SelectedPositionNumber = option.Number;







                    motor.RunMode = "RUN";







                    StateHasChanged();







                    return Task.CompletedTask;







                });















                step++;







                await Task.Delay(CabezalDashboardTarjetasProtocol.SicRunPeriodMs, cancellationToken);







            }







        } catch (OperationCanceledException) {







        }







    }















    private async Task<bool> SendTrackedAsync(string direction, string message, Func<CancellationToken, Task> sender)







    {







        // [ACURATEX] Esta funcion unifica trazas, ultimo comando y captura de errores para todo el tablero.







        string cleanMessage = message.Trim();







        if (cleanMessage.Length == 0) {







            return false;







        }















        AddTrace(direction, cleanMessage);







        _lastCommand = cleanMessage;







        _logLine = $"{direction} => {cleanMessage}";















        try {







            await sender(CancellationToken.None);







            return true;







        } catch (Exception ex) {







            AddTrace("ERR", ex.Message);







            _logLine = $"Error: {ex.Message}";







            _headProgramStatus = ex.Message;







            return false;







        }







    }















    private void OnLineReceived(string line)







    {







        // [EQUIV MCU] Esto actua como un callback de recepcion serial: llega una trama y se actualizan registros.







        _ = InvokeAsync(() =>







        {







            _lastRx = string.IsNullOrWhiteSpace(line) ? "(vacio)" : line.Trim();







            AddTrace("RX", _lastRx);







            if (TryParseCanRxLine(_lastRx, out CanRxFrame frame, out string canRxError)) {







                lock (_canRxHistoryLock)







                {







                    _canRxHistory.Add(frame);







                    if (_canRxHistory.Count > CanRxHistoryMax) {







                        _canRxHistory.RemoveRange(0, _canRxHistory.Count - CanRxHistoryMax);







                    }







                }
                ProcessCanAlarm(frame);
                ProcessHeadTestFrame(frame);

            } else if (_lastRx.StartsWith("CAN_RX|", StringComparison.OrdinalIgnoreCase)) {
                _logLine = string.IsNullOrWhiteSpace(canRxError) ? "CAN_RX invalida" : $"CAN_RX invalida: {canRxError}";
            }







            if (_alarmHaltActive && !string.IsNullOrWhiteSpace(_lastRx) && !_lastRx.StartsWith("CAN_RX|", StringComparison.OrdinalIgnoreCase)) {
                AppendCanAlarmActivity(_lastRx);
            }

            if (HeadStateEventParser.TryParse(_lastRx, out HeadStateEvent? stateEvent) && stateEvent is not null) {







                ApplyHeadStateEvent(stateEvent);







            } else if (_lastRx.StartsWith("TESTEO|", StringComparison.OrdinalIgnoreCase)







                || _lastRx.StartsWith("INIT|", StringComparison.OrdinalIgnoreCase)) {







                _headProgramStatus = _lastRx;







                if (_lastRx.StartsWith("TESTEO|ERROR", StringComparison.OrdinalIgnoreCase)







                    || _lastRx.StartsWith("INIT|ERROR", StringComparison.OrdinalIgnoreCase)) {







                    _ = EmergencyStop.ExecuteEmergencyStopAsync("FAST_DIAG");







                }







            } else if (_lastRx.Equals("QUEUED", StringComparison.OrdinalIgnoreCase)







                || _lastRx.Equals("OK", StringComparison.OrdinalIgnoreCase)







                || (_lastRx.StartsWith("OK ", StringComparison.OrdinalIgnoreCase)







                    && !_lastRx.StartsWith("OK|HEAD_ACTION|", StringComparison.OrdinalIgnoreCase))) {







                _headProgramStatus = _lastRx;







            } else if (_lastRx.StartsWith("ERR|HEAD_ACTION", StringComparison.OrdinalIgnoreCase)) {







                _headProgramStatus = _lastRx;







            } else if (_lastRx.StartsWith("OK|HEAD_ACTION|", StringComparison.OrdinalIgnoreCase)) {







                _headProgramStatus = $"Accion confirmada por firmware: {_lastRx["OK|HEAD_ACTION|".Length..]}";







            }







            StateHasChanged();







        });







    }















    private void ApplyHeadStateEvent(HeadStateEvent stateEvent)







    {







        if (stateEvent.StateType.Equals("POS", StringComparison.OrdinalIgnoreCase)) {







            ApplyPositionStateEvent(stateEvent);







        } else if (stateEvent.StateType.Equals("CH", StringComparison.OrdinalIgnoreCase)) {







            ApplyChannelStateEvent(stateEvent);







        } else if (stateEvent.StateType.Equals("RUN", StringComparison.OrdinalIgnoreCase)







            || stateEvent.StateType.Equals("RUN1", StringComparison.OrdinalIgnoreCase)) {







            ApplyRunStateEvent(stateEvent);







        }















        _headProgramStatus = $"Estado Cabezal actualizado: {stateEvent.InstanceName}.{stateEvent.StateType}";







    }















    private void ApplyPositionStateEvent(HeadStateEvent stateEvent)







    {







        int positionNumber = FirstSetBitNumber(stateEvent.Mask);







        if (positionNumber <= 0) {







            return;







        }















        if (TryParseInstanceIndex(stateEvent.InstanceName, "DEN", out int denIndex)







            && denIndex >= 0







            && denIndex < _denMotors.Count) {







            // DEN usa estado visual local; HEAD_STATE queda solo en el log.
            return;







            return;







        }















        if (TryParseInstanceIndex(stateEvent.InstanceName, "SIC", out int sicIndex)







            && sicIndex >= 0







            && sicIndex < _sicMotors.Count) {







            // SIC usa estado visual local; HEAD_STATE queda solo en el log.
            return;







            return;







        }















        if (false && TryParseInstanceIndex(stateEvent.InstanceName, "STITCH", out int stitchIndex)) {







            CabezalOutputBlockTarjetas? block = FindBlock($"stitch{stitchIndex + 1}");







            if (block is not null) {







                ApplyBlockMask(block, stateEvent.Mask);







            }







        }







    }















    private static void ApplyMotorPositionState(CabezalMotorTarjetas motor, int positionNumber, int? value)







    {







        CabezalPositionTarjetas? knownPosition = motor.Positions.FirstOrDefault(position => position.Number == positionNumber);







        motor.SelectedPositionNumber = positionNumber;







        motor.Position = value ?? knownPosition?.Value ?? 0;







    }















    private void ApplyChannelStateEvent(HeadStateEvent stateEvent)







    {







        if (TryParseInstanceIndex(stateEvent.InstanceName, "J", out int jIndex)







            && jIndex >= 0







            && jIndex < _jGroups.Count) {







            _jGroups[jIndex].Register = (byte)(~stateEvent.Mask & 0xFF);







            return;







        }















        if (false && TryParseInstanceIndex(stateEvent.InstanceName, "YARN", out int yarnIndex)) {







            CabezalOutputBlockTarjetas? block = FindBlock($"yarn{yarnIndex + 1}");







            if (block is not null) {







                ApplyBlockMask(block, stateEvent.Mask);







            }







        }







    }















    private void ApplyRunStateEvent(HeadStateEvent stateEvent)







    {







        bool isActive = stateEvent.Mask != 0;







        string runMode = stateEvent.StateType.Equals("RUN1", StringComparison.OrdinalIgnoreCase) ? "RUN1" : "RUN";















        if (TryParseInstanceIndex(stateEvent.InstanceName, "DEN", out int denIndex)







            && denIndex >= 0







            && denIndex < _denMotors.Count) {







            // DEN usa estado visual local; HEAD_STATE queda solo en el log.
            return;







            return;







        }















        if (TryParseInstanceIndex(stateEvent.InstanceName, "SIC", out int sicIndex)







            && sicIndex >= 0







            && sicIndex < _sicMotors.Count) {







            // SIC usa estado visual local; HEAD_STATE queda solo en el log.
            return;







        }







    }















    private static void ApplyBlockMask(CabezalOutputBlockTarjetas block, int mask)







    {







        for (int index = 0; index < block.States.Length; index++) {







            block.States[index] = ((mask >> index) & 0x01) != 0;







        }







    }















    private static bool TryParseInstanceIndex(string instanceName, string prefix, out int zeroBasedIndex)







    {







        zeroBasedIndex = -1;







        if (string.IsNullOrWhiteSpace(instanceName)







            || !instanceName.StartsWith(prefix, StringComparison.OrdinalIgnoreCase)) {







            return false;







        }















        string numberText = instanceName[prefix.Length..];







        if (!int.TryParse(numberText, out int parsedNumber) || parsedNumber <= 0) {







            return false;







        }















        zeroBasedIndex = parsedNumber - 1;







        return true;







    }















    private static int FirstSetBitNumber(int mask)







    {







        if (mask <= 0) {







            return 0;







        }















        for (int bit = 0; bit < 31; bit++) {







            if ((mask & (1 << bit)) != 0) {







                return bit + 1;







            }







        }















        return 0;







    }















