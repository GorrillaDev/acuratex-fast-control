    private async Task CloseCanAlarmAsync()
    {
        bool render = false;
        string? trace = null;

        lock (_canAlarmLock) {
            if (_activeCanAlarm is null) {
                _showCanAlarmModal = false;
                _alarmHaltActive = false;
                _canAlarmPendingCount = 0;
                return;
            }

            if (_activeCanAlarmHistoryItem is not null) {
                _activeCanAlarmHistoryItem.Status = "CERRADA";
                _activeCanAlarmHistoryItem.ClosedAt = DateTime.Now;
            }

            AppendCanAlarmActivityLocked("[ALARM] Cerrada");
            if (_pendingCanAlarms.Count > 0) {
                (CanAlarmInfo Alarm, CanAlarmHistoryItem HistoryItem) next = _pendingCanAlarms.Dequeue();
                _activeCanAlarm = next.Alarm;
                _activeCanAlarmHistoryItem = next.HistoryItem;
                _activeCanAlarmHistoryItem.Status = "ACTIVA";
                _activeCanAlarmHistoryItem.ClosedAt = null;
                _canAlarmPendingCount = _pendingCanAlarms.Count;
                _canAlarmActivity.Clear();
                AppendCanAlarmActivityLocked($"[ALARM] Detectada ID=0x{_activeCanAlarm.Id:X3} TYPE={_activeCanAlarm.AlarmType}");
                AppendCanAlarmActivityLocked("[ALARM] HALT activado");
                AddTrace("ALARM", "[ALARM] HALT activado");
                trace = $"[ALARM] Siguiente alerta ID=0x{_activeCanAlarm.Id:X3} TYPE={_activeCanAlarm.AlarmType}";
                _showCanAlarmModal = true;
                _alarmHaltActive = true;
            } else {
                _activeCanAlarm = null;
                _activeCanAlarmHistoryItem = null;
                _alarmHaltActive = false;
                _showCanAlarmModal = false;
                _canAlarmPendingCount = 0;
                AppendCanAlarmActivityLocked("[ALARM] HALT liberado");
                AddTrace("ALARM", "[ALARM] HALT liberado");
                trace = "[ALARM] HALT liberado";
            }

            render = true;
        }

        if (!string.IsNullOrWhiteSpace(trace)) {
            AddTrace("ALARM", trace);
        }

        if (render) {
            await InvokeAsync(StateHasChanged);
        }
    }

