        if (TryParseJDoCommand(command, "j_stop_", out int jStopIndex)) {







            StopJAnimation(jStopIndex, restore: true);







            await InvokeAsync(StateHasChanged);







            return;







        }















        if (TryParseIndexedCommand(command, "den_run1_", _denMotors.Count, out int denRun1Index)) {







            if (sent) {







                CabezalMotorTarjetas motor = _denMotors[denRun1Index - 1];







