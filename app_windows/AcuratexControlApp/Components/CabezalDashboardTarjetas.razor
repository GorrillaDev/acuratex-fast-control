                }
                if (item.ClosedAt.HasValue) {
                    builder.AppendLine($"Cerrada: {item.ClosedAt:HH:mm:ss.fff}");
                }
                if (!string.IsNullOrWhiteSpace(item.RawLine)) {
                    builder.AppendLine(item.RawLine);
                }
                builder.AppendLine();
            }

            return builder.ToString().TrimEnd();
        }
    }

    private string BuildCanAlarmClipboardText()
