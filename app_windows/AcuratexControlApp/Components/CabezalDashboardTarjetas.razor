    private Task StartDenLoopAsync(CabezalMotorTarjetas motor, IReadOnlyList<int> sequence, int periodMs, string mode)







    {







        int index = motor.LogicalIndex;







        CancellationTokenSource? previousToken = _denRunTokens[index];







        if (previousToken != null && motor.RunMode == mode) {







            return Task.CompletedTask;







        }















        if (_denRunSnapshots[index] is null) {







            _denRunSnapshots[index] = new MotorVisualSnapshot(motor.Position, motor.SelectedPositionNumber, motor.RunMode);







        }















        if (previousToken != null) {







            previousToken.Cancel();







            previousToken.Dispose();







            _denRunTokens[index] = null;







        }















        motor.RunMode = mode;







        CancellationTokenSource cts = new();







        _denRunTokens[index] = cts;







        _ = RunDenLoopAsync(motor, sequence, periodMs, cts.Token, mode);







        return Task.CompletedTask;







    }















