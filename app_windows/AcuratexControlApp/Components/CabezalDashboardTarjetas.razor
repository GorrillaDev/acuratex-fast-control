    private void StopDenRun(CabezalMotorTarjetas motor, bool restore = false)







    {







        int index = motor.LogicalIndex;







        CancellationTokenSource? token = _denRunTokens[index];







        if (token != null) {







            token.Cancel();







            token.Dispose();







            _denRunTokens[index] = null;







        }















        if (restore && token != null) {







            RestoreDenSnapshot(index);







        } else if (!restore) {







            _denRunSnapshots[index] = null;







            motor.RunMode = string.Empty;







        } else if (token == null) {







            motor.RunMode = string.Empty;







        }







    }















