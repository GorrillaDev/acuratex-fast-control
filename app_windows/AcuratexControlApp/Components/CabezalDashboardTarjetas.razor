    private static bool TryParseCanRxLine(string line, out CanRxFrame frame, out string error)







    {







        frame = default!;







        error = string.Empty;















        if (string.IsNullOrWhiteSpace(line) || !line.StartsWith("CAN_RX|", StringComparison.Ordinal))







        {







            error = "prefijo";







            return false;







        }















        string payload = line["CAN_RX|".Length..];







        string? bus = null;







        string? idText = null;







        string? dlcText = null;







        string? dataText = null;















        foreach (string rawPart in payload.Split('|'))







        {







            string part = rawPart.Trim();







            if (part.Length == 0)







            {







                continue;







            }















            int separator = part.IndexOf('=');







            if (separator <= 0 || separator == part.Length - 1)







            {







                error = "campo";







                return false;







            }















            string key = part[..separator].Trim();







            string value = part[(separator + 1)..].Trim();















            switch (key.ToUpperInvariant())







            {







                case "BUS":







                    bus = value;







                    break;







                case "ID":







                    idText = value;







                    break;







                case "DLC":







                    dlcText = value;







                    break;







                case "DATA":







                    dataText = value;







                    break;







                case "TIME":







                    break;







            }







        }















        if (!string.Equals(bus, "CAN1", StringComparison.OrdinalIgnoreCase)







            && !string.Equals(bus, "CAN2", StringComparison.OrdinalIgnoreCase))







        {







            error = "bus";







            return false;







        }















        if (string.IsNullOrWhiteSpace(idText) || string.IsNullOrWhiteSpace(dlcText))







        {







            error = "id/dlc";







            return false;







        }















        string normalizedId = idText.Trim();







        if (normalizedId.StartsWith("0x", StringComparison.OrdinalIgnoreCase))







        {







            normalizedId = normalizedId[2..];







        }















        if (!uint.TryParse(normalizedId, System.Globalization.NumberStyles.HexNumber, System.Globalization.CultureInfo.InvariantCulture, out uint id)







            || id > 0x7FF)







        {







            error = "id";







            return false;







        }















        if (!int.TryParse(dlcText, out int dlc) || dlc < 0 || dlc > 8)







        {







            error = "dlc";







            return false;







        }















        string dataValue = dataText?.Trim() ?? string.Empty;







        byte[] data = Array.Empty<byte>();







        if (dlc > 0)







        {







            string[] tokens = dataValue.Split(new[] { ' ' }, StringSplitOptions.RemoveEmptyEntries);







            if (tokens.Length != dlc)







            {







                error = "data-count";







                return false;







            }















            data = new byte[dlc];







            for (int index = 0; index < tokens.Length; index++)







            {







                if (!byte.TryParse(tokens[index], System.Globalization.NumberStyles.HexNumber, System.Globalization.CultureInfo.InvariantCulture, out byte value))







                {







                    error = "data";







                    return false;







                }















                data[index] = value;







            }







        }







        else if (dataValue.Length > 0)







        {







            error = "data-empty";







            return false;







        }















        frame = new CanRxFrame(DateTime.Now, bus!.ToUpperInvariant(), id, dlc, data, line);







        return true;







    }















